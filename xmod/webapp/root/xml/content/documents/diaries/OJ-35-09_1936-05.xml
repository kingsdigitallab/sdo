   <sdo:record ID="r0008">
      <sdo:itemDesc>
         <dc:title>Diary entry by Jeanette Schenker May 9, 1936</dc:title>
         <dcterms:created>1936-05-09T12:00:00Z</dcterms:created>
         <dcterms:dateSubmitted>The Date of Electronic Creation Goes Here:
            2024-09-06</dcterms:dateSubmitted>
         <dc:description/>
         <dc:subject/>
