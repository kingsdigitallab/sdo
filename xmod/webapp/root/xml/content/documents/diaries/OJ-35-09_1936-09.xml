   <sdo:record ID="r0009">
      <sdo:itemDesc>
         <dc:title>Diary entry by Jeanette Schenker September 9, 1936</dc:title>
         <dcterms:created>1936-09-09T12:00:00Z</dcterms:created>
         <dcterms:dateSubmitted>The Date of Electronic Creation Goes Here:
            2024-09-12</dcterms:dateSubmitted>
