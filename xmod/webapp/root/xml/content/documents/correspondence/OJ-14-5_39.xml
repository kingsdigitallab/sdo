      <tei:addrLine>To: <tei:handShift new="#MS"/>Professor Heinrich Schenker, Esq.</tei:addrLine>
      <tei:addrLine rend="indent-50"><tei:handShift new="#printed"/>in <tei:handShift new="#MS"
