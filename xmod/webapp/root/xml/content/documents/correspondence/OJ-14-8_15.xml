  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-008461">SchiffP ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-008460">SchiffA ~
        H+JSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Typewritten and handwritten letter with envelope from Paul &amp; Anna Schiff to
        Jeanette Schenker, postmarked February 1, 1938</dc:title>

      <dcterms:created>1938-02-01T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-02-12</dcterms:dateSubmitted>
      <dc:description>Paul and Anna Schiff have moved from Karlsbad back to Prague. They marvel at
        Jeanette’s work on her late husband’s papers and on a new edition of one of his books. —
        They give news about the family and ask her to write before her next
        travels.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000782">Paul Schiff</marcrel:correspondent>
      <marcrel:correspondent key="entity-000781">Anna Schiff</marcrel:correspondent>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:div type="part_1">
        <tei:opener>
          <tei:fw type="envelope">
            <tei:note type="editorial" place="inline"><tei:hi rend="bold"
              >Envelope</tei:hi></tei:note><tei:lb/>
            <tei:milestone unit="folio" n="recto"/><tei:lb/>
            <tei:address>
              <tei:addrLine><tei:supplied reason="clarity">An:</tei:supplied>
                <tei:handShift new="#TPps"/>Wohlgeboren Frau Dr. Lie-Lie Schenker,</tei:addrLine>
              <tei:addrLine><tei:hi rend="underline">WIEN – 1</tei:hi></tei:addrLine>
              <tei:addrLine>Reichsratsstrasse 7/19.</tei:addrLine>
              <tei:addrLine><tei:hi rend="underline">Oesterreich.</tei:hi></tei:addrLine>
            </tei:address>
            <tei:fw type="postmark">|| PRAHA 25 | 1. II. 38 – 23 | ch2 | x m ||</tei:fw><tei:lb/>
            <tei:add><tei:handShift new="#JS"/>Antw. <tei:date when="1938-03-27">27. III.
                38</tei:date></tei:add><tei:lb/><tei:lb/>
            <tei:milestone unit="folio" n="verso"/><tei:lb/>
            <tei:address>
              <tei:addrLine><tei:handShift new="#TPps"/>Schiff, <tei:rs type="place"
                  key="entity-002892">Praha</tei:rs> – XIII <tei:add place="interlinear-above"
                    ><tei:handShift new="#PS"/>Strašnice,</tei:add>
              </tei:addrLine>
              <tei:addrLine><tei:handShift new="#TPps"/>Nad Primaskou 13.</tei:addrLine>
            </tei:address>
          </tei:fw>
          <tei:note type="editorial" place="inline"><tei:hi rend="bold">Letter</tei:hi></tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#TPps"/>Paul Schiff,</tei:addrLine>
            <tei:addrLine><tei:rs type="place" key="entity-002892">Prag</tei:rs>- Strašnice 202/13
              (Praha-XIII).</tei:addrLine>
            <tei:addrLine>Nad Primaskou.</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:salute>Liebe <tei:rs type="person" key="entity-000771"
            >Schwester</tei:rs>,[1]</tei:salute>
        </tei:opener>

        <tei:p rend="first">Du </tei:p>

        <tei:p rend="first">Wir </tei:p>

        <tei:p rend="first">Ich </tei:p>

        <tei:p rend="first"><tei:pb n="2"/>
          <tei:rs type="person" key="entity-006478">Emma</tei:rs>
        </tei:p>

        <tei:p rend="first"><tei:rs type="person" key="entity-008429">Liesl</tei:rs>
        </tei:p>

        <tei:p rend="first">Wenn </tei:p>


        <tei:closer>
          <tei:salute>und sei aufs herzlichste gegrüsst von</tei:salute>
          <tei:salute rend="indent-80">Deinem</tei:salute>
          <tei:signed rend="indent-90"><tei:handShift new="#PS"/><tei:rs type="person"
              key="entity-000782">Paul</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_2">

        <tei:opener>
          <tei:salute>
            <tei:handShift new="#AS"/>Liebe <tei:rs type="person" key="entity-000771"
              >Lie-Lie</tei:rs>!</tei:salute>
        </tei:opener>

        <tei:p>Wir </tei:p>

        <tei:p>Bitte </tei:p>

        <tei:closer>
          <tei:salute rend="indent-20">Es umarmen Dich herzlich</tei:salute>
          <tei:signed rend="indent-80"><tei:rs type="person" key="entity-000781">Anna</tei:rs> und
              <tei:rs type="person" key="entity-008429">Lisl</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>



    <tei:div type="translation">

      <tei:div type="part_1">
        <tei:opener>
          <tei:fw type="envelope">
            <tei:note type="editorial" place="inline"><tei:hi rend="bold"
              >Envelope</tei:hi></tei:note><tei:lb/>
            <tei:milestone unit="folio" n="recto"/><tei:lb/>
            <tei:address>
              <tei:addrLine><tei:supplied reason="clarity">To:</tei:supplied>
                <tei:handShift new="#TPps"/>Esteemed Mrs. Lie-Lie Schenker</tei:addrLine>
              <tei:addrLine>Reichsratsstrasse 7/19</tei:addrLine>
              <tei:addrLine><tei:hi rend="underline">VIENNA – 1</tei:hi></tei:addrLine>
              <tei:addrLine><tei:hi rend="underline">Austria</tei:hi></tei:addrLine>
            </tei:address>
            <tei:fw type="postmark">|| PRAGUE 25 | 1. II. 38 – 23 | ch2 | x m ||</tei:fw><tei:lb/>
            <tei:add><tei:handShift new="#JS"/>Answered <tei:date when="1938-03-27">March 27, 1938</tei:date></tei:add><tei:lb/><tei:lb/>
            <tei:milestone unit="folio" n="verso"/><tei:lb/>
            <tei:address>
              <tei:addrLine><tei:handShift new="#TPps"/>Schiff, <tei:rs type="place"
                key="entity-002892">Prague</tei:rs> – XIII <tei:add place="interlinear-above"
                  ><tei:handShift new="#PS"/>Strašnice,</tei:add>
              </tei:addrLine>
              <tei:addrLine><tei:handShift new="#TPps"/>Nad Primaskou 13</tei:addrLine>
            </tei:address>
          </tei:fw>
          <tei:note type="editorial" place="inline"><tei:hi rend="bold">Letter</tei:hi></tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#TPps"/>Paul Schiff</tei:addrLine>
            <tei:addrLine><tei:rs type="place" key="entity-002892">Prague</tei:rs>- Strašnice 202/13
              (Prague XIII)</tei:addrLine>
            <tei:addrLine>Nad Primaskou</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:salute>Dear <tei:rs type="person" key="entity-000771"
            >Sister</tei:rs>,[1]</tei:salute>
        </tei:opener>
        
        <tei:p rend="first">I hope </tei:p>
        
        <tei:p rend="first">We </tei:p>
        
        <tei:p rend="first">At </tei:p>
        
        <tei:p rend="first"><tei:pb n="2"/>
          <tei:rs type="person" key="entity-006478">Emma</tei:rs>
        </tei:p>
        
        <tei:p rend="first">At the moment, <tei:rs type="person" key="entity-008429">Liesl</tei:rs>
        </tei:p>
        
        <tei:p rend="first">We </tei:p>
        
        
        <tei:closer>
          <tei:salute>and receive the most cordial greetings from</tei:salute>
          <tei:salute rend="indent-80">Your</tei:salute>
          <tei:signed rend="indent-90"><tei:handShift new="#PS"/><tei:rs type="person"
            key="entity-000782">Paul</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>
      
      <tei:div type="part_2">
        
        <tei:opener>
          <tei:salute>
            <tei:handShift new="#AS"/>Dear <tei:rs type="person" key="entity-000771"
              >Lie-Lie</tei:rs>,</tei:salute>
        </tei:opener>
        
        <tei:p>We </tei:p>
        
        <tei:p>Please </tei:p>
        
        <tei:closer>
          <tei:salute rend="indent-20">We embrace you cordially</tei:salute>
          <tei:signed rend="indent-80"><tei:rs type="person" key="entity-000781">Anna</tei:rs> and
            <tei:rs type="person" key="entity-008429">Lisl</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>

  </sdo:record>
