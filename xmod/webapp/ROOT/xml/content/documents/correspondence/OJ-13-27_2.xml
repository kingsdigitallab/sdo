  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-008521">RoentgenJ ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Handwritten letter from Julius Röntgen to Schenker, dated April 22, 1901</dc:title>

      <dcterms:created>1901-04-22T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-10-05</dcterms:dateSubmitted>
      <dc:description>Röntgen comments favorably on two compositions by Schenker; he plans to play
        through the songs when in the coming days Johannes Messchaert visits him. -- He is working on
        one of his editorial commitments for Universal Edition.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-008632">HSchenker</marcrel:correspondent>
      <marcrel:recipient key="entity-000724">RöntgenJ</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:dateline rend="indent-30"><tei:handShift new="#JR"/>Amsterdam, <tei:date
          when="1901-04-22">22 April 1901</tei:date></tei:dateline><tei:lb/>
        <tei:salute>Verehrtester Herr <tei:rs type="person" key="entity-000632"
            >Doctor</tei:rs>[1]</tei:salute>
      </tei:opener>

      <tei:p>Endlich </tei:p>

      <tei:p>Sie</tei:p>

      <tei:p>Soweit </tei:p>

      <tei:p>Mit </tei:p>

      <tei:p>“Ausklang” </tei:p>

      <tei:p><tei:rs type="person" key="entity-000592">Messchaert</tei:rs> </tei:p>

      <tei:p>Und </tei:p>

      <tei:closer>
        <tei:salute rend="indent-40">Ihren Sie verehrenden</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000724">Julius
            Röntgen</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:dateline rend="indent-30"><tei:handShift new="#JR"/>Amsterdam, <tei:date
          when="1901-04-22">Apri 22, 1901</tei:date></tei:dateline><tei:lb/>
        <tei:salute>Most revered <tei:rs type="person" key="entity-000632"
          >Dr. <tei:supplied reason="identity">Schenker</tei:supplied></tei:rs>[1]</tei:salute>
      </tei:opener>
      
      <tei:p>At </tei:p>
      
      <tei:p>In </tei:p>
      
      <tei:p>Considering </tei:p>
      
      <tei:p>I have </tei:p>
      
      <tei:p>To </tei:p>
      
      <tei:p><tei:rs type="person" key="entity-000592">Messchaert</tei:rs> </tei:p>
      
      <tei:p>And </tei:p>
      
      <tei:closer>
        <tei:salute rend="indent-40">Yours, in great admiration,</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000724">Julius
          Röntgen</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
