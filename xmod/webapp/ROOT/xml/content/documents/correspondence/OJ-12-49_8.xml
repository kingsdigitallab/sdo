  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005509">Gesellschaft der
        Musikfreunde ~ HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002746">Bank document</tei:rs>


      <dc:title>Payment authorization from the Gesellschaft der Musikfreunde to Schenker, dated
        September 17, 1920</dc:title>

      <dcterms:created>1920-09-17T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-10-27</dcterms:dateSubmitted>
      <dc:description>The Gesellschaft der Musikfreunde notifies Schenker of a payment to
        him.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-002430">Gesellschaft der
        Musikfreunde</marcrel:correspondent>
      <marcrel:correspondent key="entity-000562">Eusebius Mandyczewski</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:note target="editorial" place="pre-text">Italic type = handwritten; Roman type =
        printed</tei:note>

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/><tei:hi rend="bold">Gesellschaft der
              Musikfreunde</tei:hi></tei:addrLine>
          <tei:addrLine><tei:hi rend="bold">in Wien.</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-60">Wien, <tei:handShift new="#GdMF-sten"/><tei:date
              when="1920-09-17">17. 9. 20</tei:date></tei:addrLine>
        </tei:address><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/>An <tei:handShift new="#GdMF-sten"/><tei:hi
              rend="italic">D<tei:hi rend="supralinear">r.</tei:hi> Heinrich Schenker III Reisnerstr
              38</tei:hi><tei:note xml:id="r0001-fn01" type="editorial" place="foot">The purpose of
              this payment is unclear, but Schenker’s diary for September 17, 1920 records: “Into
              the Archive: a lot in the <tei:rs type="journal" key="entity-002480"><tei:title
                  level="j">Zeitschrift für Musikwissenschaft</tei:title></tei:rs> by <tei:rs
                type="person" key="entity-000960">Wetzel</tei:rs>; also read an article by <tei:rs
                type="person" key="entity-000326">Halm</tei:rs> in <tei:rs type="journal"
                key="entity-002550"><tei:title level="j">Der Merker</tei:title></tei:rs>; leave a
              500 Kronen deposit (<tei:hi rend="italic">deponiere 500 Kronen Kaution</tei:hi>); take
              several items home... .”</tei:note></tei:addrLine>
        </tei:address>
      </tei:opener>

      <tei:ab><tei:handShift new="#pr"/>Die gefertigte Kassa <tei:rs type="organization"
          key="entity-002430">der Gesellschaft der Musikfreunde</tei:rs> beehrt sich Ihnen
        anzuzeigen, daß der Betrag per Kronen <tei:cit>
          <tei:q><tei:handShift new="#GdMF-sten"/><tei:hi rend="italic">fünf Hundert</tei:hi><tei:lb/>
            <tei:hi rend="italic"><tei:unclear reason="reading">eile</tei:unclear>
            Kaution</tei:hi></tei:q>
        </tei:cit>
      </tei:ab>

      <tei:ab><tei:handShift new="#pr"/>am heutigen Tage erlegt wurde.</tei:ab>

      <tei:ab><tei:handShift new="#pr"/>Pr. K<tei:handShift new="#GdMF-sten"/><tei:hi rend="italic"
          >500</tei:hi>
        <tei:handShift new="#pr"/>h<tei:handShift new="#GdMF-sten"/><tei:hi rend="italic"
        >—</tei:hi></tei:ab>

      <tei:closer>
        <tei:salute rend="indent-70"><tei:handShift new="#pr"/>Für die Kassa</tei:salute>
        <tei:salute rend="indent-70"><tei:rs type="organization" key="entity-002430">der
            Gesellschaft der Musikfreunde</tei:rs>:</tei:salute>
        <tei:signed rend="indent-70"><tei:handShift new="#EM"/><tei:rs type="person"
            key="entity-000562">D<tei:hi rend="supralinear">r.</tei:hi>
          Mandyczewski</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/><tei:hi rend="bold">Society of the Friends of
              Music</tei:hi></tei:addrLine>
          <tei:addrLine><tei:hi rend="bold">in Vienna</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-60">Vienna, <tei:handShift new="#GdMF-sten"/><tei:date
              when="1920-09-17">September 17, 1920</tei:date></tei:addrLine>
        </tei:address><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/>To <tei:handShift new="#GdMF-sten"/><tei:hi
              rend="italic">Dr. Heinrich Schenker III Reisnerstraße 38</tei:hi><tei:ptr
              corresp="#r0001-fn01" type="footnote"/></tei:addrLine>
        </tei:address>
      </tei:opener>

      <tei:ab><tei:handShift new="#pr"/>The undersigned cashier of <tei:rs type="organization"
          key="entity-002430">The Society of the Friends of Music</tei:rs> has the honor of
        notifying you that the sum of Kronen <tei:cit>
          <tei:q><tei:handShift new="#GdMF-sten"/><tei:hi rend="italic">five hundred</tei:hi><tei:lb/>
            <tei:hi rend="italic"><tei:unclear reason="original_unclear">express</tei:unclear>
              security</tei:hi></tei:q>
        </tei:cit>
      </tei:ab>

      <tei:ab><tei:handShift new="#pr"/>was paid out on this day.</tei:ab>

      <tei:ab><tei:handShift new="#pr"/>Sum Kr<tei:handShift new="#GdMF-sten"/><tei:hi rend="italic"
          >500</tei:hi>
        <tei:handShift new="#pr"/>H<tei:handShift new="#GdMF-sten"/><tei:hi rend="italic"
        >—</tei:hi></tei:ab>

      <tei:closer>
        <tei:salute rend="indent-70"><tei:handShift new="#pr"/>For the cashier</tei:salute>
        <tei:salute rend="indent-70">of <tei:rs type="organization" key="entity-002430">The Society
            of the Friends of Music</tei:rs>:</tei:salute>
        <tei:signed rend="indent-70"><tei:handShift new="#EM"/><tei:rs type="person"
            key="entity-000562">Dr. Mandyczewski</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
  </sdo:record>
