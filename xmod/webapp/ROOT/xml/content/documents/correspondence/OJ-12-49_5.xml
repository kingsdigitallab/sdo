 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



   <dc:title>Handwritten postcard from Mandyczewski to Schenker, dated November 6, 1912</dc:title>

   <dcterms:created>1912-11-06T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-26</dcterms:dateSubmitted>
   <dc:description>Mandyczewski informs Schenker that inspecting the autograph manuscript of Beethoven Op. 109
    at the Wittgenstein house is now possible.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000562">EMandyczewski</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:supplied>An:</tei:supplied>
       <tei:handShift new="#EM"/>Herrn D<tei:hi rend="supralinear">r.</tei:hi>
       <tei:hi rend="lateinschr">Heinr. Schenker</tei:hi></tei:addrLine>
      <tei:addrLine rend="indent-60">Wien III</tei:addrLine>
      <tei:addrLine>Reisnertr. 38.</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 WIEN 1 | 6. XI. 12 | * 4a * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Verehrtester Hr <tei:rs type="person" key="entity-000632">D<tei:hi
       rend="supralinear">r.</tei:hi></tei:rs>!</tei:salute>
   </tei:opener>


   <tei:p>Wann </tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">Besten Gruß</tei:salute>
    <tei:salute rend="indent-50">von</tei:salute>
    <tei:signed rend="indent-55"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine><tei:date when="1912-11-06">6/11 912</tei:date></tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:supplied>To:</tei:supplied>
       <tei:handShift new="#EM"/>Dr. Heinrich Schenker</tei:addrLine>
      <tei:addrLine><tei:handShift new="#pr"/>in <tei:handShift new="#EM"/>Paneveggio</tei:addrLine>
      <tei:addrLine>South Tyrol</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 VIENNA 15 | <tei:gap reason="illegible"/> | * 4a * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Highly revered <tei:rs type="person" key="entity-000623">Dr. S.</tei:rs>,<tei:ptr
      corresp="#r0001-fn01" type="footnote"/></tei:salute>
   </tei:opener>


   <tei:p>By chance on a day in Vienna, I have just found your letter.<tei:ptr corresp="#r0001-fn02"
     type="footnote"/> The autograph manuscript of Op. 109 is in private possession, strangely
    enough in Vienna, at <tei:supplied reason="clarity">the residence of</tei:supplied> Mrs. <tei:rs
     type="person" key="entity-000970">Poldy Wittgenstein</tei:rs>, Alleegasse.<tei:ptr
     corresp="#r0001-fn03" type="footnote"/> From <tei:date when="1912-09-20">September
     20</tei:date>, I shall resume my civic duties and can be of service with further particulars
    that are at the moment superfluous since the lady is of course also spending the summer in the
    country. In the meantime, in haste, but</tei:p>

   <tei:closer>
    <tei:salute rend="indent-10"><tei:milestone unit="folio" n="recto"/> with cordial
     greetings</tei:salute>
    <tei:salute rend="indent-40">from your devoted</tei:salute>
    <tei:signed rend="indent-35"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine>Vienna <tei:date when="1912-08-01">August 1, 1912</tei:date>, otherwise: </tei:addrLine>
     <tei:addrLine><tei:rs type="place" key="entity-004067">Mönichkirchen</tei:rs> Lower
      Austria</tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>
 </sdo:record>
