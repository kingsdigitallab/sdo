 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



   <dc:title>Handwritten postcard from Mandyczewski to Schenker, dated November 6, 1912</dc:title>

   <dcterms:created>1912-11-06T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-27</dcterms:dateSubmitted>
   <dc:description>Mandyczewski informs Schenker that inspecting the autograph manuscript of
    Beethoven Op. 109 at the Wittgenstein house is now possible.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000562">EMandyczewski</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:supplied>An:</tei:supplied>
       <tei:handShift new="#EM"/>Herrn D<tei:hi rend="supralinear">r.</tei:hi>
       <tei:hi rend="lateinschr">Heinr. Schenker</tei:hi></tei:addrLine>
      <tei:addrLine rend="indent-60">Wien III</tei:addrLine>
      <tei:addrLine>Reisnertr. 38.</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 WIEN 1 | 6. XI. 12 | * 4a * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Verehrter Hr <tei:rs type="person" key="entity-000632">D<tei:hi rend="supralinear"
       >r.</tei:hi></tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
      this postcard is not recorded in Schenker’s diary.</tei:note></tei:salute>
   </tei:opener>


   <tei:p rend="first">Wann wollen wir zusammen zur Besichtigung der Handschriften zu <tei:rs
     type="person" key="entity-004688">Wittgenstein</tei:rs> gehen?<tei:note xml:id="r0001-fn02"
     type="editorial" place="foot">Schenker and Mandyczewski went to the Wittgenstein house on
     November 12: see <tei:ref type="correspondence" cRef="OJ-12-49_6">OJ 12/49, [6]</tei:ref>,
     footnote 2.</tei:note> Jetzt wäre es schon möglich.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">Besten Gruß</tei:salute>
    <tei:salute rend="indent-50">von</tei:salute>
    <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine><tei:date when="1912-11-06">6/11 912</tei:date></tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:supplied>To:</tei:supplied>
       <tei:handShift new="#EM"/>Dr. Heinrich Schenker</tei:addrLine>
      <tei:addrLine rend="indent-60">Vienna III</tei:addrLine>
      <tei:addrLine>Reisnertraße 38</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 VIENNA 1 | 6. XI. 12 | * 4a * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Revered <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
       reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
      type="footnote"/></tei:salute>
   </tei:opener>


   <tei:p rend="first">When do we want to go together to <tei:supplied>the</tei:supplied>
    <tei:rs type="person" key="entity-004688">Wittgenstein</tei:rs>
    <tei:supplied>house</tei:supplied> to examine the manuscripts?<tei:ptr corresp="#r0001-fn02"
     type="footnote"/> Now it would be possible.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">Best greetings</tei:salute>
    <tei:salute rend="indent-50">from</tei:salute>
    <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine><tei:date when="1912-11-06">November 6, 1912</tei:date></tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>
 </sdo:record>
