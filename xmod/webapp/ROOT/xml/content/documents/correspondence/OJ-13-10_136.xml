  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated August 23,
        1931</dc:title>

      <dcterms:created>1931-08-23T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2026-02-12</dcterms:dateSubmitted>
      <dc:description>Oppel has finished his mountaineering expedition safely.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: mountain, captioned on recto:
          “Verpeilhütte (2000 m) mit Schwabenkopf (3379 m)”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >Postkarte</tei:hi></tei:fw><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine><tei:hi rend="underline">Galtür / Paznaun</tei:hi></tei:addrLine>
            <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"> || INMITTEN HERRLICHSTER ALPENWELT | LANDECK | <tei:gap
              reason="illegible"/> | TIROL ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1931-08-23">23. 8. 31</tei:date>. Mein
          lieber Herr <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this picture postcard is recorded in Schenker’s diary for August 25, 1931: “Von Oppel
            (K.): Gruß aus Feuchten, mehr aus Leipzig.” (“From Oppel (postcard): greetings from
            Feuchten, more from Leipzig.”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p>Gestern kamen wir wohlbehalten nach <tei:rs type="place" key="entity-005937"
          >Feuchten</tei:rs> zurück. Näheres von <tei:rs type="place" key="entity-002479"
          >Leipzig</tei:rs> aus. </tei:p>

      <tei:closer>
        <tei:salute>Alles Gute u. die herzl.</tei:salute>
        <tei:salute>Grüsse Ihnen beiden!</tei:salute>
        <tei:salute>Ihr treuer</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: mountain, captioned on recto: “Verpeil
          mountain hut (2,000 meters [above sealevel]) with the Schwabenkopf (3,379
          meters)”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >Postcard</tei:hi></tei:fw><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine><tei:hi rend="underline">Galtür / Paznaun</tei:hi></tei:addrLine>
            <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"> || AMIDST THE MOST MAGNIFICENT ALPINE WORLD | LANDECK | <tei:gap
              reason="illegible"/> | TYROL ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1931-08-23">August 23, 1931
          </tei:date>. My dear <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>Yesterday we arrived back in <tei:rs type="place" key="entity-005937">Feuchten</tei:rs>
        safe and sound. More details from <tei:rs type="place" key="entity-002479"
        >Leipzig</tei:rs>.</tei:p>

      <tei:closer>
        <tei:salute>All good wishes and the most cordial</tei:salute>
        <tei:salute>greetings to you both.</tei:salute>
        <tei:salute>Your faithful</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
