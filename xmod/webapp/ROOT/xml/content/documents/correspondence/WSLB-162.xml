  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



      <dc:title>Handwritten postcard from Schenker to UE, dated June 18, 1913</dc:title>

      <dcterms:created>1913-06-18T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-07-04</dcterms:dateSubmitted>
      <dc:description>Schenker asks UE to remind the printers to include the musical text when they
        send the [final batch of] proofs.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000632">Heinrich Schenker</marcrel:correspondent>
      <marcrel:recipient key="entity-000356">Emil Hertzka</marcrel:recipient>
      <marcrel:recipient key="entity-002408">Universal Edition</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">Absender:</tei:supplied>
              <tei:handShift new="#HS"/><tei:hi rend="lateinschr">H Schenker</tei:hi>
            </tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">III, Reisnerstr. 38</tei:hi></tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine>An die <tei:hi rend="lateinschr">„Universal-Edition“
              Verlag</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">I, Reichsrathsstr.</tei:hi> 9</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| 1/3 WIEN 49 | 18.VI.13–4 | * 3a * |||</tei:fw><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>An die „<tei:rs type="organization"
            key="entity-002408"><tei:hi rend="underline">Universal-Edition</tei:hi></tei:rs>“
            Wien.<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Writing of this
            postcard is not recorded in Schenker's diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p>Da H. <tei:rs type="person" key="entity-000356">Direktor Hertzka</tei:rs> laut
          Brief<tei:note xml:id="r0001-fn02" type="editorial" place="foot">= <tei:ref
            type="correspondence" cRef="OC-52-119">OC 52/119</tei:ref>, June 16, 1913, signed by
          Alfred Kalmus. </tei:note> in <tei:rs type="place" key="entity-002477"><tei:hi
            rend="lateinschr">Paris</tei:hi></tei:rs> ist, erlaube ich mir den geehrten Verlag zu
        ersuchen, nebst den mir schon für Mitte dieser Woche in Aussicht gestellten Korrekturen auch
        den <tei:hi rend="double-underline">Notentext</tei:hi> bei der Druckerei zu urgieren. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-40"><tei:handShift new="#HS"/>Mit ausgez Hochachtung</tei:salute>
        <tei:signed rend="indent-50">
          <tei:rs key="entity-000632" type="person"><tei:hi rend="lateinschr">D<tei:hi
                rend="supralinear">r.</tei:hi> H Schenker</tei:hi></tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-06-18">18. Juni 1913</tei:date>[3]</tei:dateline>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">From:</tei:supplied>
              <tei:handShift new="#HS"/>H. Schenker </tei:addrLine>
            <tei:addrLine><tei:supplied reason="identity">Vienna</tei:supplied> III, Reisnerstraße
              38</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine>To the Universal Edition Publishing House</tei:addrLine>
            <tei:addrLine><tei:supplied reason="identity">Vienna</tei:supplied> I, Reichsrathsstraße
              9</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| 1/3 VIENNA 49 | 18.VI.13–4 | * 3a * |||</tei:fw><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>To <tei:rs type="organization" key="entity-002408"
              ><tei:hi rend="underline">Universal Edition</tei:hi></tei:rs>, Vienna<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>Since <tei:rs type="person" key="entity-000356">Director Hertzka</tei:rs> according to
        your letter,<tei:ptr corresp="#r0001-fn02" type="footnote"/> is in <tei:rs type="place"
          key="entity-002477">Paris</tei:rs>, I take the liberty of asking the esteemed publishing
        house to call the printers urgently; in addition to the proofs that they have promised me as
        early as the middle of this week, also for the <tei:hi rend="double-underline">musical
          text</tei:hi>. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-40"><tei:handShift new="#HS"/>With kind regards, </tei:salute>
        <tei:signed rend="indent-50">
          <tei:rs key="entity-000632" type="person">Dr. H. Schenker</tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-06-18">June 18, 1913[</tei:date>[3]</tei:dateline>
      </tei:closer>

    </tei:div>

