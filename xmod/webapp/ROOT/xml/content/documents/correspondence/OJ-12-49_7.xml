 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



   <dc:title>Handwritten postcard from Mandyczewski to Schenker, dated February 23, 1916</dc:title>

   <dcterms:created>1916-02-23T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-27</dcterms:dateSubmitted>
   <dc:description>Mandyczewski informs Schenker that a Chopin autograph manuscript is ready for his
    inspection at the Archive.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000562">EMandyczewski</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:note type="editorial" place="inline">in oval stamp:</tei:note> || <tei:rs
        type="organization" key="entity-002430">K. K. Gesellschaft der | Musikfreunde | in
        Wien</tei:rs> ||</tei:addrLine>
     </tei:address>
     <tei:address>
      <tei:addrLine><tei:supplied>An:</tei:supplied>
       <tei:handShift new="#EM"/>Hrn D<tei:hi rend="supralinear">r.</tei:hi> Heinrich <tei:hi
        rend="lateinschr">Schenker</tei:hi></tei:addrLine>
      <tei:addrLine rend="indent-60"><tei:hi rend="lateinschr">Wien</tei:hi> III</tei:addrLine>
      <tei:addrLine>Reisnertr 38.</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 WIEN 15 | <tei:gap reason="illegible"/> | * 4a * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Verehrter Hr <tei:rs type="person" key="entity-000632">D<tei:hi rend="supralinear"
       >r.</tei:hi></tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
      this postcard is recorded in Schenker’s diary for February 24, 1916: “Von Mandyczewski (K.);
      benachrichtigt mich, daß das Autograph, Chopin, Prelude, As dur, mir nunmehr im Archiv zur
      Verfügung stehe. Gewiß eine wohltuende Aufmerksamkeit” (“Postcard from Mandyczewski informing
      me that the autograph of Chopin, Prelude in A<tei:g type="flat"/> major, is again available in the Archive
      for me to consult. For sure, a courtesy for which I am grateful.”). — Schenker’s reply is
      recorded the next day: “An Mandyczewski Brief mit Dank.” (“To Mandyczewski, letter with
      thanks.”).</tei:note></tei:salute>
   </tei:opener>


   <tei:p rend="first">Das <tei:rs type="person" key="entity-000129">Chopin</tei:rs> Autograf liegt
    für Sie zur Ansicht bereit, entweder bei <tei:rs type="person" key="entity-003713"
     >Schittenhelm</tei:rs> oder bei </tei:p>

   <tei:closer>
    <tei:salute rend="indent-10">Ihrem bestens </tei:salute>
    <tei:salute rend="indent-50">grüßend</tei:salute>
    <tei:signed rend="indent-40"><tei:rs type="person" key="entity-000562">D<tei:hi
       rend="supralinear">r.</tei:hi> Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine><tei:date when="1916-02-23">23/2 916</tei:date></tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:note type="editorial" place="inline">in oval stamp:</tei:note> || <tei:rs
        type="organization" key="entity-002430">Royal-Imp. Society of the | Friends of Music | in
        Vienna</tei:rs> ||</tei:addrLine>
     </tei:address>
     <tei:address>
      <tei:addrLine><tei:supplied>To:</tei:supplied>
       <tei:handShift new="#EM"/>Dr. Heinrich Schenker</tei:addrLine>
      <tei:addrLine rend="indent-60">Vienna III</tei:addrLine>
      <tei:addrLine>Reisnertraße 38</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 VIENNA 15 | <tei:gap reason="illegible"/> | * 4a * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Revered <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
       reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
      type="footnote"/></tei:salute>
   </tei:opener>


   <tei:p rend="first">The <tei:rs type="person" key="entity-000129">Chopin</tei:rs> autograph
    manuscript is available, ready for your inspection, either with <tei:rs type="person"
     key="entity-003713">Schittenhelm</tei:rs> or with </tei:p>

   <tei:closer>
    <tei:salute rend="indent-10">your <tei:supplied>devoted</tei:supplied>, who sends</tei:salute>
    <tei:salute rend="indent-50">best greetings</tei:salute>
    <tei:signed rend="indent-40"><tei:rs type="person" key="entity-000562">Dr.
     Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine><tei:date when="1916-02-23">February 23, 1916</tei:date></tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>
 </sdo:record>
