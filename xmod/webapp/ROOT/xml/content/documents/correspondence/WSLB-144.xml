  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



      <dc:title>Handwritten postcard from Schenker to Hertzka (UE), dated January 22,
        1913</dc:title>

      <dcterms:created>1913-01-22T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-11</dcterms:dateSubmitted>
      <dc:description>Schenker notifies Hertzka that the "manuscripts" [musical text and letterpress
        material of his elucidatory edition of Beethoven Op. 109] will reach him [at Universal
        Edition] next week.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000632">Heinrich Schenker</marcrel:correspondent>
      <marcrel:recipient key="entity-000356">Emil Hertzka</marcrel:recipient>
      <marcrel:recipient key="entity-002408">Universal Edition</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">Absender:</tei:supplied>
              <tei:handShift new="#HS"/><tei:hi rend="lateinschr">H Schenker</tei:hi>
            </tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">III, Reisnerstr. 38</tei:hi></tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">An:</tei:supplied> H <tei:hi
                rend="lateinschr">Dir. Emil Hertzka</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">I, Reichsrathsstr.</tei:hi> 9</tei:addrLine>
            <tei:addrLine>„<tei:hi rend="lateinschr">Universal-Edition</tei:hi>“</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| 3/3 WIEN 49 | 22. I. 13 – 4 | * b * ||</tei:fw>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>Sehr geehrter Herr <tei:rs key="entity-000356"
            type="person">Direktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Writing of this postcard is not recorded in Schenker’s
          diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p>Hiemit erlaube ich mir Ihnen, die Manuscripte (<tei:hi rend="lateinschr underline"
          >Text</tei:hi> nach <tei:hi rend="lateinschr">Autograph</tei:hi> u. <tei:hi
          rend="underline">Erläuterungen</tei:hi>)<tei:note xml:id="r0001-fn02" type="editorial"
          place="foot">Schenker's musical text and analytical/critical commentary, of his edition,
            <tei:rs type="work" key="entity-001734"><tei:title level="m">Die letzten fünf Sonaten
              von Beethoven … Op. 109</tei:title></tei:rs> (Vienna: UE, 1913).</tei:note> für
        spätestens Anfang nächster Woche anzukündigen. Sie werden die <tei:hi rend="underline"
          >größten</tei:hi> Augen machen über den Abstand des Herausgeber<tei:supplied
          reason="syntax">s</tei:supplied><tei:note xml:id="r0001-fn03" type="editorial"
          place="foot">i.e. the editor of the pre-existing edition that Schenker used as the base
          text for his own edition, very probably that of <tei:rs type="person" key="entity-000172"
            >Anton Door</tei:rs>, whose edition was published by Universal Edition (UE 7) in or soon
          after 1901 (see Schenker's request, <tei:ref type="correspondence" cRef="WSLB-143">WSLB
            143</tei:ref> = OJ 5/16, [1], November 27, 1912). </tei:note> von <tei:rs type="person"
          key="entity-000055"><tei:hi rend="lateinschr">Beethoven</tei:hi></tei:rs> im Lichte seines
        eigenen <tei:hi rend="lateinschr">Autographs</tei:hi>. . . </tei:p>

      <tei:closer>
        <tei:salute>Mit besten Grüßen</tei:salute>
        <tei:salute rend="indent-60">Ihr ergebener</tei:salute>
        <tei:signed rend="indent-60">
          <tei:rs key="entity-000632" type="person"><tei:hi rend="lateinschr">H
            Schenker</tei:hi></tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-01-22">22. 1. 1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">From:</tei:supplied>
              <tei:handShift new="#HS"/>H. Schenker </tei:addrLine>
            <tei:addrLine><tei:supplied>Vienna</tei:supplied> III, Reisnerstraße 38</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied>To:</tei:supplied> Director Emil Hertzka</tei:addrLine>
            <tei:addrLine><tei:supplied reason="identity">Vienna</tei:supplied> I, Reichsrathsstraße
              9</tei:addrLine>
            <tei:addrLine>Universal Edition</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| 3/3 VIENNA 49 | 22. I. 13 – 4 | * b * ||</tei:fw>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>Dear <tei:rs key="entity-000356" type="person"
            >Director</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>This is to notify you <tei:supplied reason="clarity">of the arrival of</tei:supplied>
        the manuscripts (<tei:hi rend="underline">text</tei:hi> in accordance with the autograph
        manuscript, and <tei:hi rend="underline">elucidations</tei:hi>)<tei:ptr
          corresp="#r0001-fn02" type="footnote"/> at the latest by the beginning of next week. You
        will be <tei:hi rend="underline">utterly astonished</tei:hi> at the discrepancy between the
          editor<tei:ptr corresp="#r0001-fn03" type="footnote"/> and <tei:rs type="person"
          key="entity-000055">Beethoven</tei:rs> in light of his original autograph manuscript.</tei:p>

      <tei:closer>
        <tei:salute>With best greetings,</tei:salute>
        <tei:salute rend="indent-60">Your devoted</tei:salute>
        <tei:signed rend="indent-60">
          <tei:rs key="entity-000632" type="person">H. Schenker</tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-01-22">January 22, 1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>

