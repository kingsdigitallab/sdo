  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Handwritten letter from Breitkopf &amp; Härtel to Schenker, dated June 30,
        1905</dc:title>

      <dcterms:created>1905-06-30T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-03</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel state that they cannot accept a work for publication
        without having first inspected it. They promise confidentiality.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:note type="editorial" place="inline">in a decorative printed letterhead:</tei:note>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#print"/><tei:hi rend="bold">BREITKOPF &amp;
              HÄRTEL</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
            DEN <tei:handShift new="#BHsten"/><tei:date when="1905-06-30">30. VI.
            05</tei:date>.</tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#print"/>NÜRNBERGER STR.
            36.</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute rend="indent-20"><tei:handShift new="#BHsten"/>Sehr geehrter <tei:rs
            type="person" key="entity-000632">Herr</tei:rs>.<tei:note xml:id="r0001-fn01"
            type="editorial" place="foot">A typed transcript of the body of this letter by Oswald
            Jonas is preserved as OJ 59/9, [1], item 2.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Im Besitze Ihres w. Schreibens vom <tei:date when="1905-06-28">28.
          dss.</tei:date> teilen wir Ihnen mit, daß es uns leider nicht möglich ist, ein Werk in
        Verlag oder Kommission zu nehmen, von welchem wir nicht vorher Einsicht genommen
          haben.<tei:note xml:id="r0001-fn02" type="editorial" place="foot">Schenker approached
          Breitkopf about the publication (under its initial title) of his <tei:rs type="work"
            key="entity-001724"><tei:title level="m">Harmonielehre</tei:title></tei:rs>, the first
          volume of his <tei:rs type="work" key="entity-001723"><tei:title level="m">Neue
              musikalische Theorien und Fantasien</tei:title></tei:rs>, to which the publisher
          responded in <tei:ref type="correspondence" cRef="OJ-9-20_32">OJ 9/20, [32]</tei:ref>,
          June 26, requesting to see the manuscript of the volume.</tei:note> Wir bitten Sie deshalb
        nochmals uns das Manuskript einmal einzusenden und versichern Sie die Angelegenheit <tei:hi
          rend="underline">streng vertraulich</tei:hi> behandeln zu wollen. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten"/>Herrn <tei:hi rend="lateinschr">H.
              Schenker</tei:hi></tei:addrLine>
          <tei:addrLine><tei:hi rend="lateinschr">Wien</tei:hi> III</tei:addrLine>
          <tei:addrLine rend="indent-60"><tei:hi rend="lateinschr">Reisnerstr</tei:hi>
            38.</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:note type="editorial" place="inline">in a decorative printed letterhead:</tei:note>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#print"/><tei:hi rend="bold">BREITKOPF &amp;
              HÄRTEL</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
              <tei:handShift new="#BHsten"/><tei:date when="1905-06-30">June 30,
            1905</tei:date></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#print"/>NÜRNBERGER STRASSE
            36</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute rend="indent-20"><tei:handShift new="#BHsten"/>Dear <tei:rs type="person"
            key="entity-000632">Sir</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"
          /></tei:salute>
      </tei:opener>

      <tei:p rend="first">We acknowledge receipt of your letter of the <tei:date when="1905-06-28"
          >28th of this month</tei:date>, and regret to inform you that it is not possible for us to
        accept work for publication or commission that we have not previously inspected.<tei:ptr
          corresp="#r0001-fn02" type="footnote"/> We therefore kindly ask you once again to send us
        the manuscript, and assure you that we will treat the matter <tei:hi rend="underline">with
          the utmost confidentiality</tei:hi>. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Respectfully,</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten"/>Mr. H. Schenker</tei:addrLine>
          <tei:addrLine><tei:hi rend="underline">Vienna III</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-60">Reisnerstrasse 38</tei:addrLine>
        </tei:address>
      </tei:closer>


    </tei:div>
  </sdo:record>
