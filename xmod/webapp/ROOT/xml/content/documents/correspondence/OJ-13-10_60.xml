  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated July 31, 1928</dc:title>

      <dcterms:created>1928-07-31T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-14</dcterms:dateSubmitted>
      <dc:description>Oppel and his sons are hiking towards Galtür and will arrive in two
        days..</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:note type="editorial" place="inline">small picture: town with mountains behind,
          captioned: “Kufstein, Tirol”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Galtür / Paznauntal</tei:addrLine>
            <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"><tei:gap reason="illegible"/>ROE | 31. VII. 28 | c ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:dateline><tei:handShift new="#RO"/><tei:date when="1928-07-21">Dienstag 31. VII
            28</tei:date>. <tei:placeName>St Anton</tei:placeName>.</tei:dateline>
        <tei:salute>Mein lieber Herr <tei:rs type="person" key="entity-000632"
            >Schenker</tei:rs>,<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt
            of this picture postcard is recorded in Schenker’s diary for August 1, 1928: “Von Oppel
            (eine verspätete Ansichtsk. aus St. Anton): Anzeige der Ankunft.” (“From Oppel (a
            delayed picture postcard from St. Anton): announcement of his
          arrival.”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p>wir gehn heute abend bis Constanzer Hütte,<tei:note xml:id="r0001-fn02"
          type="editorial" place="foot">An alpine hut on the Rosanna River, about 5 miles (8 km)
          southwest of St Anton and 6 miles (10 km) north of Galtür.</tei:note> Morgen weiter u.
        treffen gegen Abend bei Ihnen ein. Alles weitere mündlich. Auf frohes Wiedersehen! </tei:p>


      <tei:closer>
        <tei:salute rend="indent-10">Mit herzl Grüsse Ihnen beiden</tei:salute>
        <tei:salute rend="indent-20">Ihr treuer</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
        <tei:signed rend="indent-50"><tei:handShift new="#UO"/><tei:rs type="person" key="entity-000644"
          >Ulrich</tei:rs></tei:signed>
      </tei:closer>

      <tei:postscript>
        <tei:p><tei:handShift new="#RO"/><tei:rs type="person" key="entity-003957">Walter</tei:rs>
          kommt auch mit, er muss das <tei:note type="editorial" place="inline">sideways in left
            margin:</tei:note> Gepäck hüten. </tei:p>
      </tei:postscript>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:note type="editorial" place="inline">small picture: town with mountains behind,
          captioned: “Kufstein, Tyrol”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Galtür, Paznaun Valley</tei:addrLine>
            <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"><tei:gap reason="illegible"/>ROE | 31. VII. 28 | c ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:dateline><tei:handShift new="#RO"/><tei:date when="1928-07-21">Tuesday July 31,
            1928</tei:date>, <tei:placeName>Sankt Anton</tei:placeName>.</tei:dateline>
        <tei:salute>My dear Mr. <tei:rs type="person" key="entity-000632">Schenker</tei:rs>,<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>This evening we are walking to the Konstanz Hut;<tei:ptr corresp="#r0001-fn02"
          type="footnote"/> tomorrow we will go further, and we shall be with you toward evening.
        Everything else when we meet. Until we see each other!</tei:p>


      <tei:closer>
        <tei:salute rend="indent-10">With cordial greetings to the two of you, </tei:salute>
        <tei:salute rend="indent-20">Your faithful</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
        <tei:signed rend="indent-50"><tei:handShift new="#UO"/><tei:rs type="person" key="entity-000644"
          >Ulrich</tei:rs></tei:signed>
      </tei:closer>

      <tei:postscript>
        <tei:p><tei:handShift new="#RO"/><tei:rs type="person" key="entity-003957">Walter</tei:rs>
          is also coming; he has to <tei:note type="editorial" place="inline">sideways in left
            margin:</tei:note> take care of the baggage.</tei:p>
      </tei:postscript>


    </tei:div>

  </sdo:record>
