   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-003332">calling card</tei:rs>



   <dc:title>Handwritten calling card from Eugen Brüll to Schenker, dated September 25,
    1907</dc:title>

   <dcterms:created>1907-09-25T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-08-06</dcterms:dateSubmitted>
   <dc:description>Eugen Brüll thanks Schenker for his friendship toward his deceased brother
    Ignaz.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-008520">BrüllE</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="verso"/><tei:lb/>
    <tei:salute><tei:handShift new="#EB"/>Lieber <tei:rs type="person" key="entity-000632"
      >Freund</tei:rs>!</tei:salute>
   </tei:opener>

   <tei:p>In solchen Fällen nützt keine <tei:hi rend="lateinschr">Philosophie</tei:hi>-Verben – das
    ist ein hartes Wort.</tei:p>

   <tei:p>Sie, mein lieber <tei:rs type="person" key="entity-000632"
    >Freund</tei:rs>, haben <tei:rs type="person" key="entity-000105">meinem
     Bruder</tei:rs> stets Freundschaft bewiesen . . .<tei:note xml:id="r0001-fn01" type="editorial"
      place="foot">Ignaz Brüll died on September 17, 1907.</tei:note></tei:p>

   <tei:p><tei:milestone unit="folio" n="recto"/> Seien Sie von Herzen bedankt für Ihr Mitempfinden
    an einem Teueren.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">herzl. </tei:salute>
    <tei:salute rend="indent-70">Ihr</tei:salute>
    <tei:signed rend="indent-80">
     <tei:rs type="person" key="entity-008520">Brüll</tei:rs>
    </tei:signed>
    <tei:signed><tei:handShift new="#pr"/><tei:del rend="overstrike">EUGEN
     BRÜLL</tei:del></tei:signed><tei:lb/>
    <tei:dateline><tei:handShift new="#EB"/><tei:date when="1907-09-25">25/9
     1907</tei:date></tei:dateline>
    <tei:address>
     <tei:addrLine><tei:handShift new="#pr"/>Wien, IX., Berggasse 13</tei:addrLine>
    </tei:address>
   </tei:closer>


  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="verso"/><tei:lb/>
    <tei:salute><tei:handShift new="#EB"/>Dear <tei:rs type="person" key="entity-000632"
      >friend</tei:rs>,</tei:salute>
   </tei:opener>

   <tei:p>In such situations words of philosophy are of no avail – that is a hard thing to
    say.</tei:p>

   <tei:p>You, my dear <tei:rs type="person" key="entity-000632"
    >friend</tei:rs>, have shown friendship constantly toward my <tei:rs type="person"
     key="entity-000105">brother</tei:rs> . . .<tei:ptr corresp="#r0001-fn01" type="footnote"
    /></tei:p>

   <tei:p><tei:milestone unit="folio" n="recto"/> Accept heartfelt thanks for your sympathy for a
    dear friend.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">Cordially </tei:salute>
    <tei:salute rend="indent-70">your</tei:salute>
    <tei:signed rend="indent-80">
     <tei:rs type="person" key="entity-008520">Brüll</tei:rs>
    </tei:signed>
    <tei:signed><tei:handShift new="#pr"/><tei:del rend="overstrike">EUGEN
     BRÜLL</tei:del></tei:signed><tei:lb/>
    <tei:dateline><tei:handShift new="#EB"/><tei:date when="1907-09-25">September 25,
      1907</tei:date></tei:dateline>
    <tei:address>
     <tei:addrLine><tei:handShift new="#pr"/>Vienna IX, Berggasse 13</tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>
