 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-008518">BrüllE ~
    HSchenker</tei:rs>
   <tei:rs role="correspondence" type="correspondence" key="entity-008517">BrüllI ~
