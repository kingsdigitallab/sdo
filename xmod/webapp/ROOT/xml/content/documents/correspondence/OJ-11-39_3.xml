      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Handwritten letter from Hanslick to Schenker, dated August 24, 1894</dc:title>

      <dcterms:created>1894-08-24T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-08</dcterms:dateSubmitted>
      <dc:description>Hanslick looks forward to Schenker's "Smetana feuilleton."</dc:description>
      <dc:subject/>


      <marcrel:correspondent key="entity-000331">Eduard Hanslick</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine rend="indent-50"><tei:handShift new="#EH"/><tei:rs type="place"
              key="entity-003099">Bad Gastein</tei:rs>
            <tei:date when="1894-08-24">24. Aug. 94</tei:date></tei:addrLine>
          <tei:addrLine rend="indent-60">(„Solitude“.)</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute>Hochgeehrter Herr <tei:rs type="person" key="entity-000632"
          >Doctor</tei:rs>!</tei:salute>
      </tei:opener>

      <tei:p>Ihr Brief<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Schenker’s letter
          is not know to survive.</tei:note> hat mich nach vielen Umwegen so eben hier erreicht. Mit
        großem Vergnügen sehe ich Ihren <tei:rs type="person" key="entity-000833"
          >Smetana</tei:rs>-Feuilleton<tei:note xml:id="r0001-fn02" type="editorial" place="foot"
          >The same day, in <tei:ref type="correspondence" cRef="OJ-71-14_1">OJ 71/14,
          [1]</tei:ref>, Hanslick recommended this to the editor of the <tei:title level="a">Neue
            freie Presse</tei:title>. As <tei:ref type="correspondence" cRef="OJ-11-39_4">OJ 11/39,
            [4]</tei:ref> reports, the article was referred to another newspaper:
              <tei:bibl><tei:title level="a">Aus dem Leben Smetana’s (Ein Besuch bei Fr. Smetana’s
              Witwe),</tei:title>
            <tei:title level="j">Neues Wiener Tagblatt</tei:title>, year 28, No. 245 (September 6,
            1894)</tei:bibl>, the newspaper of which <tei:rs type="person" key="entity-000363"
            >Richard Heuberger</tei:rs> was editor. The article is reproduced in
              <tei:bibl><tei:editor>Hellmut Federhofer</tei:editor>, ed., <tei:title level="m"
              >Heinrich Schenker als Essayist und Kritiker …</tei:title> (Hildesheim: Georg Olms
            Verlag, 1990), pp. 109–14</tei:bibl>.</tei:note> entgegen und beeile mich, Ihnen die
        gewünschten Karten beizulegen, deren es übrigens sicher nicht bedurft hätte. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">Mit bestem Gruß</tei:salute>
        <tei:salute rend="indent-50">Ihr</tei:salute>
        <tei:salute rend="indent-50">aufrichtig ergebener</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000562">Ed.
          Hanslick</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine rend="indent-50"><tei:handShift new="#EH"/><tei:rs type="place"
              key="entity-003099">Bad Gastein</tei:rs>, <tei:date when="1894-08-24">August 24,
              1894</tei:date></tei:addrLine>
          <tei:addrLine rend="indent-60">("Solitude")</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute>Highly revered <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p>Your letter<tei:ptr corresp="#r0001-fn01" type="footnote"/> just now reached me here
        after many detours. I look forward with great delight to your feuilleton on <tei:rs
          type="person" key="entity-000833">Smetana</tei:rs><tei:ptr corresp="#r0001-fn02"
          type="footnote"/> and hasten to enclose for you the desired tickets, which by the way were
        surely not necessary.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">With best greetings, </tei:salute>
        <tei:salute rend="indent-50">your</tei:salute>
        <tei:salute rend="indent-50">sincerely devoted</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000562">Ed.
          Hanslick</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
  </sdo:record>
