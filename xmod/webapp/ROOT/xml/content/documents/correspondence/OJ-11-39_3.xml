  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-008451">Hanslick ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Handwritten letter from Hanslick to Schenker, dated August 24, 1894</dc:title>

      <dcterms:created>1894-08-24T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-08</dcterms:dateSubmitted>
      <dc:description>Hanslick looks forward to Schenker's "Smetana feuilleton."</dc:description>
      <dc:subject/>


      <marcrel:correspondent key="entity-000331">Eduard Hanslick</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:dateline rend="indent-50"><tei:handShift new="#EH"/>Bad Gastein <tei:date
            when="1894-08-24">24. Aug. 94</tei:date></tei:dateline>
        <tei:add place="inline" rend="indent-60">(„Solitude“.)</tei:add><tei:lb/>
        <tei:salute>Hochgeehrter Herr <tei:rs type="person" key="entity-000632"
          >Doctor</tei:rs></tei:salute>
      </tei:opener>

      <tei:p>Ihr </tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">Mit bestem Gruß</tei:salute>
        <tei:salute rend="indent-50">Ihr</tei:salute>
        <tei:salute rend="indent-50">aufrichtig ergebener</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000562">Ed.
          Hanslick</tei:rs>.</tei:signed>
      </tei:closer>



    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:dateline rend="indent-70"><tei:handShift new="#EM"/>Vienna, <tei:date when="1894-02-15"
            >February 15, 1894</tei:date></tei:dateline><tei:lb/>
        <tei:salute>Highly revered <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs></tei:salute>
      </tei:opener>

      <tei:p>Many thanks for your friendly lines and for the sign of trust that they contain! Your
        idea for a “History of Melody”<tei:ptr corresp="#r0001-fn01" type="footnote"/> interests me
        very much – or more accurately <tei:hi rend="underline">will</tei:hi> interest me very much
        when I am in a somewhat more relaxed state of mind and disposition. I am now very depressed
        by Billroth’s<tei:ptr corresp="#r0001-fn02" type="footnote"/> death and that of other
        friends, further by the severe illness of my brother. On top of all of that, I am
        overwhelmed with work – and in the middle of the concert season! It would thus be most
        congenial of you if you would postpone <tei:add place="interlinear-above">the</tei:add>
        promised presentation of your plans to Easter week,<tei:ptr corresp="#r0001-fn03"
          type="footnote"/> when I will again hopefully be more receptive to serious theoretical
        conversations.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-40">Respectfully, <tei:supplied>your</tei:supplied>
          devoted</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000562"> Dr. Ed.
            Hanslick</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
  </sdo:record>
