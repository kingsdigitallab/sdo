 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



   <dc:title>Handwritten postcard from Mandyczewski to Schenker, dated August 1, 1912</dc:title>

   <dcterms:created>1912-08-01T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-26</dcterms:dateSubmitted>
   <dc:description>Mandyczewski informs Schenker that the autograph manuscript of Beethoven Op. 109
    is in private possession in Vienna.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000562">EMandyczewski</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:supplied>An:</tei:supplied>
       <tei:handShift new="#EM"/>Herrn D<tei:hi rend="supralinear">r.</tei:hi>
       <tei:hi rend="lateinschr">Heinrich Schenker</tei:hi></tei:addrLine>
      <tei:addrLine><tei:handShift new="#pr"/>in <tei:handShift new="#EM"/><tei:hi rend="lateinschr"
        >Paneveggio</tei:hi></tei:addrLine>
      <tei:addrLine><tei:hi rend="lateinschr">Südtirol</tei:hi></tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 WIEN 15 | <tei:gap reason="illegible"/> | * 4a * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Verehrtester Hr <tei:rs type="person" key="entity-000623">D<tei:hi
       rend="supralinear">r.</tei:hi> S</tei:rs><tei:note xml:id="r0001-fn01" type="editorial"
      place="foot">Receipt of this postcard is recorded in Schenker’s diary for August 21, 1912:
      “Mandyczewski teilt mit, daß das Manuscript op. 109 in Wien sich befindet!” (“Mandyczewski
      informs me that the autograph manuscript of Op. 109 is to be found in
     Vienna!”).</tei:note></tei:salute>
   </tei:opener>


   <tei:p>Zufälligerweise auf einem Tag in Wien finde ich eben Ihren Brief vor.<tei:note
     xml:id="r0001-fn02" type="editorial" place="foot">Writing of the letter in question is not
     recorded in Schenker’s diary.</tei:note> Das Autograph von op 109 ist im Privatbesitz,
    merkwürdigerweise in Wien, bei Frau <tei:rs type="person" key="entity-000970"><tei:hi
      rend="lateinschr">Poldy Wittgenstein</tei:hi></tei:rs>, Alleegasse. Ab <tei:date
     when="1912-09-20">20. Sept.</tei:date> bin ich wieder in alter Stadtordnung und kann mit
    weiteren Angaben dienen, die jetzt überflüssig sind, da die Dame natürlich im Sommer auch auf
    dem Lande weilt. Inzwischen eiligen aber </tei:p>

   <tei:closer>
    <tei:salute rend="indent-10"><tei:milestone unit="folio" n="recto"/> Herzlich
     grüßendst</tei:salute>
    <tei:salute rend="indent-40">Ihres ergebenen</tei:salute>
    <tei:signed rend="indent-35"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine>Wien <tei:date when="1912-08-01">1/8 912</tei:date> sonst: </tei:addrLine>
     <tei:addrLine><tei:rs type="place" key="entity-004067">Mönichkirchen</tei:rs> Nied.
      Österr.</tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:supplied>To:</tei:supplied>
       <tei:handShift new="#EM"/>Dr. Heinrich Schenker</tei:addrLine>
      <tei:addrLine><tei:handShift new="#pr"/>in <tei:handShift new="#EM"/>Paneveggio</tei:addrLine>
      <tei:addrLine>South Tyrol</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 VIENNA 15 | <tei:gap reason="illegible"/> | * 4a * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Highly revered <tei:rs type="person" key="entity-000623">Dr. S.</tei:rs>,<tei:ptr
      corresp="#r0001-fn01" type="footnote"/></tei:salute>
   </tei:opener>


   <tei:p>By chance on a day in Vienna, I have just found your letter.<tei:ptr corresp="#r0001-fn02"
     type="footnote"/> The autograph manuscript of Op. 109 is in private possession, strangely
    enough in Vienna, at <tei:supplied reason="clarity">the residence of</tei:supplied> Mrs. <tei:rs
     type="person" key="entity-000970">Poldy Wittgenstein</tei:rs>, Alleegasse. From <tei:date
     when="1912-09-20">September 20</tei:date>, I shall resume my civic duties and can be of service
    with further particulars that are at the moment superfluous since the lady is of course also
    spending the summer in the country. In the meantime, in haste, but</tei:p>

   <tei:closer>
    <tei:salute rend="indent-10"><tei:milestone unit="folio" n="recto"/> with cordial
     greetings</tei:salute>
    <tei:salute rend="indent-40">from your devoted</tei:salute>
    <tei:signed rend="indent-35"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine>Vienna <tei:date when="1912-08-01">August 1, 1912</tei:date>, otherwise: </tei:addrLine>
     <tei:addrLine><tei:rs type="place" key="entity-004067">Mönichkirchen</tei:rs> Lower
      Austria</tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>
 </sdo:record>
