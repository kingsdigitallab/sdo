 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-008521">RoentgenJ ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



   <dc:title>Handwritten letter from Julius Röntgen to Schenker, dated March 18, 1901</dc:title>

   <dcterms:created>1901-03-18T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-03</dcterms:dateSubmitted>
   <dc:description>Schenker has invited Röntgen to contribute to publications of the newly-formed
    Universal Edition in Vienna. Röntgen responds with questions as to choice of works and editorial
    policy. -- He apologizes for giving insufficient attention at his last time with Schenker in
    Vienna.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-008632">HSchenker</marcrel:correspondent>
   <marcrel:recipient key="entity-000724">RöntgenJ</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:dateline rend="indent-30"><tei:handShift new="#JR"/>Amsterdam, <tei:date when="1901-03-18"
      >18 März 1901</tei:date></tei:dateline><tei:lb/>
    <tei:salute>Verehrtester Herr <tei:rs type="person" key="entity-000632"
     >Doctor</tei:rs>,[1]</tei:salute>
   </tei:opener>

   <tei:p>Herzlichsten </tei:p>

   <tei:p>Es </tei:p>
   
   <tei:p>Handelt </tei:p>
   
   <tei:p>Eine </tei:p>
   
   <tei:p>Ich </tei:p>
   
   <tei:p>Zum </tei:p>
   
   <tei:p>Sie </tei:p>
   
   <tei:p><tei:pb n="5"/> Gelegentlich </tei:p>
   
   <tei:p>Ich </tei:p>
   
   <tei:p><tei:pb n="6"/> An</tei:p>
   
   <tei:p>Für </tei:p>
   
   <tei:p>Wollen </tei:p>
   
   <tei:p>Ich </tei:p>

   <tei:closer>
    <tei:salute rend="indent-30">Mit herzlichstem Gruß</tei:salute>
    <tei:salute rend="indent-50">Ihr</tei:salute>
    <tei:salute rend="indent-40">verehrungsvoll ergebener</tei:salute>
    <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000724">Julius
     Röntgen</tei:rs>.</tei:signed>
   </tei:closer>
   
   <tei:postscript>
    <tei:p><tei:pb n="7"/> Bitte</tei:p>
    
    <tei:p>D. O.</tei:p>
   </tei:postscript>


  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:dateline rend="indent-50"><tei:handShift new="#JR"/><tei:date>Friday, crack of
      dawn!</tei:date></tei:dateline><tei:lb/>
    <tei:salute>Most revered <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
       reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
      type="footnote"/></tei:salute>
   </tei:opener>

   <tei:p>Suddenly you vanished yesterday evening, and I didn’t have a chance to thank you for your
    kindness in honoring me with your piano pieces.<tei:ptr corresp="#r0001-fn02" type="footnote"
    /></tei:p>

   <tei:p><tei:milestone unit="folio" n="verso"/> Provisionally then, by this means, I hope soon
     <tei:supplied reason="clarity">to meet</tei:supplied> in person in a somewhat less <tei:hi
     rend="italic">prestissimo</tei:hi> mood than yesterday at the concert!</tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">In the meantime,</tei:salute>
    <tei:salute rend="indent-60">your devoted friend</tei:salute>
    <tei:salute rend="indent-50">greets you admiringly</tei:salute>
    <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000724">Julius
     Röntgen</tei:rs></tei:signed>
   </tei:closer>

  </tei:div>
 </sdo:record>
