 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-008517">BrüllI ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



   <dc:title>Handwritten letter from Brüll to Schenker, dated April 12, [1898?]</dc:title>

   <dcterms:created>1898-04-12T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-08-06</dcterms:dateSubmitted>
   <dc:description>Ignaz Brüll praises Schenker's Inventionen, Op. 5 and his Sechs Lieder, Op.
    3.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000105">BrüllI</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:salute>Hochverehrter Herr <tei:rs type="person" key="entity-000632"
      >Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">This letter is
      published in English in <tei:bibl><tei:editor>Bent, Ian</tei:editor>, <tei:editor>David
        Bretherton</tei:editor> and <tei:editor>William Drabkin</tei:editor>, eds, <tei:title
        level="m">Heinrich Schenker: Selected Correspondence</tei:title> (Woodbridge: Boydell
       Press), p. 21</tei:bibl>.</tei:note></tei:salute>
   </tei:opener>

   <tei:p>Ich wollte Sie besuchen, um Ihnen meinen herzlichen Dank für Ihre freundliche Sendung
    mündlich abzustatten. Doch Überhäufung mit Arbeiten hindert mich; wahrscheinlich würde ich Sie
    auch nicht antreffen oder Sie stören.</tei:p>

   <tei:p>Ihre <tei:title>Inventionen</tei:title> u. <tei:title>Lieder</tei:title><tei:note
     xml:id="r0001-fn02" type="editorial" place="foot"><tei:bibl><tei:author>Heinrich
       Schenker</tei:author>, <tei:title level="m">Zweistimmige Inventionen</tei:title>, Op. 5
      (Leipzig: Breitkopf &amp; Härtel, 1898)</tei:bibl>, dedicated to <tei:rs type="person"
      key="entity-000582">Irene Mayerhofer</tei:rs>; <tei:bibl><tei:title level="m">Sechs Lieder für
       eine Singstimme mit Begleitung des Pianoforte</tei:title>, Op. 3 (Leipzig: Breitkopf &amp;
      Härtel, 1898)</tei:bibl>, dedicated to <tei:rs type="person" key="entity-000116">Ferruccio
      Busoni</tei:rs>.</tei:note> habe ich mit Genuß durchgespielt. Alles, was Sie machen, ist
    ungewöhnlich, trägt den Stempel eines tiefen Geistes u. bedeutenden Talentes.
     „<tei:title>Ausklang</tei:title>“ ist wirklich ergreifend; nicht minder
     „<tei:title>Allein</tei:title>“.<tei:note xml:id="r0001-fn03" type="editorial" place="foot"
      ><tei:title level="a">Ausklang</tei:title> and <tei:title level="a">Allein</tei:title> are Nos
     4 and 5 of Schenker’s Op. 3.</tei:note> Herzlichsten Dank! </tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">Ihr</tei:salute>
    <tei:salute rend="indent-30">freundschaftlich ergebener</tei:salute>
    <tei:signed rend="indent-80">
     <tei:rs type="person" key="entity-000105">Ignaz Brüll</tei:rs>
    </tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1898-04-12">12/4</tei:date></tei:dateline>
   </tei:closer>


  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:salute>Highly revered <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
       reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
      type="footnote"/></tei:salute>
   </tei:opener>

   <tei:p>I wanted to call on you to render my heartfelt thanks in person for the things you sent
    me. However, an accumulation of work has prevented me, and the possibility that I might not find
    you in, or might disturb you.</tei:p>

   <tei:p>I have enjoyed playing through your <tei:title level="m">Inventions</tei:title> and
     <tei:title level="m">Songs</tei:title>.<tei:ptr corresp="#r0001-fn02" type="footnote"/>
    Everything that you create is extraordinary, and bears the stamp of a deep spirit and
    significant talent. <tei:title level="a">Ausklang</tei:title> is truly moving; and no less so
     <tei:title level="a">Allein.</tei:title><tei:ptr corresp="#r0001-fn03" type="footnote"/> Most
    heartfelt thanks!</tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">In friendship</tei:salute>
    <tei:salute rend="indent-30">your devoted</tei:salute>
    <tei:signed rend="indent-80">
     <tei:rs type="person" key="entity-000105">Ignaz Brüll</tei:rs>
    </tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1898-04-12">April 12</tei:date></tei:dateline>
   </tei:closer>

  </tei:div>
 </sdo:record>
