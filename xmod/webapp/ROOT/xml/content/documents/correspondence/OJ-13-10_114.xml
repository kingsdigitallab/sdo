  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Jeanette Schenker, dated October 11,
        1930</dc:title>

      <dcterms:created>1930-10-11T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-09-12</dcterms:dateSubmitted>
      <dc:description>Oppel sends greetings to Jeanette Schenker from Berlin, where he is about to
        attend a rehearsal of his arrangement of a Handel cantata with the bass singer
        Sitowsky.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: carpet, captioned on recto: “STAATLICHE
          MUSEEN IN BERLIN / ISLAMISCHE KUNSTABTEILUNG“</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Frau Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Wien III</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
            <tei:addrLine>Östreich!</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"> || BERLIN SW | 12 10 30 | 17-18 | * 11 * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:address>
          <tei:addrLine><tei:handShift new="#RO"/><tei:placeName>Berlin</tei:placeName>, <tei:date
              when="1930-10-11">11 X. 30</tei:date>.</tei:addrLine>
        </tei:address>
        <tei:salute>Liebe <tei:rs type="person" key="entity-000771">Frau Schenker</tei:rs>,<tei:note
            xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this postcard is recorded
            in Schenker’s diary for October 13, 1930: “Von Oppel (Ansichtsk. an Lie-Liechen): wie es
            mir gehe?” (“From Oppel (picture postcard to Lie-Liechen): how am I?”).
          </tei:note></tei:salute>
      </tei:opener>

      <tei:p>ist das nicht ein herrliches Stück? Wie gehts <tei:rs type="person" key="entity-000632"
          >Herrn Schenker</tei:rs>? Ich bin am Freitag hierher gefahren zur Probe mit
          Sitowsky.<tei:note xml:id="r0001-fn02" type="editorial" place="foot">Presumably a
          rehearsal of Oppel’s arrangement of a Handel bass cantata, mentioned together with the
          Russian bass Sitowsky in Oppel’s letter <tei:ref type="correspondence" cRef="OJ-13-10_113"
            >OJ 13/10, [113]</tei:ref> of September 24. No subsequent report by Oppel as to how the
          performance went is recorded in Schenker’s diary.</tei:note></tei:p>

      <tei:closer>
        <tei:salute>Alles Gute u. die herzlichsten </tei:salute>
        <tei:salute>Grüsse Ihnen beiden.</tei:salute>
        <tei:salute rend="indent-40">Ihr treuer</tei:salute>
        <tei:signed rend="indent-40"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: carpet, captioned on recto: “STATE
          MUSEUMS IN BERLIN / ISLAMIC DEPARTMENT OF ART“</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Mrs. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Vienna III</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
            <tei:addrLine>Austria!</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"> || BERLIN SW | 12 10 30 | 17-18 | * 11 * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:address>
          <tei:addrLine><tei:handShift new="#RO"/><tei:placeName>Berlin</tei:placeName>, <tei:date
              when="1930-10-11">October 11, 1930</tei:date></tei:addrLine>
        </tei:address>
        <tei:salute>Dear <tei:rs type="person" key="entity-000771">Mrs. Schenker</tei:rs>,<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>Is this not a splendid piece? How is <tei:rs>Mr. Schenker</tei:rs>? I came here on
        Friday for the rehearsal with Sitowsky.<tei:ptr corresp="#r0001-fn02" type="footnote"
        /></tei:p>

      <tei:closer>
        <tei:salute>All good wishes and the most cordial </tei:salute>
        <tei:salute>greetings to the two of you.</tei:salute>
        <tei:salute rend="indent-40">Your faithful</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>
    </tei:div>

  </sdo:record>
