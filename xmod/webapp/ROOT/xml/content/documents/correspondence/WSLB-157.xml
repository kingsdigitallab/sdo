  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



      <dc:title>Handwritten postcard from Schenker to Hertzka (UE), dated May 16, 1913</dc:title>

      <dcterms:created>1913-05-16T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-26</dcterms:dateSubmitted>
      <dc:description>Schenker has still received no galley-proofs [of his elucidatory edition of
        Op. 109].</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000632">Heinrich Schenker</marcrel:correspondent>
      <marcrel:recipient key="entity-000356">Emil Hertzka</marcrel:recipient>
      <marcrel:recipient key="entity-002408">Universal Edition</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">Absender:</tei:supplied>
              <tei:handShift new="#HS"/><tei:hi rend="lateinschr">H Schenker</tei:hi>
            </tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">III, Reisnerstr. 38</tei:hi></tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">An:</tei:supplied> H <tei:hi
                rend="lateinschr">Direktor Em. Hertzka</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">I, Reichsrathsstr.</tei:hi> 9</tei:addrLine>
            <tei:addrLine>„<tei:hi rend="lateinschr">Universal-Edition</tei:hi>“</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| 1/3 WIEN 49 | 16.V.13–6 | * 3a * ||</tei:fw>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>Sehr geehrter Herr <tei:rs key="entity-000356"
            type="person">Direktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Writing of this postcard is recorded in Schenker's diary for May 16, 1913:
            “An Hertzka urgirende Karte” (“To Hertzka, postcard urging
          action.”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p>Es scheinen 10.000 entzückte „<tei:hi rend="underline">Setzer</tei:hi> mein kleines
          <tei:rs type="work" key="entity-001734"><tei:hi rend="lateinschr"
          >opus</tei:hi></tei:rs><tei:note xml:id="r0001-fn02" type="editorial" place="foot"
          >Schenker is waiting anxiously for galley-proofs of <tei:title level="m">Op.
            109</tei:title>. The "(?)" in this clause appears thus in the original. </tei:note> zu
          <tei:hi rend="underline">studieren</tei:hi>(?)“, denn wie sollte ich es mir erklären, daß
        die paar Blätter nicht mindestens schon zu einem Teile an mich gekommen sind. Vielleicht
        genügt es, wenn Sie noch einmal einen telephonischen Ukas geben. Schließlich schreiben wir
        schon den <tei:date when="1913-05-16">16. Mai</tei:date>! Ich möchte Alles aufbieten, an
        einem Schaden vorzubeugen, ich habe des Schadens wahrlich schon genug. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-30">Mit ausgez. Hochachtung,</tei:salute>
        <tei:salute rend="indent-70">I<tei:supplied>h</tei:supplied>r
            erg<tei:supplied>e</tei:supplied>b<tei:supplied>ener</tei:supplied></tei:salute>
        <tei:signed rend="indent-60">
          <tei:rs key="entity-000632" type="person"><tei:hi rend="lateinschr">H
            Schenker</tei:hi></tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-04-16">16. Mai 1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">From:</tei:supplied>
              <tei:handShift new="#HS"/>H. Schenker </tei:addrLine>
            <tei:addrLine><tei:supplied>Vienna</tei:supplied> III, Reisnerstraße 38</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">To:</tei:supplied>Direktor Emil
              Hertzka</tei:addrLine>
            <tei:addrLine><tei:supplied>Vienna</tei:supplied> I, Reichsrathsstraße 9</tei:addrLine>
            <tei:addrLine>Universal Edition</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| 1/3 WIEN 49 | 16.V.13–6 | * 3a * ||</tei:fw>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>Dear <tei:rs key="entity-000356" type="person"
            >Director</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>Ten thousand enraptured "<tei:hi rend="underline">typesetters</tei:hi> seem to be
          <tei:hi rend="underline">studying</tei:hi>(?) my little <tei:rs type="work"
          key="entity-001734">opus</tei:rs>,"<tei:ptr corresp="#r0001-fn02" type="footnote"/> for
        how am I to interpret the fact that not even a portion of the handful of sheets have yet
        reached me? Perhaps it will suffice if you yet again issue a telephonic decree. As we write,
        it is already <tei:date when="1913-05-16">May 16</tei:date>! I should like to get everything
        together so as to forestall anything going wrong – I really have had my share of
        wrong.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-30">With kind regards, </tei:salute>
        <tei:salute rend="indent-70">Your devoted</tei:salute>
        <tei:signed rend="indent-60">
          <tei:rs key="entity-000632" type="person">H. Schenker</tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-04-16">May 16, 1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>

