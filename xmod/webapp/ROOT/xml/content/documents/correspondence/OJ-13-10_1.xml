   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

   <dc:title>Handwritten letter from Oppel to Schenker, dated October 15, 1913</dc:title>

   <dcterms:created>1913-10-15T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-04-21</dcterms:dateSubmitted>
   <dc:description>Oppel thanks Schenker for the valuable insights into music which his work has
    provided; he has just received the Erläuterungsausgabe of Op. 109. -- He is disparaging of the
    hermeneuticists, and asks if Schenker knows Halm’s Von zwei Kulturen der Musik and Dahm’s
    Schubert biography.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000643">Oppel</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


