    </tei:dateline>
    <tei:address rend="indent-60">
     <tei:addrLine>Feldstr 77<tei:hi rend="supralinear">IV.</tei:hi></tei:addrLine>
    </tei:address>
    <tei:salute rend="indent-10">Sehr geehrter Herr D<tei:hi rend="supralinear">r.</tei:hi>
     <tei:rs type="person" key="entity-000632">Schenker</tei:rs>![1]</tei:salute>
   </tei:opener>

   <tei:p>Längst </tei:p>

   <tei:p>Lassen </tei:p>

   <tei:p>Ende </tei:p>

   <tei:p><tei:pb n="3"/> Nun </tei:p>

   <tei:p>Nehmen </tei:p>

   <tei:p>Wenn </tei:p>

   <tei:p>Kennen </tei:p>

   <tei:p>Also </tei:p>

   <tei:closer>
