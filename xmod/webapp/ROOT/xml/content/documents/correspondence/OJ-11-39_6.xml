  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-008451">Hanslick ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-005504">Notecard</tei:rs>



      <dc:title>Handwritten notecard from Hanslick to Schenker, dated November 13, 1899</dc:title>

      <dcterms:created>1899-11-13T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-10</dcterms:dateSubmitted>
      <dc:description>Hanslick looks forward to Schenker's visit.</dc:description>
      <dc:subject/>


      <marcrel:correspondent key="entity-000331">Eduard Hanslick</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#print"/><tei:rs type="person" key="entity-000331">ED.
              HANSLICK</tei:rs></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#EH"/>Wien <tei:date when="1899-11-13"
              >13. Nov. 99</tei:date>.</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute>Sehr geehrter Herr <tei:rs type="person" key="entity-000632"
          >Doctor</tei:rs></tei:salute>
      </tei:opener>

      <tei:p>Bestens dankend für Ihren freundlichen Antrag werde ich Sie mit Vergnügen morgen
        Dienstag um <tei:hi rend="underline">12 Uhr</tei:hi> erwarten.<tei:note xml:id="r0001-fn01"
          type="editorial" place="foot">i.e. November 14.</tei:note></tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Ihr ergebenster</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000331">Ed.
          Hanslick</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#print"/><tei:rs type="person" key="entity-000331">ED.
              HANSLICK</tei:rs></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#EH"/>Vienna, <tei:date
              when="1899-11-13">November 13, 1899</tei:date></tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute>Dear <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs></tei:salute>
      </tei:opener>

      <tei:p>With many thanks for your friendly request, I will expect you with pleasure tomorrow,
        Tuesday, at <tei:hi rend="underline">12 noon</tei:hi>.<tei:ptr corresp="#r0001-fn01"
          type="footnote"/></tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Your most devoted</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000331">Ed.
          Hanslick</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
