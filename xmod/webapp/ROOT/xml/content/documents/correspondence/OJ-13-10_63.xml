  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated August 14,
        1928</dc:title>

      <dcterms:created>1928-08-14T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-15</dcterms:dateSubmitted>
      <dc:description>Oppel reports his arrival at his home in Kiel.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">photograph of ship, captioned: “Linienschiff
          „Schlesien“”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Galtür / Paznauntal</tei:addrLine>
            <tei:addrLine>östr. Tirol</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"> || <tei:gap reason="illegible"/> | <tei:gap reason="illegible"/>8
            28 | – 1 99 ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1928-08-14">14.VIII 28</tei:date>.
          Mein lieber Herr <tei:rs type="person" key="entity-000632">Schenker</tei:rs>,<tei:note
            xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this postcard is recorded
            in Schenker’s diary for August 16, 1928: “Von Oppel (Ansichtsk.): Begleitzeilen zum
            Datterich” (“From Oppel (picture postcard): lines accompanying [the sending of]
              <tei:title level="m">Datterich</tei:title>”). – <tei:title level="m"
              >Datterich</tei:title> is a comic play written in Hessian dialect in 1841 by Ernst
            Elias Niebergall (1815–1843) of Darmstadt.</tei:note></tei:salute>
      </tei:opener>

      <tei:p>am Sonnabend kamen wir gut hier an.<tei:note xml:id="r0001-fn02" type="editorial"
          place="foot">The photograph of the <tei:title level="m">Schlesien</tei:title> on the
            <tei:hi rend="italic">verso</tei:hi>, which was based at Kiel Harbour, suggests that the
          Oppels had returned to Kiel. </tei:note> Wetter schwül u. regnerisch. Den <tei:rs
          type="person" key="entity-004801">Jungen</tei:rs> geht’s gut. </tei:p>

      <tei:p>Das Quartett<tei:note xml:id="r0001-fn03" type="editorial" place="foot">Oppel’s String
          Quartet No. 4 in F minor, Op. 33.</tei:note> v. <tei:rs type="organization"
          key="entity-002422">Peters</tei:rs> ist noch immer nicht gekommen. Der
          „<tei:title>Datterich</tei:title>“<tei:note xml:id="r0001-fn04" type="editorial"
          place="foot">On August 15, 1928, Schenker’s diary records: “Von Oppel – „Datterich“; ich
          lese daraus vor. Eine sehr bekömmliche Heiterkeit – wir lachen nicht nur über den Inhalt,
          sondern auch darüber, daß so etwas in der 8. Auflage erscheinen kann ” (“From Oppel –
            <tei:title level="m">Datterich</tei:title>; I read aloud from it. Very wholesome humor –
          we laugh not only at the content but also because of the fact that something of this sort
          can reach an eighth edition!”).</tei:note>
        <tei:del rend="overstrike">soll</tei:del> wird Ihnen als grundlegende Morgenlektüre gute
        Dienst leisten. </tei:p>

      <tei:closer>
        <tei:salute>Mit d. herzl. Grüssen Ihnen allen </tei:salute>
        <tei:salute rend="indent-50">Ihr treuer</tei:salute>
        <tei:signed rend="indent-80"><tei:rs type="person" key="entity-000643"
          >RO.</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">photograph of ship, captioned: “Battleship
          ‘Schlesien’”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Galtür, Paznaun Valley</tei:addrLine>
            <tei:addrLine>Austrian Tyrol</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"> || <tei:gap reason="illegible"/> | <tei:gap reason="illegible"/>8
            28 | – 1 99 ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1928-08-14">August 14,
          1928</tei:date>. My dear Mr. <tei:rs type="person" key="entity-000632"
            >Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>We arrived here<tei:ptr corresp="#r0001-fn02" type="footnote"/> safely on Saturday. The
        weather is humid and rainy. The <tei:rs type="person" key="entity-004801">boys</tei:rs> are
        well.</tei:p>

      <tei:p>The quartet published by <tei:rs type="organization" key="entity-002422"
          >Peters</tei:rs><tei:ptr corresp="#r0001-fn03" type="footnote"/> has still not yet
        arrived. <tei:title level="m">Datterich</tei:title><tei:ptr corresp="#r0001-fn04"
          type="footnote"/> will serve you well as basic morning reading.</tei:p>

      <tei:closer>
        <tei:salute>With most cordial greetings to you all,</tei:salute>
        <tei:salute rend="indent-50">Your faithful</tei:salute>
        <tei:signed rend="indent-80"><tei:rs type="person" key="entity-000643"
          >RO</tei:rs></tei:signed>
      </tei:closer>
    </tei:div>

  </sdo:record>
