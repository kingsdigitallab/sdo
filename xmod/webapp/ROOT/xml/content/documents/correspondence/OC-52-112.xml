      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated March 18, 1913</dc:title>

      <dcterms:created>1913-03-18T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-23</dcterms:dateSubmitted>
      <dc:description>Hertzka has read Schenker's letter [WSLB 149] and its enclosures, and will be
        in touch when he returns.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>Die Direktion der Universal-Edition,
            A.-G.</tei:addrLine>
          <tei:addrLine>Wien, I., <tei:del rend="overstrike">Wipplingerstr.
            32,</tei:del></tei:addrLine>
          <tei:addrLine><tei:handShift new="#stamped"/>I. Reichsratsstrasse 9</tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:dateline rend="indent-70"><tei:handShift new="#TPue"/>
          <tei:placeName>Wien</tei:placeName>, <tei:date when="1913-03-18">18. März
          1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Wohlgeboren Herrn Professor Dr. <tei:persName>Heinr.
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:placeName><tei:hi rend="underline"
              >Wien</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute>Sehr verehrter Herr <tei:rs key="entity-000632" type="person"
            >Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this letter is recorded in Schenker's diary for March 19, 1913: “Antwort v. Hertzka
            langt ein: er stehe vor der Osterreise; der Gegensatz sei in die Augen springend, u. s.
            f. Ob er doch meinen Vorschlag anzunehmen die Klugheit haben wird?” (“Reply from Hertzka
            arrives: he is about to go on his Easter travels; the contrast is startling to behold,
            etc. But will he have the intelligence to take up my
          suggestion?”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Ich stehe unmittelbar vor einer Osterreise; habe Ihren gesch.
          Brief<tei:note xml:id="r0001-fn02" type="editorial" place="foot"><tei:ref
            type="correspondence" cRef="WSLB-149">WSLB 149</tei:ref>, March 18, 1913, enclosing five
          letters that Schenker has received, two from Vienna and three from Germany, supposedly
          contrasting the “dishonorableness” (<tei:hi rend="italic">Unehrlichkeit</tei:hi>) of the
          two Austrians with the “honorableness” (<tei:hi rend="italic">Ehrlichkeit</tei:hi>) of the
          three Germans.</tei:note> mit grossem Interesse gelesen und danke Ihnen für den Inhalt
        desselben sehr. Auch die 5 Beilagen habe ich aufmerksam studiert. Der Gegensatz zwischen
        Wien und <tei:rs type="place" key="entity-002482">Deutschland</tei:rs> ist in die Augen
        springend. Ich lasse Ihnen die Zuschriften wieder zugehen und behalte mir vor, sofort nach
        meiner Rückkehr, Sie zum Zwecke einer Zusammenkunft zu verständigen. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-20">Mit verbindlichen Grüssen</tei:salute>
        <tei:salute rend="indent-30">Ihr in aufrichtiger Hochschätzung</tei:salute>
        <tei:salute rend="indent-70">ergebener</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>The Administration of Universal Edition,
            &amp; Co.</tei:addrLine>
          <tei:addrLine>Vienna I, <tei:del rend="overstrike">Wipplingerstraße
            32</tei:del></tei:addrLine>
          <tei:addrLine><tei:handShift new="#stamped"/>I, Reichsratsstrasse 9</tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:dateline rend="indent-70"><tei:handShift new="#TPue"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:date when="1913-03-18">March 18,
            1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Professor <tei:persName>Heinrich
            Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:placeName><tei:hi rend="underline"
              >Vienna</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute>Highly revered <tei:rs key="entity-000632" type="person">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
            type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">I am just about to set off on an Easter journey. I have read your esteemed
          letter<tei:ptr corresp="#r0001-fn02" type="footnote"/> with great interest, and thank you
        very much for its contents. I have studied its five enclosures, too, with care. The contrast
        between Vienna and <tei:rs type="place" key="entity-002482">Germany</tei:rs> is striking. I
        will have the replies returned to you, and will make a mental note to be in touch with you
        the moment I get back with a view to setting up a meeting.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-20">With sincere greetings,</tei:salute>
        <tei:salute rend="indent-30">and kind regards,</tei:salute>
        <tei:salute rend="indent-70">Your devoted</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
