 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-008515">WittgensteinP ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



   <dc:title>Typewritten letter from Paul Wittgenstein to Schenker, dated June 26, 1913</dc:title>

   <dcterms:created>1913-06-26T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-08-01</dcterms:dateSubmitted>
   <dc:description>Paul Wittgenstein regrets that he is unable to acquiesce to Schenker's
    photographic request since it is his mother who must give authorization.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000971">WittgensteinP</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:address>
     <tei:addrLine><tei:handShift new="#pr"/>WIEN</tei:addrLine>
     <tei:addrLine>I., ALBRECHTGASSE 3.</tei:addrLine>
    </tei:address>
    <tei:dateline><tei:handShift new="#TPpw"/>Wien, <tei:date when="1913-06-26">26. Juni
      1913</tei:date>.</tei:dateline><tei:lb/>
    <tei:salute>Sehr geehrter <tei:rs type="person" key="entity-000632">Herr</tei:rs>!<tei:note
      xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this letter is not recorded in
      Schenker’s diary.</tei:note>
    </tei:salute>
   </tei:opener>

   <tei:p rend="indent-20">Ich bestätige dankend den Empfang Ihres werten Schreiben vom <tei:date
     when="1913-06-25">25. Juni</tei:date>.<tei:note xml:id="r0001-fn02" type="editorial"
     place="foot">Writing of Schenker’s (non-extant) communication to Paul Wittgenstein is recorded
     in his diary for June 25, 1913: “An Paul Wittgenstein wegen der Erlaubnis eines fotographischen
     Abzuges von opus 109.” (“To Paul Wittgenstein, regarding permission to have a photographic copy
     made of Op. 109.”).</tei:note> Leider kann ich Ihre Bitte vorläufig nicht erfüllen, da meine
     <tei:rs type="person" key="entity-000970">Mutter</tei:rs>, deren Eigentum das gewünschte
    Manuscript ist gegenwärtig nicht in Wien ist und erst Anfang der nächsten Woche hieher
    zurückkehrt. </tei:p>

   <tei:p rend="indent-20">Sobald meine <tei:rs type="person" key="entity-000970">Mutter</tei:rs>
    zurückgekehrt sein wird, werde ich sie fragen, ob sie bereit ist, das Manuscript fotografieren
    zu lassen und Ihnen die diesbezügliche Antwort schriftlich mitteilen. Auf jeden Fall aber können
    Sie Samstag zwischen 12–1 Uhr das Manuscript besichtigen. </tei:p>

   <tei:closer>
    <tei:salute rend="indent-20">Mit dem Ausdrucke vorzüglicher Hochachtung</tei:salute>
    <tei:signed rend="indent-40">
     <tei:rs type="person" key="entity-000971"><tei:handShift new="#PW"/>Paul Wittgenstein</tei:rs>
    </tei:signed>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:address>
     <tei:addrLine><tei:handShift new="#pr"/>VIENNA I</tei:addrLine>
     <tei:addrLine>ALBRECHTGASSE 3</tei:addrLine>
    </tei:address>
    <tei:dateline><tei:handShift new="#TPpw"/>Vienna, <tei:date when="1913-06-26">June 26,
      1913</tei:date></tei:dateline><tei:lb/>
    <tei:salute>Dear <tei:rs type="person" key="entity-000632">Sir</tei:rs>,<tei:ptr
      corresp="#r0001-fn01" type="footnote"/></tei:salute>
   </tei:opener>

   <tei:p rend="indent-20">With thanks I acknowledge receipt of your esteemed letter of <tei:date
     when="1913-06-25">June 25</tei:date>.<tei:ptr corresp="#r0001-fn02" type="footnote"/> Sadly, I
    cannot at this point acquiesce to your request, since my <tei:rs type="person"
     key="entity-000970">mother</tei:rs>, who is the owner of the manuscript, is currently not in
    Vienna and will return <tei:supplied reason="clarity">to the city</tei:supplied> at earliest the
    beginning of next week.</tei:p>

   <tei:p rend="indent-20">As soon as my <tei:rs type="person" key="entity-000970">mother</tei:rs>
    is back, I will ask her whether she is willing to have the manuscript photographed, and will
    inform you in writing of her answer on this matter. In any case, however, you can examine the
    manuscript on Saturday between 12 noon and 1 p.m.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-20">Respectfully yours,</tei:salute>
    <tei:signed rend="indent-40">
     <tei:rs type="person" key="entity-000971"><tei:handShift new="#PW"/>Paul Wittgenstein</tei:rs>
    </tei:signed>
   </tei:closer>

  </tei:div>
 </sdo:record>
