 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-008515">WittgensteinP ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



   <dc:title>Handwritten postcard from Paul Wittgenstein to Schenker, postmarked June 27,
    1913</dc:title>

   <dcterms:created>1913-06-27T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-08-01</dcterms:dateSubmitted>
   <dc:description>Paul Wittgenstein regrets that he cannot let Schenker examine the autograph
    manuscript of Beethoven Op. 109 on Saturday because the key is not available.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000971">WittgensteinP</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#PW"/>Herrn D<tei:hi
        rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:addrLine>
      <tei:addrLine>III. Reisnerstraße 38</tei:addrLine>
      <tei:addrLine>Wien</tei:addrLine>
     </tei:address>
     <tei:lb/>
     <tei:fw type="postmark"> || 3/3 WIEN 49 | 27 VI 1<tei:gap reason="illegible"/> | * I *
      ||</tei:fw>
     <tei:fw type="postmark"> || <tei:gap reason="illegible"/> WIEN <tei:gap reason="illegible"/> |
      27. VI. 13 | * 7a * ||</tei:fw>
     <tei:lb/>
     <tei:note type="editorial" place="inline">For continuation of the recto, see
     below.</tei:note><tei:lb/>
    </tei:fw>
    <tei:milestone unit="folio" n="verso"/><tei:lb/>
    <tei:salute><tei:handShift new="#PW"/> Sehr geehrter <tei:rs type="person" key="entity-000632"
      >Herr</tei:rs>,<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this
      postcard is not recorded in Schenker’s diary. — The postcard is a follow-up to Wittgenstein's
      letter <tei:ref type="correspondence" cRef="OJ-15-24_2">OJ 15/24, [2]</tei:ref>, of June 26,
      1913.</tei:note></tei:salute>
   </tei:opener>

   <tei:p rend="first">zu meinem größten Bedauern, kann ich Ihnen nicht einmal Samstag den
    Manuscripte erschauen lassen, da meine <tei:rs type="person" key="entity-000970">Mutter</tei:rs>
    den Schlüssel des betreffenden Kastens mitgenommen hat. So wie meine <tei:rs type="person"
     key="entity-000970">Mutter</tei:rs> zurückgekehrt sein wird, werde ich Ihnen Ihre Antwort
    mittheilen. <tei:milestone unit="folio" n="recto"/> Es thut mir leid, Sie durch meinen gestrigen
    Brief unwissentlich irre geführt zu haben.<tei:note xml:id="r0001-fn02" type="editorial"
     place="foot">Schenker’s diary for June 28, 1913 records his follow-up to this letter:
     “Expreßbrief an Wittgenstein mit gründlicher Motivierung meiner Bitte, im Hinblick auf seine
     Mutter” (“express letter to Wittgenstein giving the underlying motivation for my request, in
     consideration of his mother.”).</tei:note></tei:p>

   <tei:closer>
    <tei:salute rend="indent-10">Ihr sehr ergebr</tei:salute>
    <tei:signed rend="indent-10"><tei:rs type="person" key="entity-000971">Paul
      Wittgenstein</tei:rs></tei:signed>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#PW"/>Dr. Heinrich
       Schenker</tei:addrLine>
      <tei:addrLine>Reisnerstraße 38</tei:addrLine>
      <tei:addrLine>Vienna III</tei:addrLine>
     </tei:address>
     <tei:lb/>
     <tei:fw type="postmark"> || 3/3 VIENNA 49 | 27 VI 1<tei:gap reason="illegible"/> | * I *
      ||</tei:fw>
     <tei:fw type="postmark"> || <tei:gap reason="illegible"/> VIENNA <tei:gap reason="illegible"/>
      | 27. VI. 13 | * 7a * ||</tei:fw>
     <tei:lb/>
     <tei:note type="editorial" place="inline">For continuation of the recto, see
     below.</tei:note><tei:lb/>
    </tei:fw>
    <tei:milestone unit="folio" n="verso"/><tei:lb/>
    <tei:salute><tei:handShift new="#PW"/> Dear <tei:rs type="person" key="entity-000632"
      >Sir</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
   </tei:opener>

   <tei:p rend="first">To my greatest regret, I cannot have you inspect the manuscripts, since my
     <tei:rs type="person" key="entity-000970">mother</tei:rs> has taken away with her the key to
    the cabinet concerned. As soon as my <tei:rs type="person" key="entity-000970">mother</tei:rs>
    returns, I will convey her answer to you. <tei:milestone unit="folio" n="recto"/> I am sorry
    that I unwittingly misled you by my letter of yesterday.<tei:ptr corresp="#r0001-fn02"
     type="footnote"/></tei:p>

   <tei:closer>
    <tei:salute rend="indent-10">Your very devoted</tei:salute>
    <tei:signed rend="indent-10"><tei:rs type="person" key="entity-000971">Paul
      Wittgenstein</tei:rs></tei:signed>
   </tei:closer>

  </tei:div>
 </sdo:record>
