  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-008521">RoentgenJ ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002845">Lettercard</tei:rs>



      <dc:title>Handwritten lettercard from Julius Röntgen to Schenker, dated February 10,
        1915</dc:title>

      <dcterms:created>1915-02-10T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-10-10</dcterms:dateSubmitted>
      <dc:description>Röntgen reminisces on past experiences with Schenker and hopes to meet
        again.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000724">JRoentgen</marcrel:correspondent>

      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >BRIEFKAART</tei:hi></tei:fw><tei:lb/>
          <tei:address>
            <tei:addrLine>Naam en Adres des Afzenders</tei:addrLine>
            <tei:addrLine><tei:handShift new="#JR"/>Julius Röntgen</tei:addrLine>
            <tei:addrLine>Amsterdam</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/>AAN <tei:handShift new="#JR"/>Herrn D<tei:hi
                rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine rend="indent-10">p/a Herrn <tei:unclear reason="reading">E</tei:unclear>.
                Röntgen<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Possibly
                Engelbert Röntgen (1886–1958), Julius’s son, who served as principal cellist in the
                Vienna Court Opera from 1912 to 1914.</tei:note></tei:addrLine>
            <tei:addrLine rend="indent-20">Bauernmarkt 11</tei:addrLine>
            <tei:addrLine rend="indent-60"><tei:hi rend="double-underline">Wien
              I</tei:hi></tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| AMSTERDAM | 11-12N | 10.II | 1915 | *** ||</tei:fw><tei:lb/>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:address>
            <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-005779"
                >Amsterdam</tei:rs>, <tei:date when="1915-02-10">10 Febr.
              15</tei:date></tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute>Verehrtester Herr <tei:rs type="person" key="entity-000632"
            >Doctor</tei:rs>,<tei:note xml:id="r0001-fn02" type="editorial" place="foot">Receipt of
            this lettercard is not recorded in Schenker’s diary; presumably it was forwarded by
            hand.</tei:note></tei:salute>
      </tei:opener>

      <tei:p>Ihre Karte<tei:note xml:id="r0001-fn03" type="editorial" place="foot">Writing of this
          postcard, which is not known to survive, is not recorded in Schenker’s diary. Presumably
          it omitted Schenker’s address.</tei:note> war mir eine große Freude, für die ich Ihnen
        herzlichst danke – es war wie ein Gruß aus der guten alten Wiener Zeit, wo Sie u. <tei:rs
          type="person" key="entity-000094">Brahms</tei:rs> auf dem Podium im Bösendorfer
          Saal<tei:note xml:id="r0001-fn04" type="editorial" place="foot">Bösendorfer Saal: recital
          and chamber-music hall in Vienna, on the Herrengasse, district I, first opened in
          1872.</tei:note> saßen und uns zuhörten, wo wir guten Wein im Klosterneuburger Keller
        zusammen tranken – all diese Erinnerungen weckten Ihre lieben Zeilen auf’s Neue. Also auf
        Wiedersehen hoffentlich einmal mit dem Röntgen-Trio,<tei:note xml:id="r0001-fn05"
          type="editorial" place="foot">Röntgen Trio: Julius Röntgen (piano) and his two sons,
          Julius (violin) and Engelbert (cello).</tei:note> dessen Senior Ihnen freundschaftlichsten
        Gruß sendet! </tei:p>

      <tei:closer>
        <tei:note type="editorial" place="inline">without signature</tei:note>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >LETTERCARD</tei:hi></tei:fw><tei:lb/>
          <tei:address>
            <tei:addrLine>Name and Address of the Sender</tei:addrLine>
            <tei:addrLine><tei:handShift new="#JR"/>Julius Röntgen</tei:addrLine>
            <tei:addrLine>Amsterdam</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/>To: <tei:handShift new="#JR"/>Dr. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine rend="indent-10">c/o Mr. <tei:unclear reason="reading">E</tei:unclear>.
                Röntgen<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:addrLine>
            <tei:addrLine rend="indent-20">Bauernmarkt 11</tei:addrLine>
            <tei:addrLine rend="indent-60"><tei:hi rend="double-underline">Vienna
              I</tei:hi></tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| AMSTERDAM | 11-12N | 10.II | 1915 | *** ||</tei:fw><tei:lb/>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:address>
            <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-005779"
                >Amsterdam</tei:rs>, <tei:date when="1915-02-10">February 10,
              1915</tei:date></tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute>Most revered <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn02"
            type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>Your postcard<tei:ptr corresp="#r0001-fn03" type="footnote"/> was a great joy for me,
        for which I thank you most heartily. It was like a greeting from the good old Vienna days,
        when you and <tei:rs type="person" key="entity-000094">Brahms</tei:rs> sat on the stage in
        the Bösendorfer Saal<tei:ptr corresp="#r0001-fn04" type="footnote"/> and listened to us,
        when we drank good wine together in the Klosterneuburger Keller. Your loving lines stirred
        up all of these memories anew. So until we see each other again sometime – with the Röntgen
          Trio,<tei:ptr corresp="#r0001-fn05" type="footnote"/> I hope, whose leader sends you the
        most friendly greeting!</tei:p>

      <tei:closer>
        <tei:note type="editorial" place="inline">without signature</tei:note>
      </tei:closer>

    </tei:div>
