  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">postcard</tei:rs>



      <dc:title>Typewritten postcard from UE to Schenker, dated June 4, 1913</dc:title>

      <dcterms:created>1913-06-04T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-24</dcterms:dateSubmitted>
      <dc:description>Hertzka has instructed the printers regarding placement of
        bar-numbers.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:note type="editorial" place="inline">advertisement for Der Album der Saison / Excelsior
          in left third of <tei:hi rend="italic">recto</tei:hi></tei:note><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:supplied>An:</tei:supplied>
            <tei:handShift new="#TPue"/>Wohlgeboren Herrn Prof. H. Schenker</tei:addrLine>
          <tei:addrLine rend="indent-40">Wien III.,</tei:addrLine>
          <tei:addrLine rend="indent-40">Reisnerstrasse 38</tei:addrLine>
        </tei:address>
        <tei:fw type="postmark"><tei:note type="editorial" place="inline"
          >illegible</tei:note></tei:fw><tei:lb/><tei:lb/>
        <tei:milestone unit="folio" n="verso"/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#TPue"/>Wohlgeboren Herrn Dr. Heinrich
            Schenker</tei:addrLine>
          <tei:addrLine rend="indent-60">Wien</tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:salute>Sehr geehrter Herr <tei:rs type="person" key="entity-000632"
            >Professor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt
            of this postcard is apparently not recorded in Schenker's diary, but receipt of the
            second batch of proofs is recorded on June 4, 1913: “Zweite Correkturen eingelaufen!”
            (“Second proofs arrived!”). </tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="indent-30">Im Besitze Ihrer gesch. Karte vom <tei:date when="1913-06-03">3.
          ds.</tei:date><tei:note xml:id="r0001-fn02" type="editorial" place="foot"> = <tei:ref
            type="correspondence" cRef="WSLB-159">WSLB 159</tei:ref>, June 3, 1913. </tei:note>
        erlauben wir uns Ihnen mitzuteilen, dass wir die Druckerei bereits angewiesen haben, die
        Taktzahlen am Rand<tei:note xml:id="r0001-fn03" type="editorial" place="foot">In the
          analytical section, entitled “Einführung” (“Introduction”), bars 26–48, which is in
          two-column layout, containing text, music examples, and diagrams, bar-numbers are given
          for reference in small type in the outer margins of each page, in the form of, e.g., “T.
          14–16” and “T. 29 ff.”. </tei:note> gemäss Ihrer Angabe zu setzen. </tei:p>

      <tei:p rend="indent-30">Wir empfehlen uns</tei:p>

      <tei:closer>
        <tei:add><tei:note type="editorial" place="inline">unsigned</tei:note></tei:add><tei:lb/>
        <tei:salute rend="indent-80"><tei:handShift new="#printed"/>Hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-70"><tei:rs key="entity-002408" type="organization"
            >„Universal-Edition“ A-G.</tei:rs></tei:signed>
        <tei:signed rend="indent-70">(Jos. Aibl Verlag, G.m.b.H.)</tei:signed><tei:lb/>
        <tei:dateline><tei:handShift new="#printed"/>Wien, am <tei:handShift new="#TPue"/><tei:date
            when="1913-06-04">4. Juni <tei:handShift new="#printed"/>191<tei:handShift new="#TPue"
            />3</tei:date></tei:dateline>
        <tei:address>
          <tei:addrLine>I. Reichsratsstraße 9.</tei:addrLine>
        </tei:address>
        <tei:add place="inline"><tei:note type="editorial" place="inline">initialled in bottom left
            corner: </tei:note><tei:handShift new="#unkUE"/><tei:unclear reason="reading"
            >U</tei:unclear></tei:add>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:note type="editorial" place="inline">advertisement for Der Album der Saison / Excelsior
          in left third of <tei:hi rend="italic">recto</tei:hi></tei:note><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:supplied>To:</tei:supplied>
            <tei:handShift new="#TPue"/>Prof. H. Schenker, Esq.</tei:addrLine>
          <tei:addrLine rend="indent-40">Vienna III</tei:addrLine>
          <tei:addrLine rend="indent-40">Reisnerstraße 38</tei:addrLine>
        </tei:address>
        <tei:fw type="postmark"><tei:note type="editorial" place="inline"
          >illegible</tei:note></tei:fw><tei:lb/><tei:lb/>
        <tei:milestone unit="folio" n="verso"/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#TPue"/>Dr. Heinrich Schenker, Esq.</tei:addrLine>
          <tei:addrLine rend="indent-60">Vienna</tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:salute>Dear <tei:rs type="person" key="entity-000632">Professor</tei:rs>,<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="indent-30">In receipt of your esteemed card of the <tei:date when="1913-06-03"
          >3rd of the month</tei:date>,<tei:ptr corresp="#r0001-fn02" type="footnote"/> we take the
        liberty of informing you that we have already instructed the printers to set the bar numbers
        at the edge<tei:ptr corresp="#r0001-fn03" type="footnote"/> in accordance with your
        specification.</tei:p>

      <tei:p rend="indent-30">We remain,</tei:p>

      <tei:closer>
        <tei:add><tei:note type="editorial" place="inline">unsigned</tei:note></tei:add><tei:lb/>
        <tei:salute rend="indent-80"><tei:handShift new="#printed"/>With kind regards,</tei:salute>
        <tei:signed rend="indent-70"><tei:rs key="entity-002408" type="organization">Universal
            Edition &amp; Co.</tei:rs></tei:signed>
        <tei:signed rend="indent-70">(Jos. Aibl Publishers &amp; Co.)</tei:signed><tei:lb/>
        <tei:dateline><tei:handShift new="#printed"/>Vienna, <tei:handShift new="#TPue"/><tei:date
            when="1913-06-04">June 4, <tei:handShift new="#printed"/>191<tei:handShift new="#TPue"
            />3</tei:date></tei:dateline>
        <tei:address>
          <tei:addrLine>I, Reichsratsstraße 9</tei:addrLine>
        </tei:address>
        <tei:add place="inline"><tei:note type="editorial" place="inline">initialled in bottom left
            corner: </tei:note><tei:handShift new="#unkUE"/><tei:unclear reason="original_unclear"
            >U</tei:unclear></tei:add>
      </tei:closer>

    </tei:div>
