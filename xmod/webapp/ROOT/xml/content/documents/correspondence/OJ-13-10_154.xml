  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated August 16,
        1932</dc:title>

      <dcterms:created>1932-08-16T13:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2026-02-25</dcterms:dateSubmitted>
      <dc:description>Oppel sends greetings.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: lake with tower, mountains behind,
          captioned on the recto: “Mäuseturm bei Bingen erhielt seine heutige Gestalt im Jahre 1856,
          besteht jedoch bereits seit der Mitte des XIII. Jahrhunderts. […] Heute dient der
          Mäuseturm als Signalwarte der Schifffahrt.“</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Igls b. Innsbruck</tei:addrLine>
            <tei:addrLine>„Igler Hof“</tei:addrLine>
            <tei:addrLine>Tirol</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| BINGEN | <tei:gap reason="illegible"/>32 | <tei:gap
              reason="illegible"/> | * RHEIN<tei:gap reason="illegible"/> * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1932-08-16">16. 8. 32</tei:date>. Mein
          lieber Herr <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this picture postcard is recorded in Schenker’s diary for August 17, 1932: “Von Oppel
            (Ansichtsk.): Gruß aus Bingen am Rhein.” (“From Oppel (picture postcard): greetings from
            Bingen on the Rhine.”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p>Vom Rhein u. Hunsrück sende ich Ihnen beiden die herzlichsten Grüsse. Sehr heiss u.
        durstig hier. Im Brief bald mehr.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">Ihr treuer</tei:salute>
        <tei:signed rend="indent-20"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: lake with tower, mountains behind,
          captioned on the recto: “The Mouse Tower at Bingen acquired its present form in the year
          1856, but dates back to the middle of the 13th century. [...] Today the Mouse Tower serves
          as a lighthouse for shipping.“</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Igls near Innsbruck</tei:addrLine>
            <tei:addrLine>Igler Hof</tei:addrLine>
            <tei:addrLine>Tyrol</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| BINGEN | <tei:gap reason="illegible"/>32 | <tei:gap
              reason="illegible"/> | * RHINE<tei:gap reason="illegible"/> * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1932-08-16">August 16,
          1932</tei:date>. My dear <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>From the Rhine and the Hunsrück, I send the two of you my most cordial greetings. It is
        very hot and parched here.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">Your faithful</tei:salute>
        <tei:signed rend="indent-20"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
