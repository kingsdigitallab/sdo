  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated February 5, 1913</dc:title>

      <dcterms:created>1913-02-05T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-20</dcterms:dateSubmitted>
      <dc:description>Hertzka expresses delight at the MS just received [of Schenker's elucidatory
        edition of Beethoven sonata Op. 109] and requests a date/time at which they could meet to
        discuss details.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
        </tei:address>
        <tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPue"/><tei:date
            when="1913-02-05">5. Februar 1913</tei:date>.</tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Wohlgeboren Herrn Professor Dr. <tei:persName>Heinrich
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:rs type="place" key="entity-002484"><tei:hi
                rend="underline">Wien</tei:hi></tei:rs></tei:addrLine>
        </tei:address>
        <tei:salute>Sehr geehrter Herr <tei:rs key="entity-000632" type="person"
            >Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Writing of
            this letter is recorded in Schenker’s diary for February 6, 1913: “Dankbrief Hertzka’s”
            (“Letter of thanks from Hertzka”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Sie erhalten gleichzeitig das gewünschte Exemplar von <tei:rs
          type="composition" key="entity-001203">Beethoven's Sonate op. 110</tei:rs>.<tei:note
          xml:id="r0001-fn02" type="editorial" place="foot">As requested in <tei:ref
            type="correspondence" cRef="WSLB-146">WSLB 146</tei:ref>, February 6, 1913, the Piano
          Sonata in A<tei:g type="flat"/> major, Op. 110, possibly in the Anton Door edition
          published by Universal Edition, which Schenker needed as a base text for his next volume,
              <tei:bibl><tei:rs type="work" key="entity-001735"><tei:title level="m">Die letzten
                fünf Sonaten von Beethoven … op. 110</tei:title></tei:rs> (Vienna: UE,
            1914)</tei:bibl>.</tei:note> Das Manuskript, das Sie mir heute einsandten,<tei:note
          xml:id="r0001-fn03" type="editorial" place="foot">Schenker's musical text with critical
          commentary of his edition, <tei:bibl><tei:rs type="work" key="entity-001734"><tei:title
                level="m">Die letzten fünf Sonaten von Beethoven … op. 109</tei:title></tei:rs>
            (Vienna: UE, 1913</tei:bibl>).</tei:note> zeigt schon nach ganz flüchtiger Durchsicht
        die geradezu fabelhafte Arbeit, die hier geleistet wurde und ich bin überzeugt, dass die
        Herausgabe Aufsehen erregen wird. </tei:p>

      <tei:p rend="first">Ich bin unmittelbar vor einer mehrtätigen Reise (<tei:rs type="place"
          key="entity-002479">Leipzig</tei:rs> und <tei:rs type="place" key="entity-002501"
          >Berlin</tei:rs>), komme nächste Woche Mittwoch oder Donnerstag zurück, dann wollen wir
        einmal zusammenkommen (ev. abends, wenn Sie und ich unser Tagwerk beendet haben) und all die
        nötigen Fragen persönlich behandeln. Inzwischen grüsst Sie herzlichst Ihr Ihnen in
        aufrichtiger Hochachtung </tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">ganz ergebener</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Josef Aibl Publishers &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
        </tei:address>
        <tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPue"/><tei:date
            when="1913-02-05">February 5, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Professor <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:rs type="place" key="entity-002484"><tei:hi
                rend="underline">Vienna</tei:hi></tei:rs></tei:addrLine>
        </tei:address>
        <tei:salute>Dear <tei:rs key="entity-000632" type="person">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
            type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">You will be receiving at the same time the copy of <tei:rs
          type="composition" key="entity-001203">Beethoven Op. 110</tei:rs> that you
          requested.<tei:ptr corresp="#r0001-fn02" type="footnote"/> Even just the most cursory
        glance through the manuscript that you sent me today<tei:ptr corresp="#r0001-fn03"
          type="footnote"/> shows what a truly fabulous piece of work has gone into this, and I am
        convinced that the edition will create a sensation.</tei:p>

      <tei:p rend="first">I am on the point of leaving for a journey of several days (<tei:rs
          type="place" key="entity-002479">Leipzig</tei:rs> and <tei:rs type="place"
          key="entity-002501">Berlin</tei:rs>), and will be getting back next week on Wednesday or
        Thursday. Then let us get together (perhaps in the evening, when our day's work is ended)
        and deal with all the necessary questions in person. Meanwhile, I send you my most cordial
        greetings in true admiration,</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">Your wholly devoted</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>




    </tei:div>
