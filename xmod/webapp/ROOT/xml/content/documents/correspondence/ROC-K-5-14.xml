      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Handwritten letter from Heinrich Schenker to Reinhard Oppel, dated August 16,
        1932</dc:title>

      <dcterms:created>1932-08-16T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2026-02-23</dcterms:dateSubmitted>
      <dc:description>In a wide-ranging letter, Schenker offers further thoughts on Handel’s
        Keyboard Fugue in C minor (HWV 610), broadly in agreement with Oppel’s conclusions, and on
        analyzing fugue subjects and answers in terms of their content and relation to the Urlinie.
        – He advocates study of the arrangements that great composers made of their own works. – He
        praises Dvořák’s music and makes a special plea for Otto Vrieslander’s latest published
        collection of songs, remarking on how valuable it would be for his own work were Oppel’s and
        Weisse’s music available to the public. – He rails against the French, citing in
        particular Édouard Ganche’s recent edition of Chopin, and notes in closing that Free
        Composition is nearing completion.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000632">HSchenker</marcrel:correspondent>
      <marcrel:recipient key="entity-000643">ROppel</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:salute rend="indent-20">Mein lieber <tei:rs type="person" key="entity-000632">Professor
          Oppel</tei:rs>,[1]</tei:salute>

      <tei:p rend="first">Zu </tei:p>

      <tei:p rend="first">Zur </tei:p>

      <tei:p rend="first">Daß </tei:p>

      <tei:p rend="first">Uebrigens </tei:p>

      <tei:p rend="first"><tei:pb n="5"/> Gerade </tei:p>

      <tei:p rend="first"><tei:pb n="6"/> Nun</tei:p>
      
      <tei:p rend="first"> Ob</tei:p>

      <tei:p rend="first">Es </tei:p>

      <tei:p rend="first">Sie </tei:p>

      <tei:p rend="first">Was Sie </tei:p>

      <tei:p rend="first">Was alles </tei:p>

      <tei:p rend="first">An </tei:p>

      <tei:p rend="first"><tei:handShift new="#HS"/><tei:rs type="work" key="entity-001728"
            ><tei:title>Der „fr. Satz“</tei:title></tei:rs> geht </tei:p>


      <tei:closer>
        <tei:salute>Und so grüsse ich Sie u. Ihr Haus</tei:salute>
        <tei:salute>in meinem u. meiner <tei:rs type="person" key="entity-000771"
            >Lieliechen</tei:rs>s</tei:salute>
        <tei:salute>Namen auf das herzlichste</tei:salute>
        <tei:salute rend="indent-40">Ihr</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000632">H.
          Schenker</tei:rs></tei:signed><tei:lb/>
        <tei:dateline><tei:date when="1932-08-16">16. 8. 32</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:salute rend="indent-20">My dear <tei:rs type="person" key="entity-000632">Professor
        Oppel</tei:rs>,[1]</tei:salute>
      
      <tei:p rend="first">Regarding </tei:p>
      
      <tei:p rend="first">Regarding </tei:p>
      
      <tei:p rend="first">Your </tei:p>
      
      <tei:p rend="first">Incidentally, </tei:p>
      
      <tei:p rend="first"><tei:pb n="5"/> It </tei:p>
      
      <tei:p rend="first"><tei:pb n="6"/> Now </tei:p>
      
      <tei:p rend="first">Do </tei:p>
      
      <tei:p rend="first">It is </tei:p>
      
      <tei:p rend="first">You  </tei:p>
      
      <tei:p rend="first">What </tei:p>
      
      <tei:p rend="first">So </tei:p>
      
      <tei:p rend="first">I must </tei:p>
      
      <tei:p rend="first"><tei:handShift new="#HS"/><tei:rs type="work" key="entity-001728"
        ><tei:title level="m">Free Composition</tei:title></tei:rs> is </tei:p>
      
      
      <tei:closer>
        <tei:salute>And so I greet you and your family</tei:salute>
        <tei:salute>in my Lieliechen’s and my name</tei:salute>
        <tei:salute>most cordially,</tei:salute>
        <tei:salute rend="indent-40">Your</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000632">H.
          Schenker</tei:rs></tei:signed><tei:lb/>
        <tei:dateline><tei:date when="1932-08-16">August 16, 1932</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>

