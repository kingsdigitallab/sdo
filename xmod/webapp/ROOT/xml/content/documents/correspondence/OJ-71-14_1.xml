  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-008452">Hanslick ~
        EBacher</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-008451">Hanslick ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-003332">Calling card</tei:rs>



      <dc:title>Handwritten calling card from Hanslick to Eduard Bacher, dated August 24,
        1894</dc:title>

      <dcterms:created>1894-08-24T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-08</dcterms:dateSubmitted>
      <dc:description>Hanslick recommends Schenker's "Smetana feuilleton" to the editor of the Neue
        freie Presse.</dc:description>
      <dc:subject/>


      <marcrel:correspondent key="entity-000331">Eduard Hanslick</marcrel:correspondent>
      <marcrel:recipient key="entity-008453">Eduard Bacher</marcrel:recipient>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#EH"/>Herrn <tei:rs type="person" key="entity-008453"
                >D<tei:hi rend="supralinear">r.</tei:hi> Eduard Bacher.<tei:note xml:id="r0001-fn01"
                type="editorial" place="foot">Eduard Bacher (1846–1908), lawyer and journalist,
                Chief Editor of the <tei:title level="j">Neue freie Presse</tei:title> from 1879,
                and its publisher from 1880, to 1908.</tei:note></tei:rs>
          </tei:addrLine>
          <tei:addrLine rend="indent-40">„<tei:rs type="journal" key="entity-002559"><tei:title>N.
                fr. Presse</tei:title></tei:rs>“. Wien.</tei:addrLine>
        </tei:address><tei:lb/>
      </tei:opener>

      <tei:p><tei:handShift new="#printed"/><tei:hi rend="bold">D<tei:hi rend="supralinear"
            >R.</tei:hi> EDUARD HANSLICK.</tei:hi></tei:p>

      <tei:p><tei:handShift new="#EH"/>erlaubt sich, Ihnen beifolgenden Aufsatz von D<tei:hi
          rend="supralinear">r.</tei:hi> Heinrich Schenker zur Aufnahme in die „<tei:rs
          type="journal" key="entity-002559"><tei:title>N. fr. Presse</tei:title></tei:rs>“ bestens
        zu empfehlen.<tei:note xml:id="r0001-fn02" type="editorial" place="foot">Cf. <tei:ref
            type="correspondence" cRef="OJ-11-39_3">OJ 11/39, [3]</tei:ref> of the same date. As
            <tei:ref type="correspondence" cRef="OJ-11-39_4">OJ 11/39, [4]</tei:ref> reports, the
          article was referred to another newspaper: <tei:title level="a">Aus dem Leben Smetana’s
            (Ein Besuch bei Fr. Smetana’s Witwe),</tei:title>
          <tei:title level="j">Neues Wiener Tagblatt</tei:title>, year 28, No. 245 (September 6,
          1894), the newspaper of which <tei:rs type="person" key="entity-000363">Richard
            Heuberger</tei:rs> was Editor. The article is reproduced in
              <tei:bibl><tei:editor>Hellmut Federhofer</tei:editor>, ed., <tei:title level="m"
              >Heinrich Schenker als Essayist und Kritiker …</tei:title> (Hildesheim: Georg Olms
            Verlag, 1990), pp. 109–14</tei:bibl>.</tei:note></tei:p>

      <tei:closer>
        <tei:address>
          <tei:addrLine rend="indent-60"><tei:rs type="place" key="entity-003099">Bad
              Gastein</tei:rs>
            <tei:date when="1894-08-24">24. Aug. 894</tei:date></tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#EH"/><tei:rs type="person" key="entity-008453">Dr.
              Eduard Bacher<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:rs>
          </tei:addrLine>
          <tei:addrLine rend="indent-40"><tei:rs type="journal" key="entity-002559"><tei:title
                level="j">Neue freie Presse</tei:title></tei:rs>, Vienna</tei:addrLine>
        </tei:address><tei:lb/>
      </tei:opener>

      <tei:p><tei:handShift new="#printed"/><tei:hi rend="bold">DR. EDUARD HANSLICK</tei:hi></tei:p>

      <tei:p><tei:handShift new="#EH"/>takes the liberty of recommending highly to you the enclosed
        essay by Dr. Heinrich Schenker for inclusion in the <tei:rs type="journal"
          key="entity-002559"><tei:title level="j">Neue Freie Presse</tei:title></tei:rs>.<tei:ptr
          corresp="#r0001-fn02" type="footnote"/></tei:p>

      <tei:closer>
        <tei:address>
          <tei:addrLine rend="indent-60"><tei:rs type="place" key="entity-003099">Bad
              Gastein</tei:rs>, <tei:date when="1894-08-24">August 24,
            1894</tei:date></tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>
