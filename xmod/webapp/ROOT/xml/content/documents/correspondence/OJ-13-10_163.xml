  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Reinhard Oppel and others to Schenker, dated December 27,
        1932</dc:title>

      <dcterms:created>1932-12-27T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2026-02-27</dcterms:dateSubmitted>
      <dc:description>Oppel, his wife, and two of his sons send the Schenkers greetings for the New
        Year.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-000644">Ulrich Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-003957">Walter Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-005266">Elfriede Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >Postkarte</tei:hi></tei:fw><tei:lb/>
          <tei:fw type="envelope">
            <tei:address>
              <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof.
                Dr. Heinrich Schenker</tei:addrLine>
              <tei:addrLine><tei:handShift new="#pr"/>in <tei:handShift new="#RO"/>Wien III /
                Östreich</tei:addrLine>
              <tei:addrLine>Keilgasse 8<tei:hi rend="supralinear">12</tei:hi></tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark"> || LEIPZIG W31 | 27 12 32 | 9–10 V | * MESSESTADT * ||</tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:salute><tei:handShift new="#RO"/><tei:date when="1932-12-27">27. XII 32</tei:date>.
            Lieber Herr <tei:rs type="person" key="entity-000632">Professor
              Schenker</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt
              of this postcard is recorded in Schenker’s diary for December 28, 1932: “Von Oppel
              (K.): Wünsche von allen!” (“From Oppel (postcard): greetings from everyone!”). —
              Schenker’s diary for December 29 records: “An Oppel (Ansichtsk.): erwidern die Grüße.”
              (“To Oppel (picture postcard): we reciprocate their
            greetings.”).</tei:note></tei:salute>
        </tei:opener>

        <tei:p>Ihnen und <tei:rs type="person" key="entity-000771">Ihrer lieben Frau</tei:rs> senden
          wir alle die herzlichsten Grüsse u. Wünsche! <tei:rs type="person" key="entity-003957"
            >Walter</tei:rs> u. <tei:rs type="person" key="entity-000644">Ulrich</tei:rs> waren
          jetzt ein ganzes Jahr fort. <tei:rs type="person" key="entity-008523">Bepo</tei:rs> freut
          sich über d. Weinachtsbaum und die Lichter. </tei:p>

        <tei:closer>
          <tei:salute rend="indent-40">Ihr treuer</tei:salute>
          <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
              Oppel</tei:rs></tei:signed>
          <tei:signed rend="indent-60"><tei:handShift new="#EO"/><tei:rs type="person"
              key="entity-005266">Elfriede Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <!-- -->
      <!-- ULRICH -->
      <!-- -->


      <tei:div type="part_2">

        <tei:opener/>
        <tei:p/>
        <tei:closer>
          <tei:salute><tei:handShift new="#UO"/>Mit herzlichsten Neujahrswünschen</tei:salute>
          <tei:salute>grüsst Sie beide</tei:salute>
          <tei:signed rend="indent-80"><tei:rs type="person" key="entity-000644">Ulrich
              Oppel</tei:rs>
          </tei:signed>
        </tei:closer>

      </tei:div>

      <!-- -->
      <!-- WALTER -->
      <!-- -->

      <tei:div type="part_3">

        <tei:opener/>

        <tei:p><tei:handShift new="#WO"/>Aus der „großen Seestadt“ Ihnen die herzlichsten
          Neujahrsgrüße. Ich habe mich für ein paar <tei:milestone unit="folio" n="recto"/> Tage
          hier eingefunden aus Hamburg. Der Urlaub ist nur viel zu kurz und zu schnell um. Am
            <tei:date when="1933-01-01">1.</tei:date> muß ich wieder in den „Rauhen Norden“
          zurückkehren und mit frischen Kräften an die Arbeit gehen. Der <tei:rs type="person"
            key="entity-008523">Bepo</tei:rs> ist ein kleiner niedlicher Junge geworden. Ich habe
          ihn ja seit einem Jahr nicht gesehen. </tei:p>

        <tei:closer>
          <tei:salute>Mit herzlichen Grüßen Ihnen beiden</tei:salute>
          <tei:salute rend="inden-30">Ihr</tei:salute>
          <tei:signed rend="indent-40"><tei:rs type="person" key="entity-003957">Walter
              Oppel</tei:rs> (der „Torpedo“)</tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>


    <tei:div type="translation">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >Postcard</tei:hi></tei:fw><tei:lb/>
          <tei:fw type="envelope">
            <tei:address>
              <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof.
                Heinrich Schenker</tei:addrLine>
              <tei:addrLine><tei:handShift new="#pr"/>in <tei:handShift new="#RO"/>Vienna III /
                Austria</tei:addrLine>
              <tei:addrLine>Keilgasse 8<tei:hi rend="supralinear">12</tei:hi></tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark"> || LEIPZIG W31 | 27 12 32 | 9–10 V | * TRADE FAIR CITY *
              ||</tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:salute><tei:handShift new="#RO"/><tei:date when="1932-12-27">December 27,
              1932</tei:date>. Dear <tei:rs type="person" key="entity-000632">Professor
              Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
        </tei:opener>

        <tei:p>We all send you and <tei:rs type="person" key="entity-000771">your dear wife</tei:rs>
          our warmest greetings and best wishes! <tei:rs type="person" key="entity-003957"
            >Walter</tei:rs> and <tei:rs type="person" key="entity-000644">Ulrich</tei:rs> have been
          away for a whole year now. <tei:rs type="person" key="entity-008523">Bepo</tei:rs> is
          enchanted by the Christmas tree and the lights.</tei:p>

        <tei:closer>
          <tei:salute rend="indent-40">Your faithful</tei:salute>
          <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
              Oppel</tei:rs></tei:signed>
          <tei:signed rend="indent-60"><tei:handShift new="#EO"/><tei:rs type="person"
              key="entity-005266">Elfriede Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <!-- -->
      <!-- ULRICH -->
      <!-- -->


      <tei:div type="part_2">

        <tei:opener/>
        <tei:p/>
        <tei:closer>
          <tei:salute><tei:handShift new="#UO"/>With most cordial New Year’s good
            wishes</tei:salute>
          <tei:salute>to the two of you, greetings from</tei:salute>
          <tei:signed rend="indent-80"><tei:rs type="person" key="entity-000644">Ulrich
              Oppel</tei:rs>
          </tei:signed>
        </tei:closer>

      </tei:div>

      <!-- -->
      <!-- WALTER -->
      <!-- -->

      <tei:div type="part_3">

        <tei:opener/>

        <tei:p><tei:handShift new="#WO"/>From the “great city of lakes,” the most cordial New Year’s
          greetings to you. I have put in an appearance here for a couple of <tei:milestone
            unit="folio" n="recto"/> days from Hamburg. The holiday is all too short and
            <tei:supplied reason="clarity">goes by</tei:supplied> too fast. On the <tei:date
            when="1933-01-01">1st</tei:date>, I return again to the “rugged north” and back to work
          with renewed vigor. <tei:rs type="person" key="entity-008523">Bepo</tei:rs> has become a
          winsome little fellow. I have not seen him for a whole year.</tei:p>

        <tei:closer>
          <tei:salute>With cordial greetings to you both</tei:salute>
          <tei:salute rend="inden-30">Your</tei:salute>
          <tei:signed rend="indent-40"><tei:rs type="person" key="entity-003957">Walter
              Oppel</tei:rs> (the "torpedo").</tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>

  </sdo:record>
