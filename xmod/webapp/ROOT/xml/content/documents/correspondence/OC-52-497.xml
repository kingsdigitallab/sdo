      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated July 10, 1913</dc:title>

      <dcterms:created>1913-07-10T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2026-03-11</dcterms:dateSubmitted>
      <dc:description>Hertzka expresses outrage at the Wittgenstein family's claims and restrictions
        on the photographic work that Schenker will have paid for, suggests an alternative plan, and
        promises page-proofs as soon as possible.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#pr"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-07-10">10. Juli 1913</tei:date>.</tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Wohlgeboren Herrn Dr. <tei:persName>Heinrich
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:placeName><tei:hi rend="underline"
              >Fondo</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueW"/>Sehr verehrter Herr <tei:rs key="entity-000632"
            type="person">Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Receipt of this letter is recorded in Schenker’s diary for July 12, 1913:
            “Antwort von Hertzka mit Antrag bezüglich der Photografie.” (“Reply from Hertzka with
            proposal regarding the photography.”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Besten Dank für Ihre freundl. Mitteilung vom <tei:date when="1913-07-08"
          >8. ds</tei:date>,<tei:note xml:id="r0001-fn02" type="editorial" place="foot">= <tei:ref
            type="correspondence" cRef="WSLB-166">WSLB 166</tei:ref>.</tei:note> die mich
        ausserordentlich interessiert hat. Dass sich <tei:rs type="person" key="entity-004688"
          >Wittgensteins</tei:rs> die photographischen Platte, die Sie<tei:note xml:id="r0001-fn03"
          type="editorial" place="foot">"Sie" (you): underlined in pencil by Schenker.</tei:note>
        bezahlen sollen <tei:add place="interlinear-above"><tei:handShift new="#unkUE"
          />gratis</tei:add> geben lassen, finde ich unerhört! Vielleicht würde Ihnen gestattet
        werden, die Faksimile-Reproduktion uns zu übertragen; ich erkläre mich in diesem Falle
        bereit, Ihnen die gehabten Spesen für das Photographieren zu ersetzen. Hoffentlich wird
        schon die erste der Sonaten<tei:note xml:id="r0001-fn04" type="editorial" place="foot"
              ><tei:bibl><tei:title level="m"><tei:rs type="work" key="entity-001734">Die letzten
                fünf Sonaten von Beethoven …</tei:rs></tei:title> op. 109 (Vienna: UE,
            1913)</tei:bibl>. </tei:note> derart einschlagen, dass es möglich sein wird, Ihre
        Bar-Auslagen ganz oder teilweise zurückzuerstatten. An meinem guten Willen wird es nicht
          fehlen.<tei:note xml:id="r0001-fn05" type="editorial" place="foot">"Ihnen … fehlen" (to
          refund … on my part): right-sidelined in pencil by Schenker.</tei:note> Ich werde
        trachten, dass Sie die zweite Korrektur umbrochen<tei:note xml:id="r0001-fn06"
          type="editorial" place="foot">i.e. the first page-proofs of <tei:bibl><tei:title level="m"
                ><tei:rs type="work" key="entity-001734">Die letzten fünf Sonaten von Beethoven
                …</tei:rs></tei:title> op. 109 (Vienna: UE, 1913)</tei:bibl></tei:note> recht bald
        erhalten und verbleiebe, Ihre freundlichen Sommerwünsche bestens erwiedernd, Ihr in
        aufrichtiger </tei:p>

      <tei:closer>
        <tei:salute rend="indent-70">Hochschätzung</tei:salute>
        <tei:salute rend="indent-70">ergebener</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#pr"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-07-10">July 10, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Dr. <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:placeName><tei:hi rend="underline"
              >Fondo</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueW"/>Dear <tei:rs key="entity-000632" type="person">Dr.
              <tei:supplied reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">Many thanks for your kind communication of the <tei:date when="1913-07-08"
          >8th of the month</tei:date>,<tei:ptr corresp="#r0001-fn02" type="footnote"/> which I
        found extraordinarily interesting. It seems to me outrageous that the <tei:rs type="person"
          key="entity-004688">Wittgensteins</tei:rs> claim for themselves <tei:add
          place="interlinear-above"><tei:handShift new="#unkUE"/>gratis</tei:add> the photographic
        plates for which you<tei:ptr corresp="#r0001-fn03" type="footnote"/> have to pay! Perhaps
        you might be permitted to assign the facsimile reproduction to us; let me say that I am
        prepared, in that event, to refund you for the costs that have been incurred on the
        photographic work. It is to be hoped that the first of the sonatas<tei:ptr
          corresp="#r0001-fn04" type="footnote"/> will soon be such a success that it will be
        possible to recoup your out-of-pocket expenses in whole or part. There will be no lack of
        good will on my part.<tei:ptr corresp="#r0001-fn05" type="footnote"/> I will endeavor to see
        to it that you receive the second proofs in page-make-up<tei:ptr corresp="#r0001-fn06"
          type="footnote"/> at the earliest opportunity, and, in reciprocating your kind good wishes
        for the summer, I remain</tei:p>

      <tei:closer>
        <tei:salute rend="indent-70">In high esteem</tei:salute>
        <tei:salute rend="indent-70">Your devoted</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
