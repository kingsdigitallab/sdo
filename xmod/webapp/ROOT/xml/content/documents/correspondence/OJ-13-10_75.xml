  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated April 4, 1929</dc:title>

      <dcterms:created>1929-04-04T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-22</dcterms:dateSubmitted>
      <dc:description>Oppel sends Schenker a picture postcard showing the church where he used to
        practice the organ.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: cobbled city street, captioned:
          “Groß-Gerau. Kirchstraße.”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Wien III / Östreich</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| <tei:gap reason="overstamped"/> | <tei:gap reason="overstamped"
            /> | | * (MAIN) 2 * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1929-04-04">4. IV 29</tei:date>. Mein
          lieber Herr <tei:rs type="person" key="entity-000632">Prof
          Schenker</tei:rs>,[1]</tei:salute>
      </tei:opener>

      <tei:p>hier in dieser Kirche habe ich als Junge tagelang Orgel geübt. </tei:p>

      <tei:closer>
        <tei:salute>Alles Gute u. die herzl.</tei:salute>
        <tei:salute>Grüsse Ihnen beiden</tei:salute>
        <tei:salute>Ihr treuer</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: cobbled city street, captioned:
          “Groß-Gerau. Church Street”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof.
              Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Vienna III, Austria</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| <tei:gap reason="overstamped"/> | <tei:gap reason="overstamped"
          /> | | * (MAIN) 2 * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1929-04-04">April 4, 1929</tei:date>. Mein
          lieber Herr <tei:rs type="person" key="entity-000632">Prof
            Schenker</tei:rs>,[1]</tei:salute>
      </tei:opener>
      
      <tei:p>Here, in this church, as a boy I practised the organ all day long.</tei:p>
      
      <tei:closer>
        <tei:salute>All good wishes and the most</tei:salute>
        <tei:salute>cordial greetings to the two of you.</tei:salute>
        <tei:salute>Your faithful</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
          Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
