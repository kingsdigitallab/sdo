  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



      <dc:title>Handwritten postcard from Schenker to UE, dated July 2, 1913</dc:title>

      <dcterms:created>1913-07-02T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2026-03-09</dcterms:dateSubmitted>
      <dc:description>Schenker gives UE his vacation address for proofs and other
        packages.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000632">Heinrich Schenker</marcrel:correspondent>
      <marcrel:recipient key="entity-000356">Emil Hertzka</marcrel:recipient>
      <marcrel:recipient key="entity-002408">Universal Edition</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">Absender:</tei:supplied>
              <tei:handShift new="#HS"/><tei:hi rend="lateinschr">D<tei:hi rend="supralinear"
                  >r</tei:hi> H Schenker</tei:hi>
            </tei:addrLine>
            <tei:addrLine>Waldkönigin–Fondo</tei:addrLine>
            <tei:addrLine>Südtirol</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine>An die <tei:hi rend="lateinschr"
              >„Universal-Edition“</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">Wien I</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">Reichsrathstr. 9</tei:hi></tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| FONDO | 3. VII. 13 | * c * ||</tei:fw><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/><tei:hi rend="underline">An die „<tei:rs
              type="organization" key="entity-002408">Universal-Edition</tei:rs>“</tei:hi>
          <tei:hi rend="underline">Wien</tei:hi>.<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Writing of this postcard is apparently not recorded in Schenker's diary.
          </tei:note></tei:salute>
      </tei:opener>

      <tei:p>Von Sommer-Standort aus korrigiere ich hiemit die seinerzeit im Brief an <tei:rs
          type="person" key="entity-000356">H. Direktor Hertzka</tei:rs><tei:note
          xml:id="r0001-fn02" type="editorial" place="foot">= <tei:ref type="correspondence"
            cRef="WSLB-164">WSLB 164</tei:ref>, June 28, 2026. </tei:note> angegebene Adresse der
        Vorsicht halber in folgende:</tei:p>

      <tei:p><tei:address>
          <tei:addrLine rend="indent-50"><tei:del rend="overstrike">(Belvedere)</tei:del>
            Waldkönigin–Fondo</tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:hi rend="underline">Südtirol</tei:hi></tei:addrLine>
        </tei:address></tei:p>

      <tei:p>(Belvedere u. Ronzoni könnten zu Misverständnissen führen.) Korrekturen u. sonstige
        Sendungen an die sicherere Adresse erbeten!</tei:p>

      <tei:closer>
        <tei:salute rend="indent-70">Hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-60">
          <tei:rs key="entity-000632" type="person"><tei:hi rend="lateinschr">D<tei:hi
                rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:hi></tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-07-02">2. Juli 1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">From:</tei:supplied>
              <tei:handShift new="#HS"/>Dr. H. Schenker </tei:addrLine>
            <tei:addrLine>Waldkönigin–Fondo</tei:addrLine>
            <tei:addrLine>South Tyrol</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine>To: Universal Edition</tei:addrLine>
            <tei:addrLine>Vienna I</tei:addrLine>
            <tei:addrLine>Reichsrathstraße 9</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| FONDO | 3. VII. 13 | * c * ||</tei:fw><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/><tei:hi rend="underline">To <tei:rs
              type="organization" key="entity-002408">Universal-Edition</tei:rs></tei:hi>
          <tei:hi rend="underline">Vienna</tei:hi>.<tei:ptr corresp="#r0001-fn01" type="footnote"
          /></tei:salute>
      </tei:opener>

      <tei:p>From my summer location, herewith, for safety's sake, I correct the address I gave
        recently to <tei:rs type="person" key="entity-000356">Director Hertzka</tei:rs> in a
          letter,<tei:ptr corresp="#r0001-fn02" type="footnote"/> as follows: </tei:p>

      <tei:p><tei:address>
          <tei:addrLine rend="indent-50"><tei:del rend="overstrike">(Belvedere)</tei:del>
            Waldkönigin–Fondo</tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:hi rend="underline">South
            Tyrol</tei:hi></tei:addrLine>
        </tei:address></tei:p>

      <tei:p>(Belvedere and Ronzoni could lead to misunderstandings.) Please insure that proofs and
        other dispatches are sent to the safer address! </tei:p>

      <tei:closer>
        <tei:salute rend="indent-70">With kind regards, </tei:salute>
        <tei:signed rend="indent-60">
          <tei:rs key="entity-000632" type="person">Dr. Heinrich Schenker</tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-07-02">July 2, 1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>

  </sdo:record>
