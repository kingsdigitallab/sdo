 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-008545">HeubergerR ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



   <dc:title>Handwritten postcard from Richard Heuberger to Schenker, dated November 9,
    1899</dc:title>

   <dcterms:created>1899-11-09T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-11-14</dcterms:dateSubmitted>
   <dc:description>Heuberger asks Schenker to defer his visit, and advises him on submission of
    compositions to the Tonkünstler-Verein.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000363">RHeuberger</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:fw type="header" rend="center"><tei:handShift new="#print"/><tei:hi rend="bold"
       >Correspondenz-Karte.</tei:hi></tei:fw><tei:lb/>
     <tei:address>
      <tei:addrLine><tei:supplied>An:</tei:supplied>
       <tei:handShift new="#RH"/>Herrn D<tei:hi rend="supralinear">r.</tei:hi> H.
       Schenker</tei:addrLine>
      <tei:addrLine rend="indent-20">Tonkünstler</tei:addrLine>
      <tei:addrLine rend="indent-60">Wien 3</tei:addrLine>
      <tei:addrLine>Richardgasse 11</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| WIEN 1/1 | f 1 | 9 11 99 | 11-12V ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| WIEN 3/3 | 49 | BESTELLT | 10 11. 99 | 9-10V ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| WIEN 3/2 | 45 | BESTELLT | 10.11.99 | 8 : V ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:dateline rend="indent-80"><tei:handShift new="#RH"/><tei:date when="1899-11-09">9/11
      99</tei:date></tei:dateline><tei:lb/>
    <tei:salute>Verehrtester <tei:rs type="person" key="entity-000632">D<tei:hi rend="supralinear"
       >r.</tei:hi></tei:rs></tei:salute>
   </tei:opener>


   <tei:p rend="first">Wäre Ihnen <tei:hi rend="underline">sehr</tei:hi> dankbar, wenn Sie erst in
    etwa 14 Tagen kommen würden, da ich sehr unwohl bin.<tei:note xml:id="r0001-fn01"
     type="editorial" place="foot">Schenker has evidently requested an opportunity to visit
     Heuberger, perhaps seeking to place an article or review in the <tei:rs type="journal"
      key="entity-002561"><tei:title level="j">Neues Wiener Tagblatt</tei:title></tei:rs>, of which
     Heuberger was then the Editor.</tei:note> Dann stehe ich zur Verfügung. Wegen Aufführung im
     <tei:rs type="organization" key="entity-003303">Tonkünstlerverein</tei:rs> bitte ich ein
    Exemplar der Stücke in den <tei:rs type="organization" key="entity-003303">Verein</tei:rs> zu
    schicken, da <tei:note type="editorial" place="inline">illegible word</tei:note> von 3 Herrn
    angesehen werden.<tei:note xml:id="r0001-fn02" type="editorial" place="foot">The pieces in
     question were compositions by Schenker, of which he had by this date seven published, and of
     which he was seeking public performances.</tei:note> Freue mich sehr, die Sachen kennen zu
    lernen.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">Ergebenster</tei:salute>
    <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000363">R
     Heuberger</tei:rs></tei:signed><tei:lb/>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:fw type="header" rend="center"><tei:handShift new="#print"/><tei:hi rend="bold"
       >Postcard</tei:hi></tei:fw><tei:lb/>
     <tei:address>
      <tei:addrLine><tei:supplied>To:</tei:supplied>
       <tei:handShift new="#RH"/>Dr. H. Schenker</tei:addrLine>
      <tei:addrLine rend="indent-20">Composer</tei:addrLine>
      <tei:addrLine rend="indent-60">Vienna III</tei:addrLine>
      <tei:addrLine>Richardgasse 11</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| VIENNA 1/1 | f 1 | 9 11 99 | 11-12V ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| VIENNA 3/3 | 49 | DELIVERED | 10 11. 99 | 9-10V ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| VIENNA 3/2 | 45 | DELIVERED | 10.11.99 | 8 : V ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:dateline rend="indent-80"><tei:handShift new="#RH"/><tei:date when="1899-11-09">November 9,
      1899</tei:date></tei:dateline><tei:lb/>
    <tei:salute>Most revered <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
       reason="identity">Schenker</tei:supplied></tei:rs></tei:salute>
   </tei:opener>


   <tei:p rend="first">I would be <tei:hi rend="underline">very</tei:hi> thankful if you would first
    come in about two weeks’ time because I am very unwell.<tei:ptr corresp="#r0001-fn01"
     type="footnote"/> Then I will be at your service. Regarding performance in the <tei:rs
     type="organization" key="entity-003303">Society of Musicians</tei:rs>, I ask that you send a
    copy of the pieces to the <tei:rs type="organization" key="entity-003303">Society</tei:rs>
    because <tei:unclear reason="origiinal_unclear">submissions</tei:unclear> are reviewed by three
     men.<tei:ptr corresp="#r0001-fn02" type="footnote"/> I am looking forward to getting to know
    your works.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-50">Most devoted</tei:salute>
    <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000363">R
     Heuberger</tei:rs></tei:signed><tei:lb/>
   </tei:closer>

  </tei:div>
 </sdo:record>
