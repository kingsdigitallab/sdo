  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Oppel to Schenker, dated November 21, 1929</dc:title>

      <dcterms:created>1929-11-21T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-25</dcterms:dateSubmitted>
      <dc:description>Oppel asks Schenker to remind Haas or Hoboken to send him a photographic
        reproduction of Brahms’s study of parallel fifths and octaves.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
            >Postkarte</tei:hi></tei:fw><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Wien III / Östreich</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"> || [LEIPZIG] | <tei:gap reason="illegible"/>
            | <tei:supplied reason="overstamped">MESS</tei:supplied>ESTADT ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1929-11-21">21. XI. 29</tei:date>.
          Mein lieber Herr <tei:rs type="person" key="entity-000632">Prof.
            Schenker</tei:rs>,<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this postcard is recorded in Schenker’s diary for November 22, 1929: “Von Oppel (K.):
            habe die Quinten-Studie noch nicht erhalten, sei erkältet” (“From Oppel (postcard): he
            has still not received the study of parallel fifths; he has a
          cold”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p>vielen Dank f. d. letzte Karte!<tei:note xml:id="r0001-fn02" type="editorial"
          place="foot">Schenker’s diary records the writing of a postcard card to Oppel on November
          11, but the summary of its contents is more appropriate for a message sent in the late
          spring: “An Oppel (K.): werde Brief u. Noten nach Galtür mitbringen, in Eile nur einiges
          Grundsätzliche” (“To Oppel (postcard): I shall bring letter and music to Galtür; in haste
          only a few fundamental points”).</tei:note> Br' Quintenstudie habe ich noch nicht
          erhalten.<tei:note xml:id="r0001-fn03" type="editorial" place="foot">Photograms of
          Brahms’s handwritten compilation of parallel octaves, fifths, and related progressions
          from the 16th to 19th centuries, of which Schenker published a facsimile edition in 1933,
            <tei:rs type="work" key="entity-003331"><tei:title level="m">Oktaven und Quinten u.
              A.</tei:title></tei:rs>.</tei:note> Es wäre mir ganz lieb, wenn Sie <tei:rs
          type="person" key="entity-000320">Prof Haas</tei:rs> oder <tei:rs type="person"
            key="entity-000380">A. von <tei:sic>Hobocken</tei:sic></tei:rs> nochmals daran erinnerten. </tei:p>

      <tei:p>Den <tei:rs type="person" key="entity-004801">Jungen</tei:rs> gehts gut. Ich selbst
        habe eine ziemliche Erkältung durch die überheizten Züge. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-30">Alles Gute u. die herzlichsten Grüsse</tei:salute>
        <tei:salute rend="indent-25">Ihnen beiden</tei:salute>
        <tei:salute rend="indent-30">Ihr tr</tei:salute>
        <tei:signed rend="indent-40"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
            >Postcard</tei:hi></tei:fw><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Vienna III, Austria</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"> || [LEIPZIG] | <tei:gap reason="illegible"/>
            | TRADE-FAIR CITY ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1929-11-21">November 21,
            1929</tei:date>. My dear <tei:rs type="person" key="entity-000632">Prof.
            Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>Many thanks for your last postcard!<tei:ptr corresp="#r0001-fn02" type="footnote"/> I have
        not yet received Brahms's study of parallel fifths.<tei:ptr corresp="#r0001-fn03"
          type="footnote"/> It would be very kind if you could remind <tei:rs type="person"
          key="entity-000320">Professor Haas</tei:rs> or <tei:rs type="person" key="entity-000380"
          >Anthony van Hoboken</tei:rs> once more about it.</tei:p>

      <tei:p>The <tei:rs type="person" key="entity-004801">boys</tei:rs> are doing well. I myself
        have a stubborn cold from the overheated trains.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-30">All the best and the most cordial greetings</tei:salute>
        <tei:salute rend="indent-25">to you both.</tei:salute>
        <tei:salute rend="indent-30">Your faithful</tei:salute>
        <tei:signed rend="indent-40"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>

