  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Breitkopf &amp; Härtel to Schenker, dated May 29,
        1912</dc:title>

      <dcterms:created>1912-05-29T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-22</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel have sent Schenker a volume containing Chopin's Piano
        Concerto Op. 11.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/>
        <tei:fw type="header" rend="left"><tei:note type="editorial" place="inline">prowling
            bear, with “<tei:handShift new="#pr"/>B &amp; H”</tei:note> <tei:hi rend="bold">Postkarte</tei:hi></tei:fw>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/>An: Herr<tei:handShift new="#BHsten"/>n <tei:hi
                rend="lateinschr">D<tei:hi rend="supralinear">r.</tei:hi> H. Schenker</tei:hi>
              Schenker</tei:addrLine>
            <tei:addrLine rend="indent-40"><tei:hi rend="lateinschr">Wien III,</tei:hi></tei:addrLine>
            <tei:addrLine rend="indent-40"><tei:hi rend="lateinschr">Reisnerstr. 38</tei:hi></tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG | 29. 5. 12 8–9N | * 13 * || <tei:note type="editorial"
              place="inline">four stamps</tei:note></tei:fw><tei:lb/><tei:lb/>
          
          <tei:milestone unit="folio" n="verso"/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/><tei:hi rend="underline">BREITKOPF &amp; HÄRTEL</tei:hi></tei:addrLine>
            <tei:addrLine rend="intend-50">LEIPZIG, DEN <tei:handShift new="#BHsten"/>29. Mai <tei:handShift new="#pr"
                />19<tei:handShift new="#BHsten"/>12.</tei:addrLine>
            <tei:addrLine><tei:handShift new="#pr"/>NÜRNBERGER STR. 36</tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute rend="indent-10"><tei:handShift new="#BHsten"/>Sehr geehrter <tei:rs type="person"
            key="entity-000632">Herr</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">In </tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten"/>Herrn <tei:hi rend="lateinschr"> D<tei:hi rend="supralinear">r.</tei:hi> H.
              Schenker</tei:hi>,</tei:addrLine>
          <tei:addrLine rend="indent-30"><tei:hi rend="lateinschr underline">Wien</tei:hi></tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/>
        <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
            >Postcard</tei:hi></tei:fw>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">To: </tei:supplied>
              <tei:handShift new="#pr"/>Mr. <tei:handShift new="#BHsten"/>H. Schenker</tei:addrLine>
            <tei:addrLine>currently at: <tei:rs type="place" key="entity-002279">St Anton</tei:rs>
                (<tei:rs type="place" key="entity-002334">Tirol</tei:rs>)</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG | -7. 8. 05. 9-10N. | * 13 * ||</tei:fw><tei:lb/><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
          <tei:address>
            <tei:addrLine><tei:note type="editorial" place="inline">device</tei:note>
              <tei:handShift new="#pr"/>Breitkopf &amp; Härtel</tei:addrLine>
            <tei:addrLine>Leipzig, <tei:handShift new="#BHsten"/>August 7, <tei:handShift new="#pr"
                />19<tei:handShift new="#BHsten"/>05</tei:addrLine>
            <tei:addrLine><tei:handShift new="#pr"/>Nürnberger Strasse 36</tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute><tei:handShift new="#BHsten"/>Dear <tei:rs type="person" key="entity-000632"
            >Sir</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">We have received your manuscript<tei:ptr corresp="#r0001-fn01"
          type="footnote"/> and will treat it with discretion and take great care of it. But we ask
        you to give us a little time for our deliberations – like you, many other people, too, are
        currently on their travels!</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Respectfully,</tei:salute>
        <tei:signed rend="indent-70">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten"/>Mr. H. Schenker</tei:addrLine>
          <tei:addrLine rend="indent-15">currently at: <tei:rs type="place" key="entity-002279">St.
              Anton</tei:rs></tei:addrLine>
          <tei:addrLine rend="indent-30">(<tei:rs type="place" key="entity-002334"
            >Tirol</tei:rs>)</tei:addrLine>
        </tei:address>
      </tei:closer>


    </tei:div>
  </sdo:record>
