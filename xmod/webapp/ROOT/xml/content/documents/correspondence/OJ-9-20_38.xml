  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Breitkopf &amp; Härtel to Schenker, dated May 29,
        1912</dc:title>

      <dcterms:created>1912-05-29T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-22</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel have sent Schenker a volume containing Chopin's Piano
        Concerto Op. 11.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/>
        <tei:fw type="header" rend="left"><tei:note type="editorial" place="inline">prowling bear,
            with “<tei:handShift new="#pr"/>B &amp; H”</tei:note>
          <tei:hi rend="bold">POSTKARTE</tei:hi></tei:fw>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/>An: Herr<tei:handShift new="#BHsten"/>n <tei:hi
                rend="lateinschr">D<tei:hi rend="supralinear">r.</tei:hi> H.
              Schenker</tei:hi></tei:addrLine>
            <tei:addrLine rend="indent-40"><tei:hi rend="lateinschr">Wien
              III,</tei:hi></tei:addrLine>
            <tei:addrLine rend="indent-40"><tei:hi rend="lateinschr">Reisnerstr.
              38</tei:hi></tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG | 29. 5. 12 8–9N | * 13 * || <tei:note type="editorial"
              place="inline">(four stamps)</tei:note></tei:fw><tei:lb/><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/><tei:hi rend="underline">BREITKOPF &amp;
                HÄRTEL</tei:hi></tei:addrLine>
            <tei:addrLine rend="intend-50">LEIPZIG, DEN <tei:handShift new="#BHsten"/>29. Mai
                <tei:handShift new="#pr"/>19<tei:handShift new="#BHsten"/>12.</tei:addrLine>
            <tei:addrLine><tei:handShift new="#pr"/>NÜRNBERGER STR. 36</tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute rend="indent-10"><tei:handShift new="#BHsten"/>Sehr geehrter <tei:rs
            type="person" key="entity-000632">Herr</tei:rs>,<tei:note xml:id="r0001-fn01"
            type="editorial" place="foot">Receipt of this postcard is not recorded in Schenker’s
            diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">In Beantwortung Ihrer gef. Zuschrift vom <tei:date when="1912-05-26">26.
          dss.</tei:date><tei:note xml:id="r0001-fn02" type="editorial" place="foot">Writing of this
          letter is not recorded in Schenker’s diary.</tei:note> teilen wir Ihnen ergebenst mit, daß
        das <tei:rs type="composition" key="entity-004878"><tei:hi rend="lateinschr">Chopinsche
            Klavierkonzert, op. 11</tei:hi></tei:rs>, in der Kritische u Gesamtausgabe einzelne
        nicht mehr zu haben ist. Wir haben Ihnen deshalb gestern der betr. Band, in dem dieses
        Konzert enthalten ist, gesandt, und zuvor unter Nachnahme des Betrags M. 21.75. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten"/>Herrn <tei:hi rend="lateinschr"> D<tei:hi
                rend="supralinear">r.</tei:hi> H. Schenker</tei:hi>,</tei:addrLine>
          <tei:addrLine rend="indent-30"><tei:hi rend="lateinschr underline"
            >Wien</tei:hi></tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/>
        <tei:fw type="header" rend="left"><tei:note type="editorial" place="inline">prowling bear,
            with “<tei:handShift new="#pr"/>B &amp; H”</tei:note>
          <tei:hi rend="bold">POSTCARD</tei:hi></tei:fw>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/>To: <tei:handShift new="#BHsten"/>Dr. H.
              Schenker</tei:addrLine>
            <tei:addrLine rend="indent-40">Vienna III</tei:addrLine>
            <tei:addrLine rend="indent-40">Reisnerstrasse 38</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG | 29. 5. 12 8–9N | * 13 * || <tei:note type="editorial"
              place="inline">(four stamps)</tei:note></tei:fw><tei:lb/><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/><tei:hi rend="underline">BREITKOPF &amp;
                HÄRTEL</tei:hi></tei:addrLine>
            <tei:addrLine rend="indent-50">LEIPZIG, <tei:handShift new="#BHsten"/>May 29,
                <tei:handShift new="#pr"/>19<tei:handShift new="#BHsten"/>12</tei:addrLine>
            <tei:addrLine><tei:handShift new="#pr"/>NÜRNBERGER STRASSE 36</tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute rend="indent-10"><tei:handShift new="#BHsten"/>Dear <tei:rs type="person"
            key="entity-000632">Sir</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"
          /></tei:salute>
      </tei:opener>

      <tei:p rend="first">In response to your kind letter of the <tei:date when="1912-05-26">26th of
          this month</tei:date>,<tei:ptr corresp="#r0001-fn02" type="footnote"/> we regret to inform
        you that <tei:rs type="composition" key="entity-004878">Chopin’s Piano Concerto, Op.
          11</tei:rs>, is no longer available as a separate volume in the critical and complete
        edition. Therefore, we have sent you the relevant volume containing this concerto yesterday,
        with the amount of 21.75 marks due upon delivery.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Respectfully,</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten"/>Dr. H. Schenker</tei:addrLine>
          <tei:addrLine rend="indent-30"><tei:hi rend="underline">Vienna</tei:hi></tei:addrLine>
        </tei:address>
      </tei:closer>


    </tei:div>
  </sdo:record>
