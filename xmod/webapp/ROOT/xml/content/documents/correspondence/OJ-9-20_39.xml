  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Handwritten letter from Breitkopf &amp; Härtel to Schenker, dated June 7,
        1913</dc:title>

      <dcterms:created>1913-06-07T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-23</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel will supply Schenker with a volume of the Bach
        Gesellschaft edition.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/><tei:hi rend="bold">BREITKOPF &amp; HÄRTEL -
              LEIPZIG</tei:hi></tei:addrLine>
          <tei:addrLine>BERLIN * LONDON * BRÜSSEL NEW YORK</tei:addrLine>
          <tei:addrLine rend="indent-60"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
            DEN <tei:handShift new="#BHsten"/><tei:date when="1913-06-07">7. Jun.
            1913</tei:date>.</tei:addrLine>
          <tei:addrLine rend="indent-60"><tei:handShift new="#pr"/>NÜRNBERGER STR. 36</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:byline><tei:note type="editorial" place="inline">initialled in top-left
            corner:</tei:note>
          <tei:handShift new="#BHsten"/>JB</tei:byline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Herrn Dr. Heinrich <tei:hi rend="lateinschr"
              >Schenker</tei:hi>.</tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:hi rend="lateinschr underline">Wien
            III.</tei:hi></tei:addrLine>
        </tei:address>
        <tei:salute rend="indent-30">Sehr geehrter <tei:rs type="person" key="entity-000632"
            >Herr</tei:rs>,<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this letter is not recorded in Schenker’s diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Im Besitze Ihrer freundlichen Zeilen vom <tei:date when="1913-06-05">5. d.
          M.</tei:date><tei:note xml:id="r0001-fn02" type="editorial" place="foot">Writing of
          Schenker’s letter is not recorded in Schenker’s diary.</tei:note> sind wir gern bereit,
        Ihrem Wunsche bezüglich Lieferung des <tei:rs type="composition" key="entity-002952"
            >„<tei:hi rend="lateinschr"><tei:title>Wohltemperierten
          Klaviers</tei:title></tei:hi>“</tei:rs> von <tei:rs type="person" key="entity-000027"
            ><tei:hi rend="lateinschr">Bach</tei:hi></tei:rs> in der Ausgabe der alten
        Bachgesellschaft zu entsprechen. Wir lassen Ihnen den Band (14. Jahrgang) durch Vermittelung
        der <tei:rs type="organization" key="entity-002456">Musikalienhandlung <tei:hi
            rend="lateinschr">Gutmann</tei:hi></tei:rs> In <tei:hi rend="lateinschr">Wien</tei:hi>
        zum Subskriptionspreise von M. 15.– zugehen. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Hochachtungsvoll ergeben</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/><tei:hi rend="bold">BREITKOPF &amp; HÄRTEL -
              LEIPZIG</tei:hi></tei:addrLine>
          <tei:addrLine>BERLIN * LONDON * BRUSSELS NEW YORK</tei:addrLine>
          <tei:addrLine rend="indent-60"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
              <tei:handShift new="#BHsten"/><tei:date when="1913-06-07">June 7,
            1913</tei:date></tei:addrLine>
          <tei:addrLine rend="indent-60"><tei:handShift new="#pr"/>NÜRNBERGER STRASSE
            36</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:byline><tei:note type="editorial" place="inline">initialled in top-left
            corner:</tei:note>
          <tei:handShift new="#BHsten"/>JB</tei:byline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Dr. Heinrich Schenker</tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:hi rend="underline">Vienna III</tei:hi></tei:addrLine>
        </tei:address>
        <tei:salute rend="indent-30">Dear <tei:rs type="person" key="entity-000632"
            >Sir</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">In receipt of your kind letter from the <tei:date when="1913-06-05">5th of
          this month</tei:date>,<tei:ptr corresp="#r0001-fn02" type="footnote"/> we are pleased to
        comply with your request regarding the delivery of <tei:rs type="person" key="entity-000027"
          >Bach</tei:rs>’s <tei:rs type="composition" key="entity-002952"><tei:title level="m"
            >Well-Tempered Clavier</tei:title></tei:rs> in the edition of the old Bach Gesellschaft.
        We will have the volume (14th Year) sent to you through the <tei:rs type="organization"
          key="entity-002456">music shop Gutmann</tei:rs> in Vienna at the subscription price of 15
        marks.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Respectfully, <tei:supplied>your</tei:supplied>
          devoted</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed>
      </tei:closer>


    </tei:div>
  </sdo:record>
