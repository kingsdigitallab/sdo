  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Oppel to Schenker, dated August 8, 1929</dc:title>

      <dcterms:created>1929-08-08T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-22</dcterms:dateSubmitted>
      <dc:description>Oppel and his sons have arrived safely at their home in Kiel.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-003957">Walter Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-000644">Ulrich Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >Postkarte</tei:hi></tei:fw><tei:lb/>
          <tei:fw type="envelope">
            <tei:address>
              <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof.
                  D<tei:hi rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:addrLine>
              <tei:addrLine>Galtür / Paznaun</tei:addrLine>
              <tei:addrLine>Tirol / Östr</tei:addrLine>
              <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark"> || <tei:supplied>KIE</tei:supplied>L | <tei:gap
                reason="illegible"/> | * 1 * ||</tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:salute><tei:handShift new="#RO"/><tei:date when="1929-08-08">8 VIII. <tei:hi
                rend="supralinear">29</tei:hi></tei:date>. Lieber <tei:rs type="person"
              key="entity-000632">Herr</tei:rs> u. <tei:rs type="person" key="entity-000771"
              >Frau</tei:rs> Professor Schenker,<tei:note xml:id="r0001-fn01" type="editorial"
              place="foot">Receipt of this postcard is recorded in Schenker’s diary for August 10,
              1929: “Von Oppel (K.): Gruß aus Kiel, Ankündigung eines Briefes” (“From Oppel
              (postcard): greetings from Kiel, promise of a forthcoming
            letter”).</tei:note></tei:salute>
        </tei:opener>

        <tei:p>heute früh 10<tei:hi rend="supralinear">55</tei:hi> sind wir pünktlich in <tei:rs
            type="place" key="entity-002757">Kiel</tei:rs> gelandet. Friedrichshafen war leider
          nichts, alles war zu u. <tei:hi rend="underline">nicht</tei:hi> zu besichtigen,
          Zeppelinwerft, Maybach motorwerke etc. Wir blieben uns am herrlichen Bodensee
            <tei:milestone unit="folio" n="verso"/> herum, u. fuhren abds noch n. <tei:rs
            type="place" key="entity-002683">Ulm</tei:rs>, das den gestern Vormittag ausfüllten;
          mittags um 3 fuhren wir dann ab. </tei:p>

        <tei:p>Hoffentlich haben Sie noch schöne Tage, dass die Tour auf die <tei:rs type="place"
            key="entity-004235">Wiesb. Hütte</tei:rs> gelingt. Und hoffentlich sind auch alle
          Magenstörungen beseitigt u. die Wetterhexe Olivia brav.<tei:note xml:id="r0001-fn02"
            type="editorial" place="foot">“stomach ailments”: Jeanette Schenker was suffering from
            stomach cramps on July 27; “Olivia”: a storm that affected Galtür from August 1 to 4, as
            recorded in Schenker‘s diary. The Oppels had been visiting the Schenkers in Galtür from
            July 27 to August 5.</tei:note> Wir warten noch auf <tei:rs type="person"
            key="entity-008510">Hans Reinhard</tei:rs>, so dass zum Abendessen der
          Junggesellenverein wieder vollzählig beisammen ist. Es liegt ein Unmenge Post vor, die
          mich heute Nacht beschäftigen wird. Grüssen Sie <tei:rs type="person" key="entity-000922"
            >Vrieslander</tei:rs> recht herzlich von mir wenn er kommt. Brief folgt dieser Tage. </tei:p>

        <tei:closer>
          <tei:salute>Mit den herzlichsten Grüssen </tei:salute>
          <tei:salute>Ihnen beiden u. alles Gute</tei:salute>
          <tei:salute>Ihr treuer</tei:salute>
          <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000643">Reinhard
              Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_2">
        <tei:opener>
          <tei:salute><tei:handShift new="#WO"/>Liebe <tei:rs type="person" key="entity-000771"
              >Frau</tei:rs>, lieber <tei:rs type="person" key="entity-000632">Herr
              Professor</tei:rs>!</tei:salute>
        </tei:opener>
        <tei:p>Nun sind wir wieder hier in <tei:rs type="place" key="entity-002757">Kiel</tei:rs>.
          Nachher wollen wir uns gleich ins Wasser stürzen … </tei:p>
        <tei:closer>
          <tei:salute>Herzliche Grüße Ihr </tei:salute>
          <tei:signed><tei:rs type="person" key="entity-003957">Walter Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_3">
        <tei:opener/>
        <tei:p><tei:handShift new="#UO"/>Glatt gelandet! „An Bord alles wohl!“</tei:p>
        <tei:salute>Herzliche Grüsse sendet Ihnen</tei:salute>
        <tei:signed><tei:supplied reason="cut off"><tei:rs type="person" key="entity-000644">Ulrich
              Oppel</tei:rs></tei:supplied></tei:signed>
      </tei:div>

    </tei:div>


    <tei:div type="translation">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >Postcard</tei:hi></tei:fw><tei:lb/>
          <tei:fw type="envelope">
            <tei:address>
              <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof.
                Heinrich Schenker</tei:addrLine>
              <tei:addrLine>Galtür, Paznaun</tei:addrLine>
              <tei:addrLine>Tyrol, Austria</tei:addrLine>
              <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark"> || <tei:supplied>KIE</tei:supplied>L | <tei:gap
                reason="illegible"/> | * 1 * ||</tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:salute><tei:handShift new="#RO"/><tei:date when="1929-08-08">August 8,
              1929.</tei:date> Dear <tei:rs type="person" key="entity-000632">Professor</tei:rs> and
              <tei:rs type="person" key="entity-000771">Mrs.</tei:rs> Schenker,<tei:ptr
              corresp="#r0001-fn01" type="footnote"/></tei:salute>
        </tei:opener>

        <tei:p>We arrived in <tei:rs type="place" key="entity-002757">Kiel</tei:rs> punctually at
          10:55 this morning. There was unfortunately nothing in Friedrichshafen, everything was
          closed and <tei:hi rend="underline">not</tei:hi> open to visitors: the Zeppelin shipyard,
          the Maybach motor works, etc. We stayed around the splendid Lake Constance <tei:milestone
            unit="folio" n="verso"/> and then travelled in the evening to <tei:rs type="place"
            key="entity-002683">Ulm</tei:rs>; we left there at 3 o’clock.</tei:p>

        <tei:p> I hope that you are still enjoying beautiful days, and that the tour to the <tei:rs
            type="place" key="entity-004235">Wiesbaden Mountain Hut</tei:rs> is successful. And I
          hope that all your stomach ailments have settled and that Olivia, the weather witch,
            behaves.<tei:ptr corresp="#r0001-fn02" type="footnote"/> We are still waiting for
            <tei:rs type="person" key="entity-008510">Hans Reinhard</tei:rs>, so that the full
          complement of the youth club will again be together for supper. I have a huge pile of
          mail, which will occupy me tonight. If <tei:rs type="person" key="entity-000922"
            >Vrieslander</tei:rs> comes, please give him my very cordial greetings. A letter will
          follow in the coming days. </tei:p>

        <tei:closer>
          <tei:salute>With the most cordial greetings </tei:salute>
          <tei:salute>to the two of you, and all good wishes, </tei:salute>
          <tei:salute>Your faithful</tei:salute>
          <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000643">Reinhard
              Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_2">
        <tei:opener>
          <tei:salute><tei:handShift new="#WO"/>Dear <tei:rs type="person" key="entity-000771"
              >Mrs.</tei:rs>, <tei:supplied reason="identity">Schenker</tei:supplied>, dear <tei:rs
              type="person" key="entity-000632">Professor</tei:rs>,</tei:salute>
        </tei:opener>
        <tei:p>We are again here in <tei:rs type="place" key="entity-002757">Kiel</tei:rs>.
          Afterwards, we would like to jump into the water immediately …</tei:p>
        <tei:closer>
          <tei:salute>Cordial greetings, your </tei:salute>
          <tei:signed><tei:rs type="person" key="entity-003957">Walter Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_3">
        <tei:opener/>
        <tei:p><tei:handShift new="#UO"/>Safely landed! “All’s well aboard!” </tei:p>
        <tei:salute>Cordial greetings to you from</tei:salute>
        <tei:signed><tei:supplied reason="cut off"><tei:rs type="person" key="entity-000644">Ulrich
              Oppel</tei:rs></tei:supplied></tei:signed>
      </tei:div>

    </tei:div>

