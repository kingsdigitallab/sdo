   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



   <dc:title>Handwritten letter from Brüll to Schenker, dated November 6, [1898?]</dc:title>

   <dcterms:created>1898-11-06T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-08-05</dcterms:dateSubmitted>
   <dc:description>Ignaz Brüll likens Schenker's Fantasie, Op. 2 to late Beethoven.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000105">BrüllI</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:salute><tei:handShift new="#IB"/>Verehrter Herr <tei:rs type="person" key="entity-000632"
      >Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">This letter is
      published in English in <tei:bibl><tei:editor>Bent, Ian</tei:editor>, <tei:editor>David
        Bretherton</tei:editor> and <tei:editor>William Drabkin</tei:editor>, eds, <tei:title
        level="m">Heinrich Schenker: Selected Correspondence</tei:title> (Woodbridge: Boydell Press,
       2014), p. 25</tei:bibl>.</tei:note></tei:salute>
   </tei:opener>

   <tei:p>Ich bin Ihnen für Ihre freundliche Zusendung sehr verbunden. Ihre
     „<tei:title>Fantasie</tei:title>“<tei:note xml:id="r0001-fn02" type="editorial" place="foot"
     >Schenker’s <tei:title level="m">Fantasie</tei:title>, Op. 2 (Leipzig: Breitkopf &amp; Härtel,
     1898), dedicated to <tei:rs type="person" key="entity-000116">Ferruccio
     Busoni</tei:rs>.</tei:note> führt mit Recht den Namen: Es ist Fantasie darin. Fantasie, <tei:hi
     rend="underline">große</tei:hi> Gedanken, eine zuweilen an letzten <tei:rs type="person"
     key="entity-000055"><tei:hi rend="lateinschr">Beethoven</tei:hi></tei:rs> mahnende
    Ausgestaltung, als wollten Sie an ihn anknüpfen, um weiter zu bauen ‒ auch „Sturm und Drang“ ist
    drin. Mit großem Vergnügen habe ich auch meine Bekanntschaft mit den kleineren Stücken, die Sie
    meinem <tei:rs type="person" key="entity-008520">Bruder</tei:rs> gaben, wieder erneuert. In das
    G-dur Stück bin ich beinahe verliebt. </tei:p>

   <tei:closer>
    <tei:salute>Herzlichste Grüße, verehrter Herr <tei:rs type="person" key="entity-000105"
      >Doktor</tei:rs>,</tei:salute>
    <tei:salute rend="indent-40">von Ihrem ganz ergebenen </tei:salute>
    <tei:signed rend="indent-70">
     <tei:rs type="person" key="entity-000105">Ignaz Brüll</tei:rs>
    </tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1898-06-11">6/11</tei:date></tei:dateline>
   </tei:closer>


  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:salute><tei:handShift new="#IB"/>Revered <tei:rs type="person" key="entity-000632">Dr.
       <tei:supplied reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr
      corresp="#r0001-fn01" type="footnote"/></tei:salute>
   </tei:opener>

   <tei:p>I am indebted to you for what you so kindly sent me. Your <tei:title level="m"
     >Fantasy</tei:title><tei:ptr corresp="#r0001-fn02" type="footnote"/> is aptly named: it is
    imbued with fantasy. Fantasy, <tei:hi rend="underline">big</tei:hi> ideas, an organization that
    occasionally evokes late <tei:rs type="person" key="entity-000055">Beethoven</tei:rs>, as if you
    were wanting to connect to him in order to build on to him – also it has an element of Sturm und
    Drang. I was also pleased to renew my acquaintance with the shorter pieces that you gave my
     <tei:rs type="person" key="entity-008520">brother</tei:rs>. I am quite besotted with the G
    major piece.</tei:p>

   <tei:closer>
    <tei:salute>Most cordial greetings, revered <tei:rs type="person" key="entity-000105">Dr.
       <tei:supplied>Schenker</tei:supplied></tei:rs>,</tei:salute>
    <tei:salute rend="indent-40">from your most devoted </tei:salute>
    <tei:signed rend="indent-70">
     <tei:rs type="person" key="entity-000105">Ignaz Brüll</tei:rs>
    </tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1898-06-11">November 6</tei:date></tei:dateline>
   </tei:closer>

  </tei:div>
 </sdo:record>
