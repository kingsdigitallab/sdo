      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated January 23, 1913</dc:title>

      <dcterms:created>1913-01-23T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-20</dcterms:dateSubmitted>
      <dc:description>Hertzka is eager to see Schenker's manuscript [of the elucidatory edition of
        Beethoven's sonata Op. 109], and wishes to be present when it is delivered.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-01-23">23. Jänner 1913</tei:date>.</tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Wohlgeboren Herrn Prof. Dr. <tei:persName>Heinrich
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:rs type="place" key="entity-002484"><tei:hi
                rend="underline">Wien</tei:hi></tei:rs></tei:addrLine>
        </tei:address>
        <tei:salute>Sehr geehrter Herr <tei:rs key="entity-000632" type="person"
            >Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this letter is not recorded in Schenker’s diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Dem mir angekündigten Manuskript<tei:note xml:id="r0001-fn02"
          type="editorial" place="foot">Schenker's musical text and critical commentary of his
          elucidatory edition, <tei:rs type="work" key="entity-001734"><tei:title level="m">Die
              letzten fünf Sonaten von Beethoven … Op. 109</tei:title></tei:rs> (Vienna: UE, 1913).
        </tei:note> sehe ich mit <tei:hi rend="underline">grossem</tei:hi> Interesse entgegen, bitte
        Sie aber, mir vorher die Stunde Ihres gesch. Besuches (da ich ja hoffe, dass Sie mir diese
        wertvolle Arbeit selbst überbringen), vorher bekanntzugeben, damit ich auch sicher anwesend
        bin. </tei:p>

      <tei:p rend="first">Ich bin voraussichtlich Dienstag und Mittwoch in Wien abwesend, die
        übrigen Tage der nächsten Woche jedoch regelmässig anzutreffen.<tei:note xml:id="r0001-fn03"
          type="editorial" place="foot">January 23 was a Thursday; Hertzka is thus saying that he is
          unavailable on Tuesday–Wednesday, January 28–29, and available the rest of that week.
        </tei:note></tei:p>

      <tei:closer>
        <tei:salute rend="indent-20">Mit besten Grüssen</tei:salute>
        <tei:salute rend="indent-60">Ihr in Hochschätzung</tei:salute>
        <tei:salute rend="indent-70">ergebener</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Josef Aibl Publishers &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-01-23">January 23, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Professor <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:rs type="place" key="entity-002484"><tei:hi
                rend="underline">Vienna</tei:hi></tei:rs></tei:addrLine>
        </tei:address>
        <tei:salute>Dear <tei:rs key="entity-000632" type="person">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
            type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">I look forward with <tei:hi rend="underline">great</tei:hi> interest to
        the manuscript<tei:ptr corresp="#r0001-fn02" type="footnote"/> of which you notify me.
        Please, however, let me know in advance the time of your esteemed visit (since I very much
        hope that you will bring this valued work in person), so that I can be sure of being
        present.</tei:p>

      <tei:p rend="first">I will probably be away from Vienna on Tuesday and Wednesday, but
        available as normal on the remaining days of next week<tei:ptr corresp="#r0001-fn03"
          type="footnote"/></tei:p>

      <tei:closer>
        <tei:salute rend="indent-20">With best greetings</tei:salute>
        <tei:salute rend="indent-60">and kind regards,</tei:salute>
        <tei:salute rend="indent-70">Your devoted</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>




    </tei:div>
