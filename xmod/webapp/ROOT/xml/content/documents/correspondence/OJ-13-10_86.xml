  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated September 7,
        1929</dc:title>

      <dcterms:created>1929-09-07T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-24</dcterms:dateSubmitted>
      <dc:description>Oppel sends greetings from Weimar.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: statue of two men on plinth, captioned:
          “Goethe- u. Schiller-Denkmal am Nationaltheater”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#RO"/>Östreich!</tei:addrLine>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Wien III</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| WEIMAR | 8 9 29 | 15-16 | * 1 * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1929-09-07">Sonntag, 7. IX
            29</tei:date>. Mein l. Herr <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this postcard is recorded in Schenker’s diary for September 9, 1929: “Von Oppel
            (Ansichtsk. aus Weimar): unterwegs nach Leipzig” (“From Oppel (picture postcard from
            Weimar): on the way to Leipzig”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p><tei:rs type="place" key="entity-002886">Weimar</tei:rs> ist ein liebliches Nest,
          <tei:note type="editorial" place="inline">several illegible words</tei:note>. Die Museen –
        das Goethehaus ausgenommen – nicht viel wert. Leider fängt auch hier das Wetter an, recht
        herbstlich zu werden. Morgen beginnt der Tanz in <tei:rs type="place" key="entity-002479"
          >Leipzig</tei:rs>. </tei:p>

      <tei:closer>
        <tei:salute>Alles Gute u. die</tei:salute>
        <tei:salute>herzlichste Grüße Ihnen beiden </tei:salute>
        <tei:salute rend="indent-20">Ihr treuer</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: statue of two men on plinth, captioned:
          “Goethe and Schiller Monument at the National Theater”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#RO"/>Austria!</tei:addrLine>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Vienna III</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| WEIMAR | 8 9 29 | 15-16 | * 1 * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1929-09-07">Sunday, September 7,
            1929</tei:date>. My dear <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p><tei:rs type="place" key="entity-002886">Weimar</tei:rs> is a lovely little place
          <tei:note type="editorial" place="inline">several illegible words</tei:note>. The museums,
        apart from Goethe’s House, are not of much interest. Unfortunately, the weather is beginning
        to become quite autumnal even here. Tomorrow the dance in <tei:rs type="place"
          key="entity-002479">Leipzig</tei:rs> begins.</tei:p>

      <tei:closer>
        <tei:salute>All good wishes and the most </tei:salute>
        <tei:salute>cordial greetings to the two of you.</tei:salute>
        <tei:salute rend="indent-20">Your faithful</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
