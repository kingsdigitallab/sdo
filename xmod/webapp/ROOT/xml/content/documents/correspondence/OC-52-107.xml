      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated February 3, 1913</dc:title>

      <dcterms:created>1913-02-03T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-20</dcterms:dateSubmitted>
      <dc:description>Hertzka is now not available and asks Schenker for another delivery date/time
        [of the MS of his elucidatory edition of Beethoven sonata Op. 109].</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 8</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-02-03">3. February 1913</tei:date>.</tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Wohlgeboren Herrn Prof. Dr. <tei:persName>Heinrich
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:rs type="place" key="entity-002484"><tei:hi
                rend="underline">Wien</tei:hi></tei:rs></tei:addrLine>
        </tei:address>
        <tei:salute>Sehr geehrter Herr <tei:rs key="entity-000632" type="person"
            >Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this letter is not recorded in Schenker’s diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Die Stunde <tei:date when="1913-02-04">Dienstag</tei:date> von 4–5 Uhr
          nachmittags<tei:note xml:id="r0001-fn02" type="editorial" place="foot">Tuesday February 4,
          as proposed in Schenker's postcard, <tei:ref type="correspondence" cRef="WSLB-145">WSLB
            145</tei:ref>, February 2, 1913. Schenker’s diary shows that the meeting took place on
          Wednesday February 5: “Uebergabe des Manuscriptes.” (“Delivery of the
          manuscript.”).</tei:note> habe ich leider nicht mehr frei, denn ich habe mich schon vor
        einigen Tagen zu einer wichtigen Konferenz gerade zu dieser Zeit vergeben und kann diese
        nicht absagen. Vielleicht finden Sie eine andere halbe Stunde für mich Zeit. Ich glaube,
        dass ich sonst bis <tei:date when="1913-02-06">Donnerstag</tei:date> abends keine fixe
        Abhaltung mehr haben werde. <tei:date when="1913-02-06">Donnerstag</tei:date> abends reise
        ich nach <tei:rs type="place" key="entity-002479">Leipzig</tei:rs> und komme erst anfangs
        der nächsten Woche wieder zurück. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-20">Mit besten Empfehlungen</tei:salute>
        <tei:salute rend="indent-70">hochachtungsvoll</tei:salute>
        <tei:salute rend="indent-80">ergeben</tei:salute>
        <tei:signed><tei:handShift new="#stamp"/><tei:rs type="organization" key="entity-002408"
            >Universal-Edition</tei:rs> Aktienges.</tei:signed>
        <tei:signed rend="indent-90"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Josef Aibl Publishers &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 8</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-02-03">February 3, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Professor <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:rs type="place" key="entity-002484"><tei:hi
                rend="underline">Vienna</tei:hi></tei:rs></tei:addrLine>
        </tei:address>
        <tei:salute>Dear <tei:rs key="entity-000632" type="person">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
            type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">Unfortunately, I no longer have <tei:date when="1913-02-04"
          >Tuesday</tei:date> 4–5 p.m. free,<tei:ptr corresp="#r0001-fn02" type="footnote"/> because
        several days ago I committed myself to an important meeting at exactly this time, and cannot
        cancel it. Perhaps you can find another half-hour for me. I believe I have no other fixed
        engagement up to <tei:date when="1913-02-06">Thursday</tei:date> evening. I travel to
          <tei:rs type="place" key="entity-002479">Leipzig</tei:rs> on <tei:date when="1913-02-06"
          >Thursday</tei:date> evening, and do not get back until the beginning of next week. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-20">I remain</tei:salute>
        <tei:salute rend="indent-70">with kind regards,</tei:salute>
        <tei:salute rend="indent-80">Your devoted</tei:salute>
        <tei:signed><tei:handShift new="#stamp"/><tei:rs type="organization" key="entity-002408"
            >Universal Edition</tei:rs> &amp; Co.</tei:signed>
        <tei:signed rend="indent-90"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>




    </tei:div>
