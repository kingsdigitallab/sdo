  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



      <dc:title>Handwritten postcard from Schenker to Hertzka (UE), dated April 19, 1913</dc:title>

      <dcterms:created>1913-04-19T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-17</dcterms:dateSubmitted>
      <dc:description>Schenker declares that reviews do not interest him.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000632">Heinrich Schenker</marcrel:correspondent>
      <marcrel:recipient key="entity-000356">Emil Hertzka</marcrel:recipient>
      <marcrel:recipient key="entity-002408">Universal Edition</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">Absender:</tei:supplied>
              <tei:handShift new="#HS"/><tei:hi rend="lateinschr">H Schenker</tei:hi>
            </tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">III, Reisnerstr. 38</tei:hi></tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">An:</tei:supplied> H <tei:hi
                rend="lateinschr">Direktor Em. Hertzka</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">I, Reichsrathsstr.</tei:hi> 9</tei:addrLine>
            <tei:addrLine>„<tei:hi rend="lateinschr">Universal-Edition</tei:hi>“</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| 3/3 WIEN 19 | 19.IV.13 XI<tei:hi rend="supralinear">2</tei:hi>
            | * 3a * ||</tei:fw>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>Sehr geehrter Herr <tei:rs key="entity-000356"
            type="person">Direktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Writing of this postcard is not recorded in Schenker's diary.
          </tei:note></tei:salute>
      </tei:opener>

      <tei:p>Ihrem gesch. Schreiben von heute<tei:note xml:id="r0001-fn02" type="editorial"
          place="foot">= <tei:ref type="correspondence" cRef="OC-52-114">OC 52/114</tei:ref>, April
          18, 1913. The review in question was by <tei:rs type="person" key="entity-003839">Wouter
            Hutschenruyter</tei:rs> of Utrecht in the Dutch journal <tei:rs type="journal"
            key="entity-005681"><tei:title level="j">Cäcilia</tei:title></tei:rs> about Schenker’s
            <tei:rs type="work" key="entity-001731"><tei:title level="m">Beethovens Neunte
              Sinfonie</tei:title></tei:rs>, a German translation of which is preserved in
          Schenker's scrapbook at OC 2/pp. 31–36.</tei:note> liegen aber die „2 Blätter“ <tei:hi
          rend="underline">nicht</tei:hi> bei, so daß ich nichts „retour“ zu senden haben. Es ist
        indessen gut so. Mich interessieren <tei:hi rend="underline">prinzipiell</tei:hi> Kritiken
          <tei:hi rend="underline">nicht</tei:hi>. Wenn der „Kritiker“ <tei:hi rend="underline"
          >meine</tei:hi> Arbeit gemacht hätte, diesen würde ich gerne lesen, aber ..! </tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Ihr ergebener</tei:salute>
        <tei:signed rend="indent-50">
          <tei:rs key="entity-000632" type="person"><tei:hi rend="lateinschr">H
            Sch</tei:hi></tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-04-19">19. 4. 1913</tei:date></tei:dateline>
      </tei:closer>

      <tei:postscript>
        <tei:p>NB H. <tei:rs type="person" key="entity-000800">Schrader</tei:rs> sandte mir seine
          Zeilen <tei:hi rend="underline">persönlich</tei:hi> zu; da muß ich <tei:note
            type="editorial" place="inline">sentence left incomplete</tei:note>
        </tei:p>
      </tei:postscript>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">From:</tei:supplied>
              <tei:handShift new="#HS"/>H. Schenker </tei:addrLine>
            <tei:addrLine><tei:supplied reason="identity">Vienna</tei:supplied> III, Reisnerstraße
              38</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">To:</tei:supplied>Director Emil
              Hertzka</tei:addrLine>
            <tei:addrLine><tei:supplied reason="identity">Vienna</tei:supplied> I, Reichsrathsstraße
              9</tei:addrLine>
            <tei:addrLine>Universal Edition</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| 3/3 VIENNA 19 | 19.IV.13 XI<tei:hi rend="supralinear"
              >2</tei:hi> | * 3a * ||</tei:fw>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>Dear <tei:rs key="entity-000356" type="person"
            >Director</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>But the "two leaves" are <tei:hi rend="underline">not</tei:hi> enclosed with your
        esteemed letter of today,<tei:ptr corresp="#r0001-fn02" type="footnote"/> so that I have
        nothing to "return." However, it is good so. <tei:hi rend="underline">As a matter of
          principle</tei:hi>, reviews do <tei:hi rend="underline">not</tei:hi> interest me. If the
        "critic" had done <tei:hi rend="underline">my</tei:hi> work, this I would gladly read, but
        ..!</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Your devoted</tei:salute>
        <tei:signed rend="indent-50">
          <tei:rs key="entity-000632" type="person">H. Schenker</tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-04-19">April 19, 1913</tei:date></tei:dateline>
      </tei:closer>

      <tei:postscript>
        <tei:p>N. B. Mr. <tei:rs type="person" key="entity-000800">Schrader</tei:rs> sent me his
          missive <tei:hi rend="underline">in person</tei:hi>, so I must <tei:note type="editorial"
            place="inline">sentence left incomplete</tei:note></tei:p>
      </tei:postscript>

    </tei:div>

