  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated July 11, 1913</dc:title>

      <dcterms:created>1913-07-11T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2026-03-11</dcterms:dateSubmitted>
      <dc:description>UE is sending the proofs of the wrapper and title-page of the Op. 109 edition
        for correction. -- It has chosen a series title for all five sonatas.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#stamp"/>V. A1 <tei:handShift new="#TPueGP"/>GP</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#pr"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPueGP"/><tei:date
            when="1913-07-11">11. Juli 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Wohlgeboren Herrn Prof. <tei:persName>Heinrich
              Schenker</tei:persName>,</tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:placeName><tei:hi rend="underline"
              >Fondo</tei:hi></tei:placeName>.</tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueGP"/>Sehr geehrter Herr <tei:rs key="entity-000632"
            type="person">Professor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Receipt of this letter is recorded in Schenker’s diary for July 13, 1913:
            “Von Hertzka die angekündigten Titelblätter betreffend das gesamte Werk, mit Anfrage.”
            (“[Letter] from Hertzka: the announced title-pages, concerning the entire work, with a
            question.”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Wir senden Ihnen gleichzeitig Korrektur-Abzug vom Umschlag und Innentitel
        zur <tei:rs type="work" key="entity-001734">Beethoven Sonate</tei:rs> und bitten Sie, uns
        mitzuteilen, ob Sie mit dieser Fassung einverstanden sind. Der Einfachheit halber haben wir
        für <tei:rs type="work" key="entity-001733">alle 5 Sonaten</tei:rs> einen Kollektivtitel
        gewählt. Der Umschlag wird natürlich für jede Sonate entsprechend geändert. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-30">Wir empfehlen uns</tei:salute>
        <tei:salute rend="indent-70">hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-65"><tei:handShift new="#stamp"/><tei:rs type="organization"
            key="entity-002408">„Universal-Edition“ Actiengesellschaft</tei:rs></tei:signed>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
        <tei:add><tei:note type="editorial" place="inline">initialled bottom
            left:</tei:note><tei:handShift new="UEunk"/>U</tei:add>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#pr"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#stamp"/>V. A1 <tei:handShift new="#TPueGP"/>GP</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#pr"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPueGP"/><tei:date
            when="1913-07-11">July 11, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Prof. <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:placeName><tei:hi rend="underline"
              >Fondo</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueGP"/>Dear <tei:rs key="entity-000632" type="person"
            >Professor</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">We are sending you by the same post the proof of the outer cover and
        inside title-page of the <tei:rs type="work" key="entity-001734">Beethoven
        sonata</tei:rs>, and ask you to inform us whether you are happy with this version. In the
        interests of simplicity, we have opted for a collective title for <tei:rs type="work"
          key="entity-001733">all five sonatas</tei:rs>. The outer cover will of course be modified
        in accordance with each sonata.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-30">We remain,</tei:salute>
        <tei:salute rend="indent-70">Respectfully your,</tei:salute>
        <tei:signed rend="indent-65"><tei:handShift new="#stamp"/><tei:rs type="organization"
            key="entity-002408">Universal Edition &amp; Co.</tei:rs></tei:signed>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
        <tei:add><tei:note type="editorial" place="inline">initialled bottom
            left:</tei:note><tei:handShift new="UEunk"/>U</tei:add>
      </tei:closer>

    </tei:div>
