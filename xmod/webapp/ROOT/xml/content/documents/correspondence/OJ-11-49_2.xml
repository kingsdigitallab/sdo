   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



   <dc:title>Handwritten postcard from Richard Heuberger to Schenker, dated June 12, 1902</dc:title>

   <dcterms:created>1902-06-12T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-11-14</dcterms:dateSubmitted>
   <dc:description>Heuberger thanks Schenker and hopes for something better.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000363">RHeuberger</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:fw type="header" rend="center"><tei:handShift new="#print"/><tei:hi rend="bold"
       >Correspondenz-Karte.</tei:hi></tei:fw><tei:lb/>
     <tei:address>
      <tei:addrLine><tei:supplied>An:</tei:supplied>
       <tei:handShift new="#RH"/>Herrn D<tei:hi rend="supralinear">r.</tei:hi> Heinrich
       Schenker</tei:addrLine>
      <tei:addrLine rend="indent-20">Tonkünstler</tei:addrLine>
      <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002394"><tei:handShift new="#unk"/><tei:hi
         rend="lateinschr">Baden</tei:hi>
        <tei:add place="interlinear-above">bei</tei:add>
       <tei:handShift new="#RH"/><tei:hi rend="lateinschr">Wien</tei:hi></tei:rs> <tei:del rend="overstrike">3</tei:del></tei:addrLine>
      <tei:addrLine><tei:subst>
        <tei:del rend="overstrike">Richardgasse 11</tei:del>
        <tei:add place="inline"><tei:handShift new="#unk"/>Johannesg 6</tei:add>
       </tei:subst></tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| WIEN 1/1 | a 1 | 12 6 02 | 9-10V ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| WIEN 3/3 | 49 | BESTELLT | 12. 6. 02 | 1-3N ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| BADEN 1 | N.O. | BESTELLT | 12. 6. 02 | 7-9N ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute><tei:handShift new="#RH"/><tei:rs type="person" key="entity-000632"
      >Verehrtester</tei:rs>!</tei:salute>
   </tei:opener>


   <tei:p rend="first">Allerbesten Dank. Hoffentlich kommt bei der Sache was Gescheites
     heraus.<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Nothing is known of this
     “matter.” (Schenker’s diaries have no entries for January–June 1902.)</tei:note></tei:p>

   <tei:closer>
    <tei:salute rend="indent-20">Schönster Gruß</tei:salute>
    <tei:salute rend="indent-40">Ihr</tei:salute>
    <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000363">R
     Heuberger</tei:rs></tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1902-06-12">12. 6. 902</tei:date></tei:dateline>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:note type="editorial" place="inline">all in a decorative rule-frame</tei:note><tei:lb/>
    <tei:fw type="envelope">
     <tei:fw type="header" rend="center"><tei:handShift new="#print"/><tei:hi rend="bold"
       >Postcard</tei:hi></tei:fw><tei:lb/>
     <tei:address>
      <tei:addrLine><tei:supplied>To:</tei:supplied>
       <tei:handShift new="#RH"/>Dr. Heinrich Schenker</tei:addrLine>
      <tei:addrLine rend="indent-20">Composer</tei:addrLine>
      <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002394"><tei:handShift new="#unk"/>Baden <tei:add
         place="interlinear-above">bei</tei:add> <tei:handShift new="#RH"/>Vienna</tei:rs> <tei:del rend="overstrike">3</tei:del></tei:addrLine>
      <tei:addrLine><tei:subst>
        <tei:del rend="overstrike">Richardgasse 11</tei:del>
        <tei:add place="inline"><tei:handShift new="#unk"/>Johannesgasse 6</tei:add>
       </tei:subst></tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| VIENNA 1/1 | a 1 | 12 6 02 | 9-10V ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| VIENNA 3/3 | 49 | DELIVERED | 12. 6. 02 | 1-3N ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| BADEN 1 | N.O. | DELIVERED | 12. 6. 02 | 7-9N ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute><tei:handShift new="#RH"/><tei:rs type="person" key="entity-000632">Most
      revered</tei:rs>,</tei:salute>
   </tei:opener>


   <tei:p rend="first">The very best thanks. Hopefully, something decent will emerge from the
     matter.<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:p>

   <tei:closer>
    <tei:salute rend="indent-20">Best greeting,</tei:salute>
    <tei:salute rend="indent-40">your</tei:salute>
    <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000363">R
     Heuberger</tei:rs></tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1902-06-12">June 12, 1902</tei:date></tei:dateline>
   </tei:closer>


  </tei:div>
