      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002748">Telegram</tei:rs>

      <dc:title>Handwritten telegram from Paul Wittgenstein to Schenker, incompletely dated [July 7,
        1913]</dc:title>

      <dcterms:created>1913-07-07T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-01</dcterms:dateSubmitted>
      <dc:description>Conditional permission is granted for photography of Op. 109.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000971">WittgensteinP</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:note type="editorial">Roman type = printed; Italic type = handwritten</tei:note>
      <tei:lb/>
      <tei:note type="editorial">top-left panel:</tei:note>

      <tei:ab type="formpart" rend="printed">Die Daten im dienstlichen Eingange der mittels
        Typendruckapparates ausgefertigten Telegramme bedeuten: 1. den Namen des Aufgabeamtes, 2.
        die Aufgabenummer, 3. die Wortzahl (eventuell in Bruchform), 4. den Monatstag und 5. die
        Stunde und Minute der Aufgabe.</tei:ab>

      <tei:ab type="formpart" rend="printed">Dienstliche Angaben: <tei:seg type="entry" rend="ms"
          >Wien 50</tei:seg></tei:ab>

      <tei:note type="editorial">top-center panel:</tei:note>

      <tei:ab type="formpart" rend="printed">Gattung: <tei:note type="editorial" place="inline"
          >blank</tei:note> – Eingangsnummer: <tei:note type="editorial" place="inline"
          >blank</tei:note></tei:ab>

      <tei:ab type="formpart" rend="printed">
        <tei:seg type="entry" rend="ms">H Schenker</tei:seg></tei:ab>

      <tei:ab type="formpart" rend="printed">Telegramm aus <tei:note type="editorial" place="inline"
          >blank</tei:note></tei:ab>

      <tei:note type="editorial">top-right panel:</tei:note>

      <tei:ab type="formpart" rend="printed">Die Telegraphenverwaltung übernimmt hinsichtlich der
        ihr zur Beförderung oder Bestellung übergebenen Telegramme keine wie immer geartete
        Verantwortung.</tei:ab>

      <tei:ab type="formpart" rend="printed">Aufgenommen von <tei:seg type="entry" rend="ms"
          >Na</tei:seg> auf Ltg. Nr. ... am ... 191<tei:seg type="entry" rend="ms">13</tei:seg> um
          <tei:seg type="entry" rend="ms">6</tei:seg> Uhr <tei:seg type="entry" rend="ms"
          >20</tei:seg> M. ... Mitt <tei:note type="editorial" place="inline">blank</tei:note>
        durch: <tei:note type="editorial" place="inline">illeg.</tei:note></tei:ab>

      <tei:note type="editorial">middle panel:</tei:note>

      <tei:ab type="formpart" rend="printed"><tei:handShift new="#HS"/><tei:seg type="entry"
          rend="ms">Wien 50 </tei:seg> Nr. <tei:seg type="entry" rend="ms">901</tei:seg> Taxw.
          <tei:seg type="entry" rend="ms">p</tei:seg> (W <tei:seg type="entry" rend="ms"
          >22</tei:seg> Ch ...) aufgegeben am <tei:note type="editorial" place="inline"
          >blank</tei:note> 191<tei:note type="editorial" place="inline">blank</tei:note> um
          <tei:seg type="entry" rend="ms">3</tei:seg> Uhr <tei:seg type="entry" rend="ms"
          >20</tei:seg> M. <tei:seg type="entry" rend="ms">r</tei:seg> Mittag.</tei:ab>

      <tei:note type="editorial">bottom panel:</tei:note>

      <tei:ab type="formpart" rend="printed">
        <tei:seg type="entry" rend="ms"><tei:hi rend="bold">Einwilligung gegeben unter der bedingung
            dass die fotografie in unseren hause aufgenommen wird und die Platten uns
            verbleiben</tei:hi>
        </tei:seg>
      </tei:ab>

      <tei:closer>
        <tei:salute rend="indent-30"><tei:handShift new="#unk2"/><tei:hi rend="bold"
            >Wittgenstein</tei:hi><tei:note xml:id="r0001-fn01" type="editorial" place="foot"
            >Receipt of this telegram and sending of Schenker’s preceding telegram are recorded in
            Schenker’s diary for July 7, 1913: “Telegramm an Wittgenstein; Rückantwort bringt
            Erlaubnis der Photographie.” (“Telegram to Wittgenstein; reply gives permission to
            photograph.”). — Schenker’s diary for July 20, 1913 records: “Brief an Wittgenstein mit
            Dank.” (“Letter to <tei:rs type="person" key="entity-000971">Wittgenstein</tei:rs>, with
            thanks.”).</tei:note></tei:salute><tei:lb/>
        <tei:fw type="footer">D. S. Nr. 759. (D-Ital.) (1.1910.)</tei:fw>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:note type="editorial">Roman type = printed; Italic type = handwritten</tei:note>
      <tei:lb/>
      <tei:note type="editorial">top-left panel:</tei:note>

      <tei:ab type="formpart" rend="printed">The data in the official receipt of the telegram
        prepared using the teletype mean: 1. the name of the issuing officer; 2. the issue number,
        3. the number of words (perhaps in form of a fraction), 4. the day of the week, and 5. the
        hour and minute of issue.</tei:ab>

      <tei:ab type="formpart" rend="printed">Official instructions: <tei:seg type="entry" rend="ms"
          >Vienna 50</tei:seg></tei:ab>

      <tei:note type="editorial">top-center panel:</tei:note>

      <tei:ab type="formpart" rend="printed">Category: <tei:note type="editorial" place="inline"
          >blank</tei:note> – Receipt No.: <tei:note type="editorial" place="inline"
          >blank</tei:note></tei:ab>

      <tei:ab type="formpart" rend="printed">
        <tei:seg type="entry" rend="ms">H Schenker</tei:seg></tei:ab>

      <tei:ab type="formpart" rend="printed">Telegram from <tei:note type="editorial" place="inline"
          >blank</tei:note></tei:ab>

      <tei:note type="editorial">top-right panel:</tei:note>

      <tei:ab type="formpart" rend="printed">The telegraph administration accepts no responsibility
        whatsoever for the telegrams given to them for transmission or delivery.</tei:ab>

      <tei:ab type="formpart" rend="printed">Received from <tei:seg type="entry" rend="ms"
          >Na</tei:seg> on line No. ... on ... 191<tei:seg type="entry" rend="ms">13</tei:seg> at
          <tei:seg type="entry" rend="ms">6</tei:seg> Hour <tei:seg type="entry" rend="ms"
          >20</tei:seg> Min. ... Midday <tei:note type="editorial" place="inline">blank</tei:note>
        by: <tei:note type="editorial" place="inline">illeg.</tei:note></tei:ab>

      <tei:note type="editorial">middle panel:</tei:note>

      <tei:ab type="formpart" rend="printed"><tei:handShift new="#HS"/><tei:seg type="entry"
          rend="ms">Vienna 50 </tei:seg> No. <tei:seg type="entry" rend="ms">901</tei:seg> Est. val.
          <tei:seg type="entry" rend="ms">p</tei:seg> (val <tei:seg type="entry" rend="ms"
          >22</tei:seg> Ch ...) Sent on <tei:note type="editorial" place="inline">blank</tei:note>
          191<tei:note type="editorial" place="inline">blank</tei:note> at <tei:seg type="entry"
          rend="ms">3</tei:seg> Hours <tei:seg type="entry" rend="ms">20</tei:seg> Min. <tei:seg
          type="entry" rend="ms">r</tei:seg> Midday.</tei:ab>

      <tei:note type="editorial">bottom panel:</tei:note>

      <tei:ab type="formpart" rend="printed">
        <tei:seg type="entry" rend="ms"><tei:hi rend="bold">Permission given on condition that the
            photography be requisitioned by our house and the plates remain with us.</tei:hi>
        </tei:seg>
      </tei:ab>

      <tei:closer>
        <tei:salute rend="indent-30"><tei:handShift new="#unk2"/><tei:hi rend="bold"><tei:rs
              type="person" key="entity-000971">Wittgenstein</tei:rs></tei:hi><tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute><tei:lb/>
        <tei:fw type="footer">D. S. Nr. 759. (D-Ital.) (1.1910.)</tei:fw>
      </tei:closer>

    </tei:div>
