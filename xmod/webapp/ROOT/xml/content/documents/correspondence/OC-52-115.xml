  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">postcard</tei:rs>



      <dc:title>Typewritten postcard from UE to Schenker, dated May 5, 1913</dc:title>

      <dcterms:created>1913-05-05T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-23</dcterms:dateSubmitted>
      <dc:description>Hertzka is expecting galley-proofs [of Op 109] to arrive, and has read two new
        reviews [of Beethovens neunte Sinfonie].</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:note type="editorial" place="inline">advertisement for Der Album der Saison / Excelsior
          in left third of <tei:hi rend="italic">recto</tei:hi></tei:note><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:supplied>An:</tei:supplied>
            <tei:handShift new="#TPue"/>Wohlgeboren Herrn Prof. Dr. H. Schenker</tei:addrLine>
          <tei:addrLine rend="indent-40">Wien III.</tei:addrLine>
          <tei:addrLine rend="indent-40">Reisnerstr. 38</tei:addrLine>
          <tei:addrLine rend="indent-30"><tei:handShift new="#unk"/>III/8</tei:addrLine>
        </tei:address>
        <tei:fw type="postmark">|| 1/1 WIEN <tei:gap reason="illegible"/> | <tei:gap
            reason="illegible"/> ||</tei:fw><tei:lb/><tei:lb/>
        <tei:milestone unit="folio" n="verso"/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#TPue"/>Wohlg. Herrn Prof. Dr. Heinrich
            Schenker</tei:addrLine>
          <tei:addrLine rend="indent-70">Wien</tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:salute>Sehr geehrter Herr <tei:rs type="person" key="entity-000632"
            >Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this postcard is apparently not recorded in Schenker's diary. </tei:note></tei:salute>
      </tei:opener>

      <tei:p>Ich hoffe bestimmt, von der Druckerei bald Fahnen<tei:note xml:id="r0001-fn02"
          type="editorial" place="foot">Of <tei:rs type="work" key="entity-001734"><tei:title
              level="m">Die letzten fünf Sonaten von Beethoven … op. 109</tei:title></tei:rs>
          (Vienna; UE, 1913). </tei:note> zu bekommen. – Das Referat in <tei:rs type="journal"
          key="entity-002545">der „<tei:title>Zeit</tei:title>“</tei:rs><tei:note
          xml:id="r0001-fn03" type="editorial" place="foot">Review by <tei:rs type="person"
            key="entity-000303">Max Graf</tei:rs> of <tei:rs type="work" key="entity-001731"
              ><tei:title level="m">Beethovens Neunte Sinfonie</tei:title></tei:rs> in <tei:rs
            type="journal" key="entity-002545"><tei:title level="j">Die Zeit</tei:title></tei:rs>,
          April 27, 1913, a clipping of which is preserved in Schenker's scrapbook on OC 2/p. 29.
        </tei:note> habe ich gelesen. Auch das im <tei:rs type="journal" key="entity-002561"
            ><tei:title>Neuen Wr. Tagblatt</tei:title></tei:rs>.<tei:note xml:id="r0001-fn04"
          type="editorial" place="foot">Unsigned review of <tei:rs type="work" key="entity-001731"
              ><tei:title level="m">Beethovens Neunte Sinfonie</tei:title></tei:rs>, in the <tei:rs
            type="journal" key="entity-002561"><tei:title level="j">Neues Wiener
              Tagblatt</tei:title></tei:rs>, April 7, 1913, a clipping of which is preserved in
          Schenker's scrapbook on OC 2/p. 29. </tei:note></tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">In aufrichtiger Hochschätzung </tei:salute>
        <tei:salute rend="indent-60">Ihr ganz ergebener</tei:salute>
        <tei:add><tei:note type="editorial" place="inline">unsigned</tei:note></tei:add><tei:lb/>
        <tei:salute rend="indent-80"><tei:handShift new="#printed"/><tei:del rend="overstrike"
            >Hochachtungsvoll</tei:del></tei:salute>
        <tei:signed rend="indent-70"><tei:rs key="entity-002408" type="organization"
            >„Universal-Edition“ A-G.</tei:rs></tei:signed>
        <tei:signed rend="indent-70">(Jos. Aibl Verlag, G.m.b.H.)</tei:signed><tei:lb/>
        <tei:dateline><tei:handShift new="#printed"/>Wien, am <tei:handShift new="#TPue"/><tei:date
            when="1913-05-05">5. Mai 1913 <tei:handShift new="#printed"
          />191</tei:date></tei:dateline>
        <tei:address>
          <tei:addrLine>I, Reichsratsstraße 9</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:note type="editorial" place="inline">advertisement for Der Album der Saison / Excelsior
          in left third of <tei:hi rend="italic">recto</tei:hi></tei:note><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:supplied>To:</tei:supplied>
            <tei:handShift new="#TPue"/>Prof. H. Schenker, Esq.</tei:addrLine>
          <tei:addrLine rend="indent-40">Vienna III</tei:addrLine>
          <tei:addrLine rend="indent-40">Reisnerstraße 38</tei:addrLine>
          <tei:addrLine rend="indent-30"><tei:handShift new="#unk"/>III/8</tei:addrLine>
        </tei:address>
        <tei:fw type="postmark">|| 1/1 VIENNA <tei:gap reason="illegible"/> | <tei:gap
            reason="illegible"/> ||</tei:fw><tei:lb/><tei:lb/>
        <tei:milestone unit="folio" n="verso"/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#TPue"/>Prof. Heinrich Schenker, Esq.</tei:addrLine>
          <tei:addrLine rend="indent-70">Vienna</tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:salute>Dear <tei:rs type="person" key="entity-000632">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
            type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>I very much hope to receive galley-proofs<tei:ptr corresp="#r0001-fn02" type="footnote"
        /> from the printers soon. – I have read the review in <tei:rs type="journal"
          key="entity-002545"><tei:title level="j">Die Zeit</tei:title></tei:rs>.<tei:ptr
          corresp="#r0001-fn03" type="footnote"/> Also that in the <tei:title level="j">Neues Wiener
          Tagblatt</tei:title>.<tei:ptr corresp="#r0001-fn04" type="footnote"/></tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">In sincere esteem,</tei:salute>
        <tei:salute rend="indent-60">Your wholly devoted</tei:salute>
        <tei:add><tei:note type="editorial" place="inline">unsigned</tei:note></tei:add><tei:lb/>
        <tei:salute rend="indent-80"><tei:handShift new="#printed"/><tei:del rend="overstrike"
            >Respectfully</tei:del></tei:salute>
        <tei:signed rend="indent-70"><tei:rs key="entity-002408" type="organization">Universal
            Edition &amp; Co.</tei:rs></tei:signed>
        <tei:signed rend="indent-70">(Jos. Aibl Publishers &amp; Co.)</tei:signed><tei:lb/>
        <tei:dateline><tei:handShift new="#printed"/>Vienna <tei:handShift new="#TPue"/><tei:date
            when="1913-05-05">May 5, 1913 <tei:handShift new="#printed"
          />191</tei:date></tei:dateline>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>I, Reichsratsstraße 9</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>
  </sdo:record>
