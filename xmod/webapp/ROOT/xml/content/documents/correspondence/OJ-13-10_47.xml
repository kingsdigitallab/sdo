  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten postcard from Reinhard, Walter &amp; Ulrich Oppel to Heinrich &amp;
        Jeanette Schenker, dated August 4, 1927</dc:title>

      <dcterms:created>1927-08-04T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-07-31</dcterms:dateSubmitted>
      <dc:description>Oppel and his sons send greetings; he is studying Schenker’s Counterpoint,
        vol. 1.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-003957">Walter Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-000644">Ulrich Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">photograph of waterfall, captioned: “2590 REUTTE:
          PLANSEE – GROSSER STUIBENFALL</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Galtür / Paznauntal</tei:addrLine>
            <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"><tei:note type="editorial" place="inline"
            >illegible</tei:note></tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1927-08-08">8. VIII 27 </tei:date>.
          Mein lieber Herr <tei:rs type="person" key="entity-000632">Schenker</tei:rs>,<tei:note
            xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this picture postcard is
            recorded in Schenker’s diary for August 10, 1927: “Von Oppel (Ansichtsk.): reist heim u.
            grüßt.” (“From Oppel (picture postcard): he is returning home and sends greetings.”). —
            Schenker’s reply is recorded in his diary for August 11, 1927: “An Oppel (Ansichtsk.):
            wünsche ihm Glück zu Kiel Leipzig.” (“To Oppel (picture postcard): I wish him well in
            Kiel and Leipzig.”). — Reutte: a small town on the River Lech, in the Tyrol, about five
            miles north of Heiterwang. The “Großer Stuibenfall” shown in the photograph is much
            smaller than the Stuibenfall in the Ötz Valley, which is Austria’s highest and most
            spectacular waterfall.</tei:note></tei:salute>
      </tei:opener>

      <tei:p>nun sind wir nur noch 3 Tage hier i. d. herrlichen Land. Am <tei:date when="1927-08-11"
          >11.</tei:date> fahren wir nach Hause, am <tei:date when="1927-08-16">16.</tei:date> haben
        die <tei:rs type="person" key="entity-004801">Jungen</tei:rs> wieder Schule. Ich tue hier
        nichts als <tei:rs type="work" key="entity-001727">II<tei:hi rend="supralinear"
          >1</tei:hi></tei:rs> durchstudieren. </tei:p>

      <tei:closer>
        <tei:salute>Alles Gute u. die herzlichsten</tei:salute>
        <tei:salute>Grüsse Ihnen beiden!</tei:salute>
        <tei:salute>Ihre treuen</tei:salute>
        <tei:signed><tei:rs type="person" key="entity-000643">Reinhard Oppel</tei:rs>.</tei:signed><tei:lb/>
        <tei:signed><tei:handShift new="#UO"/>Herzliche Grüsse sendet <tei:rs type="person"
            key="entity-000644">Ulrich</tei:rs>.</tei:signed><tei:lb/>
        <tei:signed><tei:handShift new="#WO"/>Herzliche Grüße von <tei:rs type="person"
            key="entity-003957">Walter</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">photograph of waterfall, captioned: “2,590 REUTTE:
          PLANSEE – GREAT STUIBENFALL</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Galtür, Paznaun Valley</tei:addrLine>
            <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark"><tei:note type="editorial" place="inline"
            >illegible</tei:note></tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1927-08-08">August 8, 1927</tei:date>.
          My dear Mr. <tei:rs type="person" key="entity-000632">Schenker</tei:rs>,<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>We shall be here in this splendid country only for another three days. We return home
        on the <tei:date when="1927-08-11">11th</tei:date>; the <tei:rs type="person"
          key="entity-004801">boys</tei:rs> are back in school on the <tei:date when="1927-08-16"
          >16th</tei:date>. I am doing nothing here but studying the <tei:rs type="work"
          key="entity-001727">first volume of your <tei:title level="m"
          >Counterpoint</tei:title></tei:rs>. </tei:p>

      <tei:closer>
        <tei:salute>All good wishes, and most cordial</tei:salute>
        <tei:salute>greetings to the two of you.</tei:salute>
        <tei:salute>Your faithful</tei:salute>
        <tei:signed><tei:rs type="person" key="entity-000643">Reinhard Oppel</tei:rs></tei:signed><tei:lb/>
        <tei:signed><tei:handShift new="#UO"/><tei:rs type="person" key="entity-000644"
            >Ulrich</tei:rs> sends cordial greetings</tei:signed><tei:lb/>
        <tei:signed><tei:handShift new="#WO"/>Cordial greetings from <tei:rs type="person"
            key="entity-003957">Walter</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

