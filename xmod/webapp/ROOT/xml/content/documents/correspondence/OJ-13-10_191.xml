  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Oppel to Schenker, dated December 31, 1934</dc:title>

      <dcterms:created>1934-12-31T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-12-29</dcterms:dateSubmitted>
      <dc:description>Oppel sends the Schenkers greetings for the New Year. – He has heard an
        excellent concert given by the Regensburg Cathedral Choir.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
            >Postkarte</tei:hi></tei:fw><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof.
                D<tei:hi rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Wien III / Österreich</tei:addrLine>
            <tei:addrLine>Keilgasse 8/<tei:hi rend="supralinear">12</tei:hi></tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| [LEIPZIG] W[31] | [3]1 <tei:gap reason="illegible"/> | 9–10 | *
            MESSESTADT * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1934-12-31">31. XII 34</tei:date>.
          Mein lieber Herr <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>,<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this postcard is recorded in Schenker’s diary for January 2, 1935: “Von Oppel (K.):
            Neujahrsgruß, immer in Treue” (“From Oppel (postcard): New Year’s greetings, always in
            faith”).</tei:note>
        </tei:salute>
      </tei:opener>

      <tei:p>für 1935 wünschen wir alle Ihnen beiden alles Gute! <tei:rs type="person"
          key="entity-003957">Walter</tei:rs> u. <tei:rs type="person" key="entity-000644"
          >Ulrich</tei:rs> sind wieder abgereist. Es geht allen gut. Ich muss ein paar Tage nun
          <tei:hi rend="underline">ab</tei:hi>schreiben, Sklavenarbeit. Dann melde ich mich
        ausführlich. Gestern hörten wir den Regensburger Domchor, sehr gut. <tei:rs type="person"
          key="entity-000104">Bruckner</tei:rs>, <tei:rs type="person" key="entity-000533"
          >Liszt</tei:rs> u. <tei:rs type="person" key="entity-000695">Reger</tei:rs> fielen gegen
        die Meister der <tei:foreign xml:lang="ita">a cap.</tei:foreign> Periode<tei:note
          xml:id="r0001-fn02" type="editorial" place="foot">By this expression, Oppel is probably
          referring to the choral polyphony of the Renaissance.</tei:note> aber gewaltig ab. </tei:p>

      <tei:closer>
        <tei:salute>Mit den herzlichsten Neujahrsgrüssen</tei:salute>
        <tei:salute>vom ganzen Haus</tei:salute>
        <tei:salute rend="indent-50">Ihr treuer</tei:salute>
        <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
            >Postcard</tei:hi></tei:fw><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Vienna III / Austria</tei:addrLine>
            <tei:addrLine>Keilgasse 8/<tei:hi rend="supralinear">12</tei:hi></tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| [LEIPZIG] W[31] | [3]1 <tei:gap reason="illegible"/> | 9–10 | *
            TRADE FAIR CITY * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1934-12-31">December 31,
            1934</tei:date>. My dear <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>All good wishes from us to the two of you for 1935! <tei:rs type="person"
          key="entity-003957">Walter</tei:rs> and <tei:rs type="person" key="entity-000644"
          >Ulrich</tei:rs> have already left. We are all well. I must now spend the next few days
          <tei:hi rend="underline">copy</tei:hi>ing: slave labor. Then I shall write
        comprehensively. Yesterday we heard the Regensburg Cathedral Choir, very good. <tei:rs
          type="person" key="entity-000104">Bruckner</tei:rs>, <tei:rs type="person"
          key="entity-000533">Liszt</tei:rs> and <tei:rs type="person" key="entity-000695"
          >Reger</tei:rs> fell far short of the masters of the <tei:hi rend="italic"><tei:foreign
            xml:lang="ita">a cappella</tei:foreign></tei:hi> period.<tei:ptr corresp="#r0001-fn02"
          type="footnote"/></tei:p>

      <tei:closer>
        <tei:salute>With the most cordial New Year’s greetings</tei:salute>
        <tei:salute>from all of us,</tei:salute>
        <tei:salute rend="indent-50">Your faithful</tei:salute>
        <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

