  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Oppel to Schenker, dated June 21, 1933</dc:title>

      <dcterms:created>1933-06-21T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-12-10</dcterms:dateSubmitted>
      <dc:description>Oppel asks Schenker for his summer address, as his letter of June 14 was
        returned unopened.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
            >Postkarte</tei:hi></tei:fw><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/>Absender: <tei:handShift new="#RO"/>D<tei:hi
                rend="supralinear">r.</tei:hi> Oppel</tei:addrLine>
            <tei:addrLine>Leipzig W 31</tei:addrLine>
            <tei:addrLine>Könneritzstr 58<tei:hi rend="supralinear">III</tei:hi></tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine><tei:del rend="overstrike">Wien III / Östreich</tei:del></tei:addrLine>
            <tei:addrLine><tei:del rend="overstrike">Keilgasse 8/<tei:hi rend="supralinear"
                  >12</tei:hi></tei:del></tei:addrLine>
            <tei:addrLine><tei:handShift new="#unk"/>Schloß Reigersberg</tei:addrLine>
            <tei:addrLine>i<tei:supplied>n</tei:supplied> Ilz Ort
                St<tei:supplied>eier</tei:supplied>m<tei:supplied>ar</tei:supplied>k</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG W3 | <tei:gap reason="illegible"/> | <tei:gap
              reason="illegible"/> ||</tei:fw><tei:lb/>
          <tei:fw type="postmark">|| 3 WIEN 40 | 22. VI. 33. 18 | * 5a * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1933-06-21">21. 6. 33</tei:date>. Mein
          lieber Herr <tei:rs type="person" key="entity-000632">Professor Schenker</tei:rs><tei:note
            xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this postcard is recorded
            in Schenker’s diary for June 23, 1933: “Von Oppel (K.): der Brief zum 19. sei
            zurückgekommen, bittet um die genaue Adresse” (“From Oppel (postcard): his letter for
            the 19th was returned, requests the precise address”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p>m. Brief zum <tei:date when="1933-06-19">19.</tei:date>,<tei:note xml:id="r0001-fn02"
          type="editorial" place="foot">= <tei:ref type="correspondence" cRef="OJ-13-10_168">OJ
            13/10, [168]</tei:ref>, June 14, 1933.</tei:note> der schon am <tei:date
          when="1933-06-16">16.</tei:date> in Wien, <tei:date when="1933-06-17">17.</tei:date>
        <tei:rs type="place" key="entity-002362">Linz</tei:rs> gestempelt ist, kam leider heute
        zurück; Ihre Ferienaddresse war zu undeutlich geschrieben. Ich hoffe, Sie sind gut
        angekommen u. haben besseres Wetter als wir, die <tei:add place="interlinear-above"
          >wir</tei:add> mit Regen ausgiebig versorgt werden. Ich bitte um baldige Nachricht u.
        Adresse. <tei:rs type="person" key="entity-005266">Meine Frau</tei:rs> u. den <tei:rs
          type="person" key="entity-004801">Kindern</tei:rs> gehts gut. – Ich schicke den Brief dann
        sofort nach. – <tei:rs type="person" key="entity-003957">Walter</tei:rs> verbringt seine
        paar Urlaubstage bei Freunden in Kitzeberg bei <tei:rs type="place" key="entity-002757"
          >Kiel</tei:rs>. Ich freue mich auch auf die Ferien, wir müssen aber noch bis <tei:date
          when="1933-07-17">17. Juli</tei:date> aushalten. </tei:p>

      <tei:closer>
        <tei:salute>Gute Erholung und viel Sonne wünschend,</tei:salute>
        <tei:salute>bleibe ich mit den herzlichsten Grüssen an Sie beide</tei:salute>
        <tei:salute rend="indent-20">Ihr treuer</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
            >Postcard</tei:hi></tei:fw><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:handShift new="#pr"/>From: <tei:handShift new="#RO"/>Dr.
              Oppel</tei:addrLine>
            <tei:addrLine>Leipzig W 31</tei:addrLine>
            <tei:addrLine>Könneritzstrasse 58<tei:hi rend="supralinear">III</tei:hi></tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine><tei:del rend="overstrike">Vienna III / Austria</tei:del></tei:addrLine>
            <tei:addrLine><tei:del rend="overstrike">Keilgasse 8/<tei:hi rend="supralinear"
                  >12</tei:hi></tei:del></tei:addrLine>
            <tei:addrLine><tei:handShift new="#unk"/>Schloß Reigersberg</tei:addrLine>
            <tei:addrLine>i<tei:supplied>n</tei:supplied> Ilz Ort
                St<tei:supplied>eier</tei:supplied>m<tei:supplied>ar</tei:supplied>k</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG W3 | <tei:gap reason="illegible"/> | <tei:gap
              reason="illegible"/> ||</tei:fw><tei:lb/>
          <tei:fw type="postmark">|| 3 VIENNA 40 | 22. VI. 33. 18 | * 5a * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1933-06-21">June 21, 1933</tei:date>.
          My dear <tei:rs type="person" key="entity-000632">Professor Schenker</tei:rs><tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>My letter intended for the <tei:date when="1933-06-19">19th</tei:date>,<tei:ptr
          corresp="#r0001-fn02" type="footnote"/> which had already been postmarked on the <tei:date
          when="1933-06-16">16th</tei:date> in Vienna and in <tei:rs type="place"
          key="entity-002362">Linz</tei:rs> on the <tei:date when="1933-06-17">17th</tei:date>,
        unfortunately came back; your holiday address had been written too unclearly. I hope that
        you arrived safely and have had better weather than <tei:add place="interlinear-above"
          >we</tei:add>, who have been amply supplied with rain. I hope to have some news, and your
        address. <tei:rs type="person" key="entity-005266">My wife</tei:rs> and <tei:rs
          type="person" key="entity-004801">children</tei:rs> are well. – I shall then send the
        letter immediately – <tei:rs type="person" key="entity-003957">Walter</tei:rs> is passing
        his few days of holiday with friends in Kitzeberg, near <tei:rs type="place"
          key="entity-002757">Kiel</tei:rs>. I am looking forward to the holidays but we must stay
        on here until <tei:date when="1933-07-17">July 17</tei:date>.</tei:p>

      <tei:closer>
        <tei:salute>Wishing you a good recovery and much sunshine,</tei:salute>
        <tei:salute>I remain, with the most cordial greetings to the two of you,</tei:salute>
        <tei:salute rend="indent-20">Your faithful</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
