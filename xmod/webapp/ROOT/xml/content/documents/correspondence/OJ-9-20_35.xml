  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Breitkopf &amp; Härtel to Schenker, dated August 7,
        1905</dc:title>

      <dcterms:created>1905-08-07T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-04</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel acknowledge receipt of Schenker's manuscript [of
        Harmonielehre].</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/>
        <tei:fw type="header" rend="center"><tei:handShift new="print"/><tei:hi rend="bold"
            >Postkarte</tei:hi></tei:fw>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">An: </tei:supplied>
              <tei:handShift new="print"/>Herr<tei:handShift new="BHsten1"/>n H.
              Schenker</tei:addrLine>
            <tei:addrLine>z. Z. <tei:rs type="place" key="entity-002279">St Anton</tei:rs> (<tei:rs
                type="place" key="entity-002334">Tirol</tei:rs>)</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG | -7. 8. 05. 9-10N. | * 13 * ||</tei:fw><tei:lb/><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
          <tei:address>
            <tei:addrLine><tei:note type="editorial" place="inline">device</tei:note>
              <tei:handShift new="print"/>Breitkopf &amp; Härtel</tei:addrLine>
            <tei:addrLine>Leipzig, den <tei:handShift new="BHsten2"/>7. 8. <tei:handShift
                new="print"/>19<tei:handShift new="BHsten2"/>05.</tei:addrLine>
            <tei:addrLine><tei:handShift new="print"/>Nürnberger Str. 36.</tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute><tei:handShift new="BHsten2"/>Sehr geehrter <tei:rs type="person"
            key="entity-000632">Herr</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">Ihr Manuscript<tei:note xml:id="r0001-fn01" type="editorial" place="foot"
          >The manuscript of Schenker’s <tei:rs type="work" key="entity-001724"><tei:title level="m"
              >Harmonielehre</tei:title></tei:rs>, at that stage entitled <tei:title level="m">Neue
            musikalische Theorien und Phantasien von einem Künstler</tei:title>.</tei:note> haben
        wir erhalten und werden es diskret behandeln und sorgsam verwahren. Doch bitten wir um etwas
        Zeit für unsere Erwägungen – gleich Ihnen befinden sich auch so manche andere Leute jetzt
        auf Reisen!</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-70">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten2"/>Herrn <tei:hi rend="lateinschr">H.
              Schenker</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-15"><tei:hi rend="lateinschr">z.Z. <tei:rs type="place"
                key="entity-002279">St. Anton</tei:rs></tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-30"><tei:hi rend="lateinschr">(<tei:rs type="place"
                key="entity-002334">Tirol</tei:rs>)</tei:hi></tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/>
        <tei:fw type="header" rend="center"><tei:handShift new="print"/><tei:hi rend="bold"
            >Postcard</tei:hi></tei:fw>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">To: </tei:supplied>
              <tei:handShift new="print"/>Mr. <tei:handShift new="BHsten1"/>H.
              Schenker</tei:addrLine>
            <tei:addrLine>currently at: <tei:rs type="place" key="entity-002279">St Anton</tei:rs>
                (<tei:rs type="place" key="entity-002334">Tirol</tei:rs>)</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG | -7. 8. 05. 9-10N. | * 13 * ||</tei:fw><tei:lb/><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
          <tei:address>
            <tei:addrLine><tei:note type="editorial" place="inline">device</tei:note>
              <tei:handShift new="print"/>Breitkopf &amp; Härtel</tei:addrLine>
            <tei:addrLine>Leipzig, <tei:handShift new="BHsten2"/>August 7, <tei:handShift
                new="print"/>19<tei:handShift new="BHsten2"/>05</tei:addrLine>
            <tei:addrLine><tei:handShift new="print"/>Nürnberger Strasse 36</tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute><tei:handShift new="BHsten2"/>Dear <tei:rs type="person" key="entity-000632"
            >Sir</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">We have received your manuscript<tei:ptr corresp="#r0001-fn01"
          type="footnote"/> and will treat it with discretion and take great care of it. But we ask
        you to give us a little time for our deliberations – like you, many other people, too, are
        currently on their travels!</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Respectfully,</tei:salute>
        <tei:signed rend="indent-70">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten2"/>Mr. H. Schenker</tei:addrLine>
          <tei:addrLine rend="indent-15">currently at: <tei:rs type="place" key="entity-002279">St.
              Anton</tei:rs></tei:addrLine>
          <tei:addrLine rend="indent-30">(<tei:rs type="place" key="entity-002334"
            >Tirol</tei:rs>)</tei:addrLine>
        </tei:address>
      </tei:closer>


    </tei:div>
