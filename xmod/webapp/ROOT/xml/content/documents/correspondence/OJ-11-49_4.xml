 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-008545">HeubergerR ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



   <dc:title>Handwritten postcard from Richard Heuberger to Schenker, dated September 21,
    1905</dc:title>

   <dcterms:created>1905-09-21T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-11-14</dcterms:dateSubmitted>
   <dc:description>Request for birth date and place, probably sent in error.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000363">RHeuberger</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:fw type="envelope">
     <tei:fw type="header" rend="center"><tei:handShift new="#print"/><tei:hi rend="bold"
       >Korrespondenz-Karte.</tei:hi></tei:fw><tei:lb/>
     <tei:address>
      <tei:addrLine><tei:handShift new="#print"/>An: <tei:handShift new="#RH"/>Herrn D<tei:hi
        rend="supralinear">r.</tei:hi> H. Schenker</tei:addrLine>
      <tei:addrLine rend="indent-40">Komponist</tei:addrLine>
      <tei:addrLine rend="indent-60">Wien 3</tei:addrLine>
      <tei:addrLine rend="indent-50">Reisnerstraße 38</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| WIEN 1/1 | 21 9 05 11-12N | a 1 * ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| WIEN 49 | 22[?] IX.05 VIII | BESTELLT ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute><tei:handShift new="#RH"/>Lieben Fr. u. <tei:gap reason="illegible"/><tei:note
      xml:id="r0001-fn01" type="editorial" place="foot">Heuberger has presumably written the rectos
      of several postcards first, and then the versos, getting the order wrong – i.e. the message
      intended for Schenker has gone to an unrelated married couple. (Schenker’s diary for the
      entire year of 1905 has no entries other than one undated one that may refer to
      July.)</tei:note></tei:salute>
   </tei:opener>


   <tei:p>Bitte umgehend um Angabe Ihres Geburts-Datums und -Ortes.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-40">Herzlich Ihr</tei:salute>
    <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000363">R
     Heuberger</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine>I. Hegelgasse 17</tei:addrLine>
     <tei:addrLine>Wien <tei:date when="1905-09-21">21. 9. 05</tei:date></tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:fw type="envelope">
     <tei:fw type="header" rend="center"><tei:handShift new="#print"/><tei:hi rend="bold"
       >Postcard</tei:hi></tei:fw><tei:lb/>
     <tei:address>
      <tei:addrLine><tei:handShift new="#print"/>To: <tei:handShift new="#RH"/>Dr. H.
       Schenker</tei:addrLine>
      <tei:addrLine rend="indent-40">Composer</tei:addrLine>
      <tei:addrLine rend="indent-60">Vienna III</tei:addrLine>
      <tei:addrLine rend="indent-50">Reisnerstraße 38</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| VIENNA 1/1 | 21 9 05 11-12N | a 1 * ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| VIENNA 49 | 22[?] IX.05 VIII | DELIVERED ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute><tei:handShift new="#RH"/>Dear Mrs. and <tei:gap reason="illegible"/><tei:ptr
      corresp="#r0001-fn01" type="footnote"/></tei:salute>
   </tei:opener>


   <tei:p>Please provide by return of post your date and place of birth.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-40">Cordially your</tei:salute>
    <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000363">R
     Heuberger</tei:rs></tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine>Vienna I, Hegelgasse 17</tei:addrLine>
     <tei:addrLine><tei:date when="1905-09-21">September 21, 1905</tei:date></tei:addrLine>
    </tei:address>
   </tei:closer>


  </tei:div>
 </sdo:record>
