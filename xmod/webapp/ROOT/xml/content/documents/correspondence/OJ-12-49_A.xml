 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
    HSchenker</tei:rs>
   <tei:rs role="correspondence" type="correspondence" key="entity-002430">Gesellschaft der
    Musikfreunde ~ HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-003332">calling card</tei:rs>



   <dc:title>Handwritten calling card from Mandyczewski to Schenker, dated November 29
    [pre-1898?]</dc:title>

   <dcterms:created>1895-01-01T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-24</dcterms:dateSubmitted>
   <dc:description>Mandyczewski replies that the Society's archive does not have a certain book by
    Alfred Boehme.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000562">EMandyczewski</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="verso"/><tei:lb/>
    <tei:salute><tei:handShift new="#EM"/>Geehrter Herr <tei:rs type="person" key="entity-000632"
      >Doctor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">While there are
      many letters from Böhme as signatory to <tei:rs type="organization" key="entity-002627">Drei
       Masken Verlag</tei:rs>, there are no references to him in Schenker’s diary, hence no way of
      dating this calling card; but the formal mode of address suggests that this document precedes
      1898.</tei:note></tei:salute>
   </tei:opener>

   <tei:p rend="indent-10">Wir haben das <tei:rs type="person" key="entity-004930"
    >Böhme</tei:rs>‘sche Buch nicht. Ich kenne es als sehr mangelhaft und unverläßlich, wie Alles,
    was von <tei:rs type="person" key="entity-004930">Böhme</tei:rs> herrührt, und haben es nicht
    angeschafft, da ich kaum Geld genug habe <tei:milestone unit="folio" n="verso"/> für die <tei:hi
     rend="underline">guten</tei:hi> Bücher, die es giebt.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-20">Mit den besten Grüßen</tei:salute>
    <tei:salute rend="indent-50">Ihr ergebener</tei:salute>
    <tei:signed rend="indent-80"> </tei:signed>
    <tei:signed><tei:handShift new="#pr"/><tei:rs type="person" key="entity-000562">EUSEBIUS
      MANDYCZEWSKI</tei:rs></tei:signed>
    <tei:signed>ARCHIVAR UND BIBLIOTHEKAR DER <tei:lb/><tei:rs type="organization"
      key="entity-002430">GESELLSCHAFT DER MUSIKFREUNDE IN WIEN</tei:rs>.</tei:signed><tei:lb/>
    <tei:dateline><tei:handShift new="#EM"/><tei:date when="1895-11-29"
     >29/11</tei:date></tei:dateline>
   </tei:closer>


  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="verso"/><tei:lb/>
    <tei:salute><tei:handShift new="#EM"/>Dear <tei:rs type="person" key="entity-000632">Dr.
       <tei:supplied reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr
      corresp="#r0001-fn01" type="footnote"/></tei:salute>
   </tei:opener>

   <tei:p rend="indent-10">We do not have the book by <tei:rs type="person" key="entity-004930"
     >Böhme</tei:rs>. I know it as very flawed and unreliable, like everything that comes from
     <tei:rs type="person" key="entity-004930">Böhme</tei:rs>, and have not purchased it, since I
    have scarcely enough money <tei:milestone unit="folio" n="verso"/> for the <tei:hi
     rend="underline">good</tei:hi> books that there are.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-20">With best greetings,</tei:salute>
    <tei:salute rend="indent-50">your devoted</tei:salute>
    <tei:signed rend="indent-80"> </tei:signed>
    <tei:signed><tei:handShift new="#pr"/><tei:rs type="person" key="entity-000562">EUSEBIUS
      MANDYCZEWSKI</tei:rs></tei:signed>
    <tei:signed>ARCHIVIST AND LIBRARIAN OF THE <tei:lb/><tei:rs type="organization"
      key="entity-002430">SOCIETY OF THE FRIENDS OF MUSIC IN VIENNA</tei:rs></tei:signed><tei:lb/>
    <tei:dateline><tei:handShift new="#EM"/><tei:date when="1895-11-29">November
     29</tei:date></tei:dateline>
   </tei:closer>

  </tei:div>
