  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated January 4,
        1930</dc:title>

      <dcterms:created>1930-01-04T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-09-02</dcterms:dateSubmitted>
      <dc:description>Oppel sends greetings from Kassel, where he has seen the Rembrandt paintings
        in the state museum. </dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: portrait, seated figure, captioned on
          recto: “REMBRANDT VAN RIJN / Bildnis eines Architekten”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >POSTKARTE</tei:hi></tei:fw><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich <tei:hi rend="underline"
                >Schenker</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="double-underline">Wien III /
              Östreich</tei:hi></tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">
            <tei:note type="editorial" place="inline">illegible</tei:note></tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1930-01-04">4. I. 30</tei:date>. Mein
          lieber Herr <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>,<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this postcard is recorded in Schenker’s diary for January 6, 1930: “Von Oppel
            (Ansichtsk.): Grüße aus Kassel” (“from Oppel (picture postcard): greetings from
            Kassel”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p>ich fuhr über <tei:rs type="place" key="etity-005379">Kassel</tei:rs>, um mir die
        Rembrandt’s anzusehn, u. nach der Ferienarbeit einen Tag auszuspannen. Von <tei:rs
          type="place" key="entity-002479">Leipzig</tei:rs> aus mehr. </tei:p>

      <tei:closer>
        <tei:salute>Mit den herzl. Grüssen </tei:salute>
        <tei:salute>Ihnen beiden </tei:salute>
        <tei:salute rend="indent-20">Ihr treuer</tei:salute>
        <tei:signed rend="indent-20"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">picture: portrait, seated figure, captioned on
          recto: “REMBRANDT VAN RIJN / Portrait of an Architect”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >POSTCARD</tei:hi></tei:fw><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
                <tei:hi rend="underline">Schenker</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="double-underline">Vienna III,
              Austria</tei:hi></tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">
            <tei:note type="editorial" place="inline">illegible</tei:note></tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1930-01-04">January 4,
          1930</tei:date>. My dear <tei:rs type="person" key="entity-000632">Professor
            Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>I travelled via <tei:rs type="place" key="etity-005379">Kassel</tei:rs> to see the
        Rembrandt paintings and to unwind after the work during the holidays. More when I get to
          <tei:rs type="place" key="entity-002479">Leipzig</tei:rs>.</tei:p>

      <tei:closer>
        <tei:salute>With the most cordial greetings</tei:salute>
        <tei:salute>to the two of you,</tei:salute>
        <tei:salute rend="indent-20">Your faithful</tei:salute>
        <tei:signed rend="indent-20"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
