  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated June 10, 1928</dc:title>

      <dcterms:created>1928-06-10T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-14</dcterms:dateSubmitted>
      <dc:description>Oppel has acted as a judge in a music competition in Bingen am
        Rhein.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-006121">Josef Knettel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">photograph: river, bridge, town, captioned:
          ”BINGEN mit der Drususbrücke”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Wien III / Östreich</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| MAINZ | 10 6 28 8–9 N |* 1 * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1928-06-10">10 VI 28</tei:date>. Mein
          lieber Herr <tei:rs type="person" key="entity-000632">Prof Schenker</tei:rs>,<tei:note
            xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this picture postcard is
            recorded in Schenker’s diary for June 12, 1928: “Von Oppel (Ansichtsk.): Gruß aus
            Bingen, wo er als Preisrichter waltet” (“From Oppel (picture postcard): greetings from
            Bingen, where he is presiding as adjudicator”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p>vom Rhein senden wir Ihnen u <tei:rs type="person" key="entity-000771">Ihrer l.
          Frau</tei:rs> die herzl Grüsse! War hier als Preisrichter.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-40">Ihr tr</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
        <tei:signed rend="indent-40"><tei:handShift new="#JK"/><tei:rs type="person"
            key="entity-006121">Josef Knettel</tei:rs><tei:note xml:id="r0001-fn02" type="editorial"
            place="foot">Josef Knettel (1875–1972), choral conductor and chief music director of the
            town of Bingen am Rhein.</tei:note></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">photograph: river, bridge, town, captioned:
          ”BINGEN with the Drusus Bridge”</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Vienna III / Austria</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| MAINZ | 10 6 28 8–9 N |* 1 * ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1928-06-10">June 10, 1928</tei:date>.
          My dear <tei:rs type="person" key="entity-000632">Prof. Schenker</tei:rs>,<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>From the Rhine, we send you and <tei:rs type="person" key="entity-000771">your dear
          wife</tei:rs> the most cordial greetings! I was here as a competition judge. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-40">Your faithful</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000643">Reinhard
            Oppel</tei:rs></tei:signed>
        <tei:signed rend="indent-40"><tei:handShift new="#JK"/><tei:rs type="person"
            key="entity-006121">Josef Knettel</tei:rs><tei:ptr corresp="#r0001-fn02" type="footnote"
          /></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
