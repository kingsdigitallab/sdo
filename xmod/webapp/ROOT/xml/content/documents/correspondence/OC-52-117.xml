      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated May 19, 1913</dc:title>

      <dcterms:created>1913-05-19T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-24</dcterms:dateSubmitted>
      <dc:description>Hertzka reproaches Schenker for the tone of his letter.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-05-19">19. Mai 1913</tei:date>.</tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-30">Wohlgeboren Herrn Prof. Dr. <tei:persName>Heinrich
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:placeName><tei:hi rend="underline"
              >Wien</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueW"/>Sehr geehrter Herr <tei:rs key="entity-000632"
            type="person">Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Receipt of this letter is recorded in Schenker's diary of May 19, 1913:
            “Brief v. Hertzka, der <tei:del rend="overstrike">plötzlich</tei:del> die Ursache meines
            Zornes nicht in sich selbst finden will!” (“Letter from Hertzka, who <tei:del
              rend="overstrike">suddenly</tei:del> does not wish to seek in himself the cause of my
            anger!”). </tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Es scheint, dass meine Briefe bei Ihnen den gegenteiligen Effekt erzielen,
        als sie beabsichtigen. Es ist nicht meine Sache<tei:note xml:id="r0001-fn02"
          type="editorial" place="foot">Hertzka is mimicking Schenker's words in <tei:ref
            type="correspondence" cRef="WSLB-158">WSLB 158</tei:ref>, May 18, 1913. </tei:note> zu
        erforschen, worüber Sie sich unmittelbar vor Abfassung Ihres Schreibens geärgert haben, denn
        wenn ein solches anderweitiges Aergernis nicht vorangegangen wäre, könnte ich wahrlich den
        Ton Ihres Briefes nicht verstehen. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-70">hochachtungsvoll</tei:salute>
        <tei:salute rend="indent-80">ergeben</tei:salute>
        <tei:signed rend="indent-60"><tei:handShift new="#stamp"/><tei:rs type="organization"
            key="entity-002408">Universal-Edition</tei:rs> Aktienges.</tei:signed>
        <tei:signed rend="indent-90"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Josef Aibl Publishers &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-05-19">May 19, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-30">Prof. <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:placeName><tei:hi rend="underline"
              >Vienna</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueW"/>Dear <tei:rs key="entity-000632" type="person">Dr.
              <tei:supplied reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">My letters seem to achieve the opposite effect on you to what they intend.
        It is not my job<tei:ptr corresp="#r0001-fn02" type="footnote"/> to investigate why
        immediately before composing your letter you worked yourself up into a fury, for if it were
        not such a fit of anger that was behind <tei:supplied reason="clarity">it</tei:supplied>, I
        would be at a loss to understand the tone of your letter. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-70">With kind regards,</tei:salute>
        <tei:salute rend="indent-80">Your devoted</tei:salute>
        <tei:signed rend="indent-60"><tei:handShift new="#stamp"/><tei:rs type="organization"
            key="entity-002408">Universal Edition</tei:rs> &amp; Co.</tei:signed>
        <tei:signed rend="indent-90"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
