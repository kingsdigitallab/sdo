  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-008451">Hanslick ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-003332">Calling card</tei:rs>



      <dc:title>Handwritten calling card from Hanslick to Schenker, dated December 1898</dc:title>

      <dcterms:created>1898-12-12T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-10</dcterms:dateSubmitted>
      <dc:description>Hanslick thanks Schenker for his kind thoughts.</dc:description>
      <dc:subject/>


      <marcrel:correspondent key="entity-000331">Eduard Hanslick</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener/>

      <tei:p><tei:handShift new="#printed"/><tei:rs type="person" key="entity-000331"><tei:hi
            rend="bold">D<tei:hi rend="supralinear">r.</tei:hi> Eduard
        Hanslick</tei:hi></tei:rs></tei:p>

      <tei:p><tei:handShift new="#EH"/>mit verbindlichstem Dank für die freundliche
          Erinnerung!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">What occasioned
          Schenker’s “remembrance” is unknown.</tei:note></tei:p>

      <tei:closer>
        <tei:address>
          <tei:addrLine rend="indent-60"><tei:handShift new="#printed"/>Wohllebengasse
            1</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:dateline><tei:handShift new="#EH"/><tei:date when="1898-12">Dez.
          898</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener/>

      <tei:p><tei:handShift new="#printed"/><tei:rs type="person" key="entity-000331"><tei:hi
            rend="bold">Dr. Eduard Hanslick</tei:hi></tei:rs></tei:p>

      <tei:p><tei:handShift new="#EH"/>with the most obliging thanks for your friendly
          remembrance!<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:p>

      <tei:closer>
        <tei:address>
          <tei:addrLine rend="indent-60"><tei:handShift new="#printed"/>Wohllebengasse
            1</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:dateline rend="indent-20"><tei:handShift new="#EH"/><tei:date when="1898-12">December
            1898</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>
