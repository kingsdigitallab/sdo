 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-008545">HeubergerR ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



   <dc:title>Handwritten calling card from Richard Heuberger to Schenker, dated April 24,
    1903</dc:title>

   <dcterms:created>1903-04-24T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-11-14</dcterms:dateSubmitted>
   <dc:description>Richard and Johanna Heuberger thank Schenker for his
    condolences.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000363">RHeuberger</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">
   <tei:div type="part_1">
    <tei:opener/>

    <tei:p><tei:handShift new="#print"/>Für die Theilnahme an ihrem schweren Verluste danken aus
     vollem Herzen<tei:note xml:id="r0001-fn01" type="editorial" place="foot">The nature of the loss
      referred to is unknown. (Schenker’s diary has no entries for January–June
     1903.)</tei:note></tei:p>

    <tei:closer>
     <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000363">Richard und Johanna
       Heuberger</tei:rs></tei:signed><tei:lb/>
     <tei:address>
      <tei:addrLine>Wien, <tei:date when="1903-04">April 1903</tei:date></tei:addrLine>
     </tei:address>
    </tei:closer>
   </tei:div>

   <tei:div type="part_2">
    <tei:opener>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
     <tei:salute><tei:handShift new="#RH"/>Lieber Herr <tei:rs type="person" key="entity-000632"
        >D<tei:hi rend="supralinear">r.</tei:hi></tei:rs></tei:salute>
    </tei:opener>


    <tei:p>Das so herzliche Telegram hat uns in unserem Schmerze aufrichtig wohl gethan. Nehmen Sie
     unseren innersten Dank</tei:p>

    <tei:closer>
     <tei:salute rend="indent-40">In treuer Verehrung</tei:salute>
     <tei:salute rend="indent-60">Ihr</tei:salute>
     <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000363">R
      Heuberger</tei:rs></tei:signed><tei:lb/>
     <tei:address>
      <tei:addrLine><tei:date when="1903-04-24">24. 4. 903</tei:date></tei:addrLine>
     </tei:address>
    </tei:closer>
   </tei:div>

  </tei:div>

  <tei:div type="translation">

   <tei:div type="part_1">
    <tei:opener/>

    <tei:p><tei:handShift new="#print"/>For your condolences at their grievous loss, thanks from the
     bottom of their hearts<tei:ptr corresp="#r0001-fn01" type="footnote"/> from</tei:p>

    <tei:closer>
     <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000363">Richard and Johanna
       Heuberger</tei:rs></tei:signed><tei:lb/>
     <tei:address>
      <tei:addrLine>Vienna, <tei:date when="1903-04">April 1903</tei:date></tei:addrLine>
     </tei:address>
    </tei:closer>
   </tei:div>

   <tei:div type="part_2">
    <tei:opener>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
     <tei:salute><tei:handShift new="#RH"/>Dear <tei:rs type="person" key="entity-000632">Dr.
        <tei:supplied reason="identity">Schenker</tei:supplied></tei:rs></tei:salute>
    </tei:opener>


    <tei:p>In our anguish, your very cordial telegram did us genuinely good. Accept our most sincere
     thanks.</tei:p>

    <tei:closer>
     <tei:salute rend="indent-40">In true admiration,</tei:salute>
     <tei:salute rend="indent-60">Your</tei:salute>
     <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000363">R
      Heuberger</tei:rs></tei:signed><tei:lb/>
     <tei:address>
      <tei:addrLine><tei:date when="1903-04-24">April 24, 1903</tei:date></tei:addrLine>
     </tei:address>
    </tei:closer>
   </tei:div>


  </tei:div>
