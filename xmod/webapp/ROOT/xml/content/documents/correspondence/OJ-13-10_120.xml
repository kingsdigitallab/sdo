  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Oppel to Schenker, dated December 31,
        1930</dc:title>

      <dcterms:created>1930-12-31T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-09-15</dcterms:dateSubmitted>
      <dc:description>The Oppels wish the Schenkers a happy and prosperous new
        year.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-000644">Ulrich Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:note type="editorial" place="inline">picture: ship with bridge over, captioned on
            recto, captioned: ”Kreuzer Emden im Kaiser-Wilhelm-Kanal unter d. Levensauer
            Hochbrücke”</tei:note><tei:lb/>
          <tei:fw type="envelope">
            <tei:milestone unit="folio" n="recto"/><tei:lb/>
            <tei:address>
              <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                  D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
              <tei:addrLine>Wien III / Östreich</tei:addrLine>
              <tei:addrLine>Keilgasse 8/<tei:hi rend="supralinear">12</tei:hi></tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark"> || <tei:gap reason="illegible"/> | <tei:gap reason="illegible"
              /> | 20-21 | * 1 * ||</tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:salute><tei:handShift new="#RO"/><tei:date when="1930-08-15">31. XII 30</tei:date>.
            Mein lieber Herr <tei:rs type="person" key="entity-000632">Professor
              Schenker</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt
              of this postcard is recorded in Schenker’s diary for January 3, 1931: “Von Oppel
              (Ansichtsk.): Wünsche” (“From Oppel (picture postcard):
            best wishes”).</tei:note></tei:salute>
        </tei:opener>

        <tei:p>Ihnen u. <tei:rs type="person" key="entity-000771">Ihrer lieben Frau</tei:rs> von uns
          allen ein glückliches u. gesundes Neujahr! Möge es uns allen nur Gutes bringen! </tei:p>

        <tei:p><tei:rs type="person" key="entity-003957">Walter</tei:rs> ist schon wieder in
          Altona.</tei:p>

        <tei:closer>
          <tei:salute>Mit den herzlichsten Grüssen</tei:salute>
          <tei:salute>Ihnen beiden</tei:salute>
          <tei:salute rend="indent-30">Ihr treuer</tei:salute>
          <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000643">Reinhard
              Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_2">
        <tei:opener/>

        <tei:p/>

        <tei:closer>
          <tei:salute><tei:handShift new="#UO"/>Herzl. Neujahrsgrüsse</tei:salute>
          <tei:salute>sendet Ihnen</tei:salute>
          <tei:signed rend="indent-30"><tei:rs type="person" key="entity-000644">Ulrich
              Oppel</tei:rs> (Panzerkreuzer)</tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>


    <tei:div type="translation">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:note type="editorial" place="inline">picture: ship with bridge over, captioned on
            recto: ”The cruiser Emden in the Kaiser-Wilhelm-Canal, beneath the Levensauer High
            Bridge”</tei:note><tei:lb/>
          <tei:fw type="envelope">
            <tei:milestone unit="folio" n="recto"/><tei:lb/>
            <tei:address>
              <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof.
                Heinrich Schenker</tei:addrLine>
              <tei:addrLine>Vienna III, Austria</tei:addrLine>
              <tei:addrLine>Keilgasse 8/<tei:hi rend="supralinear">12</tei:hi></tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark"> || <tei:gap reason="illegible"/> | <tei:gap reason="illegible"
              /> | 20-21 | * 1 * ||</tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:salute><tei:handShift new="#RO"/><tei:date when="1930-08-15">December 31,
              1930</tei:date>, My dear <tei:rs type="person" key="entity-000632">Professor
              Schenker</tei:rs>!<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
        </tei:opener>

        <tei:p>To you and <tei:rs type="person" key="entity-000771">your dear wife</tei:rs>, from
          all of us, a happy and healthy New Year!</tei:p>

        <tei:p><tei:rs type="person" key="entity-003957">Walter</tei:rs> has already gone back to
          Altona.</tei:p>

        <tei:closer>
          <tei:salute>With the most cordial greetings </tei:salute>
          <tei:salute>to the two of you,</tei:salute>
          <tei:salute rend="indent-30">Your faithful</tei:salute>
          <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000643">Reinhard
              Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_2">
        <tei:opener/>

        <tei:p/>

        <tei:closer>
          <tei:salute><tei:handShift new="#UO"/>Cordial New Year’s greetings</tei:salute>
          <tei:salute>to you, from</tei:salute>
          <tei:signed rend="indent-30"><tei:rs type="person" key="entity-000644">Ulrich
              Oppel</tei:rs> (armored cruiser)</tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>

  </sdo:record>
