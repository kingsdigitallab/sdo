  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Typewritten letter from Breitkopf &amp; Härtel to Schenker, dated July 1,
        1903</dc:title>

      <dcterms:created>1903-07-01T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-03</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel informs Schenker that in the year 1902/03 there have
        been no sales of his works.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:note type="editorial" place="inline">in a decorative printed letterhead:</tei:note>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#print"/><tei:hi rend="bold">BREITKOPF &amp;
              HÄRTEL</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
            DEN <tei:handShift new="#BHtp"/><tei:date when="1903-07-01">1. Juli
            1903</tei:date>.</tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#print"/>NÜRNBERGER STR.
            36.</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute><tei:handShift new="#BHtp"/>Sehr geehrter <tei:rs type="person"
            key="entity-000632">Herr</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">Wir beehren uns Ihnen mitzuteilen, dass bei der diesjährigen Abrechnung
        ein Absatz von Ihren Werken leider nicht zu verzeichnen gewesen ist. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">Hochachtungsvoll ergebenst</tei:salute>
        <tei:signed rend="indent-60">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHtp"/>Herrn Dr. Heinrich Schenker,</tei:addrLine>
          <tei:addrLine>Wien III.</tei:addrLine>
          <tei:addrLine><tei:sic>Richardgasse</tei:sic> 11.</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:note type="editorial" place="inline">in a decorative printed letterhead:</tei:note>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#print"/><tei:hi rend="bold">BREITKOPF &amp;
              HÄRTEL</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
              <tei:handShift new="#BHtp"/><tei:date when="1903-07-01">July 1,
            1903</tei:date></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#print"/>NÜRNBERGER STRASSE
            36</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute><tei:handShift new="#BHtp"/>Dear <tei:rs type="person" key="entity-000632"
            >Sir</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">We have the honor of informing you that, in this year’s settlement, no
        sales of your works have been recorded.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">Respectfully, <tei:supplied reason="clarity"
            >your</tei:supplied> most devoted</tei:salute>
        <tei:signed rend="indent-60">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHtp"/>Dr. Heinrich Schenker</tei:addrLine>
          <tei:addrLine>Vienna III</tei:addrLine>
          <tei:addrLine><tei:sic>Richardgasse</tei:sic> 11</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>
