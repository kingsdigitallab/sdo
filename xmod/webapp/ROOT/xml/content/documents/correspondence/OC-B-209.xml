  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Typewritten postcard from Breitkopf &amp; Härtel to Schenker, dated January 22,
        1916</dc:title>

      <dcterms:created>1916-01-22T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-20</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel is seeking a local photographer to make copies of the
        autograph of Chopin Op. 25.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/>
        <tei:fw type="header" rend="center"><tei:handShift new="print"/><tei:hi rend="bold"
            >POSTKARTE</tei:hi></tei:fw>
        <tei:fw type="header" rend="left"><tei:note type="editorial" place="inline">emblem: prowling
            bear, with “B &amp; H”</tei:note></tei:fw>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:handShift new="print"/>An Herr<tei:handShift new="BHtp"/>n Dr.
              Heinrich Schenker</tei:addrLine>
            <tei:addrLine rend="indent-20"><tei:handShift new="print"/>in <tei:handShift new="BHtp"
              />Wien III.</tei:addrLine>
            <tei:addrLine rend="indent-20"><tei:handShift new="print"/>Wohnung <tei:handShift
                new="BHtp"/>Reisnerstr. 38.</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG | 22 1. 16 | 9–10 N | * 13 d ||</tei:fw><tei:lb/><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
          <tei:address>
            <tei:addrLine><tei:handShift new="print"/><tei:hi rend="underline">BREITKOPF &amp;
                HÄRTEL</tei:hi></tei:addrLine>
            <tei:addrLine rend="indent-60">LEIPZIG, DEN <tei:handShift new="BHtp"/>22. I.
              1916.</tei:addrLine>
            <tei:addrLine rend="indent-60"><tei:handShift new="print"/>NÜRNBERGER STR.
              36.</tei:addrLine>
          </tei:address>
        </tei:fw><tei:lb/>
        <tei:byline><tei:handShift new="#BHsten"/><tei:hi rend="italic">M. V.</tei:hi></tei:byline><tei:lb/>
        <tei:salute rend="indent-20"><tei:handShift new="BHtp"/>Sehr geehrter Herr <tei:rs
            type="person" key="entity-000632">Doktor</tei:rs>!<tei:note xml:id="r0001-fn01"
            type="editorial" place="foot">Receipt of this postcard is recorded in Schenker’s diary
            for January 25, 1916: “Von Breitkopf u. Härtel Karte: sie fänden keinen Photographen in
            Leipzig, der das von mir gewünschte billige Verfahren kennt.” (“From Breitkopf &amp;
            Härtel, postcard: they could find no photographer in Leipzig, who knows the cheap
            [reproduction] process that I wish.”). — Schenker is requesting photographic copies of
            the autograph manuscript of the <tei:rs type="composition" key="entity-004724">Chopin
              Etudes, Op. 25</tei:rs>.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Wir bestätigen den Eingang Ihres Schreibens mit den beigefügten
          Belegen.<tei:note xml:id="r0001-fn02" type="editorial" place="foot">Writing of the letter
          concerned is recorded in Schenker’s diary for December 5 and 7, 1915: “Brief an Breitkopf
          u. Härtel, worin ich in 12 Punkten noch einmal mein Anliegen so deutlich als möglich
          präzisiere. Muster beigelegt. […] Brief an Breitkopf u. Härtel abgeschickt” (“Letter to
          Breitkopf &amp; Härtel in which I set out as precisely as possible once again my request
          in twelve points. Explanatory documents inclosed. [...] Letter to Breitkopf &amp; Härtel
          mailed off.”).</tei:note> Bis jetzt haben wir in <tei:rs type="place" key="entity-002479"
          >Leipzig</tei:rs> einen Photographen, der das billige Vorfahren kennt, noch nicht
        ausfindig machen können. Wir werden aber weiter suchen und Ihnen von dem Ergebnis Mitteilung
        machen.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Hochachtungsvoll ergeben</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed>
        <tei:address>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#BHtp"/>Herrn Dr. Heinrich Schenker</tei:addrLine>
          <tei:addrLine><tei:hi rend="underline">Wien III.</tei:hi></tei:addrLine>
          <tei:addrLine>Reisnerstr. 38.</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/>
        <tei:fw type="header" rend="center"><tei:handShift new="print"/><tei:hi rend="bold"
            >POSTCARD</tei:hi></tei:fw>
        <tei:fw type="header" rend="left"><tei:note type="editorial" place="inline">emblem: prowling
            bear, with “B &amp; H”</tei:note></tei:fw>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:handShift new="print"/>To: <tei:handShift new="BHtp"/>Dr. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine rend="indent-20"><tei:handShift new="print"/>in: <tei:handShift new="BHtp"
              />Vienna III</tei:addrLine>
            <tei:addrLine rend="indent-20"><tei:handShift new="print"/>Building: <tei:handShift
                new="BHtp"/>Reisnerstrasse 38</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| LEIPZIG | 22 1. 16 | 9–10 N | * 13 d ||</tei:fw><tei:lb/><tei:lb/>
          <tei:milestone unit="folio" n="verso"/>
          <tei:address>
            <tei:addrLine><tei:handShift new="print"/><tei:hi rend="underline">BREITKOPF &amp;
                HÄRTEL</tei:hi></tei:addrLine>
            <tei:addrLine rend="indent-60">LEIPZIG, <tei:handShift new="BHtp"/>January 22,
              1916</tei:addrLine>
            <tei:addrLine rend="indent-60"><tei:handShift new="print"/>NÜRNBERGER STRASSE
              36</tei:addrLine>
          </tei:address>
        </tei:fw><tei:lb/>
        <tei:byline><tei:handShift new="#BHsten"/><tei:hi rend="italic">M. V.</tei:hi></tei:byline><tei:lb/>
        <tei:salute rend="indent-20"><tei:handShift new="BHtp"/>Dear <tei:rs type="person"
            key="entity-000632">Dr. <tei:supplied reason="identity"
            >Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"
          /></tei:salute>
      </tei:opener>

      <tei:p rend="first">We acknowledge receipt of your letter with the enclosed documents.<tei:ptr
          corresp="#r0001-fn02" type="footnote"/> Up to now, we have not yet been able to find a
        photographer in <tei:rs type="place" key="entity-002479">Leipzig</tei:rs> who is familiar
        with the inexpensive process in question. However, we shall continue our search and inform
        you of the result.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Respectfully, <tei:supplied>your</tei:supplied>
          devoted</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed>
        <tei:address>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#BHtp"/>Dr. Heinrich Schenker</tei:addrLine>
          <tei:addrLine><tei:hi rend="underline">Vienna III</tei:hi></tei:addrLine>
          <tei:addrLine>Reisnerstrasse 38</tei:addrLine>
        </tei:address>
      </tei:closer>


    </tei:div>
