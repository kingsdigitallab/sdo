  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated May 17, 1913</dc:title>

      <dcterms:created>1913-05-17T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-24</dcterms:dateSubmitted>
      <dc:description>Hertzka has had to divert [Schenker's elucidatory edition of Op. 109] from
        Eberle [in Vienna] to UE's printing works in Leipzig; hence the delay in supplying
        galley-proofs.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-05-17">17. Mai 1913</tei:date>.</tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Wohlgeboren Herrn Prof. Dr. <tei:persName>Heinrich
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:placeName><tei:hi rend="underline"
              >Wien</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueW"/>Sehr geehrter Herr <tei:rs key="entity-000632"
            type="person">Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Receipt of this letter and Schenker’s reply (<tei:ref type="correspondence"
              cRef="WSLB-158">WSLB 158</tei:ref>) are recorded in Schenker's diary for May 18, 1913:
            “Antwort v. Hertzka, er habe das Manuscript nach Leipzig geschickt. Darauf sofort zurück
            Antwort gegeben, daß ich den Rechtsweg beschreiten werde, sobald der Vertrag verletzt u.
            mir dadurch ein Schaden erwachsen würde.” (“Reply from Hertzka: he has sent the
            manuscript to Leipzig. A reply to it made immediately, to the effect that I would take
            legal steps as soon as the contract is infringed and damages to me result from
            it.”).</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Die Aufklärung dafür, dass Sie noch keine Bürstenabzüge<tei:note
          xml:id="r0001-fn02" type="editorial" place="foot">Of <tei:rs type="work"
            key="entity-001734"><tei:title level="m">Die letzten fünf Sonaten von Beethoven … op.
              109</tei:title></tei:rs> (Vienna: UE, 1913).</tei:note> erhalten haben liegt darin,
        dass ich die Arbeit <tei:rs type="organization" key="entity-002402">Eberle</tei:rs>
        wegnehmen musste und unserer <tei:rs type="place" key="entity-002479">Leipzig</tei:rs>er
        Druckerei übergeben habe. Durch diesen Umstand ist die Verzögerung entstanden und ich
        urgiere heute in <tei:rs type="place" key="entity-002479">Leipzig</tei:rs> raschere
        Erledigung. </tei:p>

      <tei:p rend="first">Jedenfalls besten Dank für Ihre <tei:add place="interlinear-above"
            ><tei:handShift new="#EH"/>im Interesse der Sache liegende</tei:add>
        <tei:handShift new="#TPueW"/>Urgenz und verbindlichste Grüsse</tei:p>

      <tei:closer>
        <tei:salute>von Ihrem in Hochschätzung</tei:salute>
        <tei:salute rend="indent-70">ergebener</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Josef Aibl Publishers &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-05-17">May 17, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Prof. <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:placeName><tei:hi rend="underline"
              >Vienna</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueW"/>Dear <tei:rs key="entity-000632" type="person">Dr.
              <tei:supplied reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">The reason why you have so far received no galley-proofs<tei:ptr
          corresp="#r0001-fn02" type="footnote"/> is that I had to take the work away from <tei:rs
          type="organization" key="entity-002402">Eberle</tei:rs>, and have passed it on to our
          <tei:rs type="place" key="entity-002479">Leipzig</tei:rs> printing works. It is this
        situation that has given rise to the delay, and I am today urging upon <tei:rs type="place"
          key="entity-002479">Leipzig</tei:rs> a speedier handling <tei:supplied reason="clarity">of
          the work</tei:supplied>. </tei:p>

      <tei:p rend="first">In any case, many thanks for your urgency <tei:add
          place="interlinear-above"><tei:handShift new="#EH"/>in the best interests of the
          matter</tei:add>, <tei:handShift new="#TPueW"/>and sincere greetings,</tei:p>

      <tei:closer>
        <tei:salute>with kind regards,</tei:salute>
        <tei:salute rend="indent-70">Your devoted</tei:salute>
        <tei:signed rend="indent-80"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
