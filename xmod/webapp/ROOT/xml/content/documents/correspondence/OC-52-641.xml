      <dc:title>Handwritten receipt from Walter Mühlau to the Musikwissenschaftlisches Seminar Kiel,
        dated January 13, 1925</dc:title>

      <dcterms:created>1925-01-13T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-07-22</dcterms:dateSubmitted>
      <dc:description>Receipt for payment by the Musikwissenschaftliches Seminar, Kiel for ten
        issues of Der Tonmille.</dc:description>
      <dc:subject/>


    </sdo:itemDesc>

    <tei:div type="transcription">

