  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">postcard</tei:rs>



      <dc:title>Handwritten and typewritten postcard from UE to Schenker, dated March 28,
        1913</dc:title>

      <dcterms:created>1913-03-28T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-23</dcterms:dateSubmitted>
      <dc:description>Emil Hertzka is currently away.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>UNIVERSAL-EDITION, A.-G.</tei:addrLine>
          <tei:addrLine>WIEN, I, REICHSRATSSTRASSE 9</tei:addrLine>
        </tei:address>
        <tei:address>
          <tei:addrLine><tei:handShift new="#unkUE"/>Wohlgeboren Herrn Professor D<tei:hi
              rend="supralinear">r.</tei:hi> Heinr. Schenker</tei:addrLine>
          <tei:addrLine rend="indent-40">Wien III. </tei:addrLine>
          <tei:addrLine rend="indent-40">Reisnerstr. 38</tei:addrLine>
        </tei:address>
        <tei:fw type="postmark">|| 1/3 WIEN | 28.IX.13 | * 8 * ||</tei:fw><tei:lb/><tei:lb/>
        <tei:milestone unit="folio" n="verso"/>
        <tei:salute><tei:handShift new="#TPue"/>Sehr geehrter Herr <tei:rs type="person"
            key="entity-000632">Professor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Receipt of this postcard is not recorded in Schenker’s
          diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Nachdem unser Herr <tei:rs type="person" key="entity-000356">Direktor
          Hertzka</tei:rs> gegenwärtig verreist ist, bitten wir Sie, sich mit der Erledigung Ihres
          Werten<tei:note xml:id="r0001-fn02" type="editorial" place="foot">= <tei:ref
            type="correspondence" cRef="WSLB-150">WSLB 150</tei:ref>, March 28, 1913. </tei:note>
        einige <tei:handShift new="#unkUE"/>Tage <tei:handShift new="#TPue"/>gedulden zu wollen und
        zeichnen</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-50"><tei:rs key="entity-002408" type="organization"
            >Universal-Edition A-G.</tei:rs></tei:signed><tei:lb/>
        <tei:dateline>Wien, <tei:handShift new="#unkUE"/><tei:date when="1913-03-28">28. März
            1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>UNIVERSAL EDITION &amp; Co.</tei:addrLine>
          <tei:addrLine>VIENNA I, REICHSRATSSTRASSE 9</tei:addrLine>
        </tei:address>
        <tei:address>
          <tei:addrLine><tei:handShift new="#unkUE"/>Professor Heinrich Schenker</tei:addrLine>
          <tei:addrLine rend="indent-40">Vienna III</tei:addrLine>
          <tei:addrLine rend="indent-40">Reisnerstraße 38</tei:addrLine>
        </tei:address>
        <tei:fw type="postmark">|| 1/3 VIENNA | 28.IX.13 | * 8 * ||</tei:fw><tei:lb/><tei:lb/>
        <tei:milestone unit="folio" n="verso"/>
        <tei:salute><tei:handShift new="#TPue"/>Dear <tei:rs type="person" key="entity-000632"
            >Professor</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">Since our <tei:rs type="person" key="entity-000356">Director
          Hertzka</tei:rs> is currently away, we ask you to be patient for a few <tei:handShift
          new="#unkUE"/>days <tei:handShift new="#TPue"/>for your esteemed communication<tei:ptr
          corresp="#r0001-fn02" type="footnote"/> to be dealt with, and we remain</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">With kind regards,</tei:salute>
        <tei:signed rend="indent-50"><tei:rs key="entity-002408" type="organization">Universal
            Edition &amp; Co.</tei:rs></tei:signed><tei:lb/>
        <tei:dateline>Vienna, <tei:handShift new="#unkUE"/><tei:date when="1913-03-28">March 28,
            1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>
  </sdo:record>
