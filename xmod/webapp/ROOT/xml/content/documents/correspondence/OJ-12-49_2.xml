 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-005509">Gesellschaft der
    Musikfreunde ~ HSchenker</tei:rs>
   <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



   <dc:title>Stenographically written letter from the Gesellschaft der Musikfreunde to Schenker,
    dated November 16, 1908</dc:title>

   <dcterms:created>1908-11-16T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-26</dcterms:dateSubmitted>
   <dc:description>The Gesellschaft der Musikfreunde thanks Schenker for the gift of his Beitrag zur
    Ornamentik.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-002430">Gesellschaft der Musikfreunde</marcrel:correspondent>
   <marcrel:correspondent key="entity-000562">Eusebius Mandyczewski</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:address>
     <tei:addrLine><tei:handShift new="#pr"/>Gesellschaft <tei:note type="editorial" place="inline"
       >device: lyre overlaid by „der“</tei:note> Musikfreunde</tei:addrLine>
     <tei:addrLine>in Wien.</tei:addrLine>
     <tei:addrLine rend="indent-70">Wien, am <tei:handShift new="#GdMF-sten"/>16. Novbr.
      1908</tei:addrLine>
     <tei:addrLine rend="indent-70"><tei:handShift new="#pr"/>I., Giselastraße 12.</tei:addrLine>
    </tei:address><tei:lb/>
    <tei:salute><tei:handShift new="#GdMF-sten"/>Hochgeehrter Herr <tei:rs type="person"
      key="entity-000632">Doctor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
      place="foot">Receipt of this letter is recorded in Schenker’s diary for November 24, 1908:
      “Dankschreiben der Gesellsch. d. Musikfreunde für mein Geschenk der „Ornamentik.“ Indessen
      wurde ich von Dr. Mandyczewsky gebeten, das Geschenk zu machen, u. war meinerseits selbst
      durchaus nicht aufdringlich.” (“Letter of thanks from the Gesellschaft der Musikfreunde for
      presenting them with [a copy of] my <tei:title level="m">Ornamentation</tei:title>. However, I
      was asked by Dr. Mandyczewski to make the presentation; for my part, I was not at all
      importunate.”).</tei:note></tei:salute>
   </tei:opener>

   <tei:p rend="first">Die gefertigte <tei:hi rend="lateinschr">Direction</tei:hi> spricht Ihnen für
    das ihr geschenkweise überlassene, von Ihnen verfaßte Werk, <tei:cit>
     <tei:q><tei:rs type="work" key="entity-001721"><tei:title><tei:hi rend="lateinschr underline"
         >„Ein Beitrag zur Ornamentik“</tei:hi></tei:title></tei:rs><tei:lb/>
      <tei:rs type="work" key="entity-001721"><tei:title><tei:hi rend="lateinschr underline">Als
         Einführung zu Ph. Em. Bach’s Klavierwerken umfaßend auch die Ornamentik Haydn’s, Mozarts u.
         Beethovens</tei:hi></tei:title></tei:rs></tei:q>
    </tei:cit>
   </tei:p>

   <tei:p>den verbindlichsten Dank aus und beehrt sich, mitzuteilen, daß dasselbe dem <tei:rs
     type="organization" key="entity-002430"><tei:hi rend="lateinschr">Archiv</tei:hi> der
     Gesellschaft</tei:rs> einverleibt wurde.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-40">Mit vorzüglicher Hochachtung</tei:salute>
    <tei:salute rend="indent-40">Für die <tei:hi rend="lateinschr">Direction</tei:hi>
     der</tei:salute>
    <tei:signed><tei:note type="editorial" place="inline">oval stamp:</tei:note> || * <tei:rs
      type="organization" key="entity-002430">Gesellschaft der | Musikfreunde | in Wien</tei:rs> *
     ||</tei:signed><tei:lb/>
    <tei:signed><tei:handShift new="GdMF-unk"/><tei:note type="editorial" place="inline"
      >illegible</tei:note></tei:signed>
    <tei:signed rend="indent-70"><tei:handShift new="#EM"/><tei:rs type="person" key="entity-000562"
       >D<tei:hi rend="supralinear">r.</tei:hi> Mandyczewski</tei:rs></tei:signed>
    <tei:signed rend="indent-70">Bibliothekar.</tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine><tei:handShift new="#GdMF-sten"/>S<tei:hi rend="supralinear">r.</tei:hi>
      Hochwohlgeborener Herr D<tei:hi rend="supralinear">or.</tei:hi>
      <tei:hi rend="lateinschr">Heinrich Schenker</tei:hi></tei:addrLine>
     <tei:addrLine rend="indent-80"><tei:hi rend="lateinschr underline"
      >Wien.</tei:hi></tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:address>
     <tei:addrLine><tei:handShift new="#pr"/>Society <tei:note type="editorial" place="inline"
       >device: lyre overlaid by “of the”</tei:note> Friends of Music</tei:addrLine>
     <tei:addrLine>in Vienna</tei:addrLine>
     <tei:addrLine rend="indent-70">Vienna, <tei:handShift new="#GdMF-sten"/>November 16,
      1908</tei:addrLine>
     <tei:addrLine rend="indent-70"><tei:handShift new="#pr"/>I, Giselastraße 12</tei:addrLine>
    </tei:address><tei:lb/>
    <tei:salute><tei:handShift new="#GdMF-sten"/>Highly revered <tei:rs type="person"
      key="entity-000632">Dr. <tei:supplied reason="identity"
      >Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"
     /></tei:salute>
   </tei:opener>

   <tei:p rend="first">The undersigned Board expresses its most grateful thanks to you for the
    generous gift of the work: <tei:cit>
     <tei:q><tei:rs type="work" key="entity-001721"><tei:title level="m"><tei:hi rend="underline">A
         Contribution to the Study of Ornamentation</tei:hi></tei:title></tei:rs><tei:lb/>
      <tei:rs type="work" key="entity-001721"><tei:title level="m"><tei:hi rend="underline">As an
         Introduction to the Keyboard Works of C. P. E. Bach, encompassing also the Ornamentation of
         Haydn, Mozart and Beethoven</tei:hi></tei:title></tei:rs></tei:q>
    </tei:cit>
   </tei:p>

   <tei:p>written by you, and has the honor of informing you that this work will be accessioned into
    the <tei:rs type="organization" key="entity-002430">Archive of the Society</tei:rs>.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-40">Yours faithfully,</tei:salute>
    <tei:salute rend="indent-40">For the Board of the</tei:salute>
    <tei:signed><tei:note type="editorial" place="inline">oval stamp:</tei:note> || * <tei:rs
      type="organization" key="entity-002430">Society of the | Friends of Music | in Vienna</tei:rs>
     * ||</tei:signed><tei:lb/>
    <tei:signed><tei:handShift new="GdMF-unk"/><tei:note type="editorial" place="inline"
      >illegible</tei:note></tei:signed>
    <tei:signed rend="indent-70"><tei:handShift new="#EM"/><tei:rs type="person" key="entity-000562"
      >Dr. Mandyczewski</tei:rs></tei:signed>
    <tei:signed rend="indent-70">Librarian</tei:signed><tei:lb/>
    <tei:address>
     <tei:addrLine><tei:handShift new="#GdMF-sten"/>Dr. Heinrich Schenker, Esq.</tei:addrLine>
     <tei:addrLine rend="indent-80"><tei:hi rend="underline">Vienna</tei:hi></tei:addrLine>
    </tei:address>
   </tei:closer>

  </tei:div>
 </sdo:record>
