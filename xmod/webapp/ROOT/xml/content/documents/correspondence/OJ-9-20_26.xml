  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Handwritten letter from Breitkopf &amp; Härtel to Schenker, dated June 30,
        1901</dc:title>

      <dcterms:created>1901-06-30T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-02</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel inform Schenker that there were no sales of his Fünf
        Klavierstücke, Op. 4 in 1900/01.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:note type="editorial" place="inline">in a decorative printed letterhead:</tei:note>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#print"/><tei:hi rend="bold">Breitkopf &amp;
              Härtel</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
            den <tei:handShift new="#BHsten"/><tei:date when="1901-06-30">30. Jun.
            1901</tei:date>.</tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#print"/>Nürnberger Str.
            36.</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-40"><tei:handShift new="#BHsten"/>Herrn Dr. Heinr. <tei:hi
              rend="lateinschr">Schenker</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:hi rend="lateinschr underline">Wien
            III</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-70">Richardgasse 11</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute><tei:handShift new="#BHsten"/>Sehr geehrter <tei:rs type="person"
            key="entity-000632">Herr</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">Gelegentlich der diesjährigen Abrechnung über den Vertrieb Ihrer
        Komposition <tei:cit>
          <tei:q><tei:rs type="composition" key="entity-004560">Op. 4. <tei:title level="m">Fünf
                Klavierstücke</tei:title></tei:rs><tei:note xml:id="r0001-fn01" type="editorial"
              place="foot"><tei:title level="m">Fünf Klavierstücke</tei:title>, Op. 4 (Leipzig:
              Breitkopf &amp; Härtel, 1898), dedicated to <tei:rs type="person" key="entity-000150"
                >Eugen d’Albert</tei:rs>.</tei:note></tei:q>
        </tei:cit>
      </tei:p>

      <tei:p rend="first">ließ sich ein Verkauf leider nicht feststellen,<tei:note
          xml:id="r0001-fn02" type="editorial" place="foot">Schenker had received statements of
          account in 1899 and 1900, with payments of 40.50 Marks for 45 copies sold and 27 Marks for
          30 copies respectively, and would receive in 1902 37.50 Marks for 56 copies
          sold.</tei:note> was wir im beiderseitigen Interesse bedauern. Wir verfehlen nicht Sie
        vertragsmäßig hiervon in Kenntnis zu setzen mit dem Wunsche, daß es uns gelingen möge, Ihnen
        künftig günstiger hierüber berichten zu können. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-40">Hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:note type="editorial" place="inline">in a decorative printed letterhead:</tei:note>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#print"/><tei:hi rend="bold">Breitkopf &amp;
              Härtel</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
              <tei:handShift new="#BHsten"/><tei:date when="1901-06-30">June 30,
            1901</tei:date></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#print"/>Nürnberger Strasse
            36</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-40"><tei:handShift new="#BHsten"/>Dr. Heinrich
            Schenker</tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:hi rend="underline">Vienna III</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-70">Richardgasse 11</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute><tei:handShift new="#BHsten"/>Dear <tei:rs type="person" key="entity-000632"
            >Sir</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">On the occasion of this year’s statement of account for sales of your
        composition <tei:cit>
          <tei:q><tei:rs type="composition" key="entity-004560"><tei:title level="m">Five Pieces for
                Piano</tei:title>, Op. 4</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"
            /></tei:q>
        </tei:cit>
      </tei:p>

      <tei:p rend="first">unfortunately, not a single sale was made,<tei:ptr corresp="#r0001-fn02"
          type="footnote"/> which we regret for both our sakes. In compliance with the contract, we
        do not fail to inform you of this fact, and we hope that we will be able to bring you more
        favourable news on this in the future.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-40">With kind regards,</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed>
      </tei:closer>


    </tei:div>
  </sdo:record>
