  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002707">Österreichische
        Länderbank ~ HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002746">Bank document</tei:rs>




      <dc:title>Receipt for bank transfer from the Austrian Provincial Bank to Schenker, dated
        February 17, 1913</dc:title>

      <dcterms:created>1913-02-17T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-23</dcterms:dateSubmitted>
      <dc:description>Receipt for payment of 600 Kronen [from UE via Österreichische
        Länderbank]</dc:description>
      <dc:subject/>


      <marcrel:correspondent key="entity-000356">Hertzka</marcrel:correspondent>
      <marcrel:correspondent key="entity-002408">UE</marcrel:correspondent>
      <marcrel:correspondent key="entity-002467">Österreichische Länderbank</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:note type="editorial" place="inline">printed coupon with handwritten and stamped entries,
        all in a decorative frame</tei:note>
      <tei:lb/>
      <tei:note type="editorial" place="inline">Roman type = printed; Italic type = handwritten or
        stamped</tei:note>
      <tei:lb/>

      <tei:ab type="formpart" rend="printed">Abschnitt Kann vom Empfänger abgetrennt werden
        <tei:lb/></tei:ab>

      <tei:ab type="formpart" rend="printed">Stempel des Aufgabepostamtes<tei:supplied
          reason="punctuation">:</tei:supplied>
        <tei:lb/><tei:seg type="entry" rend="stamp">|| 3 WIEN | 17. II. 13 | *ANWSG. ANNAHME I. *
          ||</tei:seg>
      </tei:ab>

      <tei:ab type="formpart" rend="printed">Angewiesener Betrag<tei:supplied reason="punctuation"
          >:</tei:supplied>
        <tei:seg type="entry" rend="ms">600</tei:seg> K. – h.<tei:note xml:id="r0001-fn01"
          type="editorial" place="foot">Emil Hertzka (UE) notified Schenker in <tei:ref
            type="correspondence" cRef="OC-52-108">OC 52/108</tei:ref>, February 15, 1913, that he
          had authorized this payment. The actual transaction, which presumably took place at a
          branch of the bank, is not recorded in Schenker’s diary. — The sum of 600 Kronen
          represented Schenker’s first half-honorarium for <tei:rs type="work" key="entity-001735"
              ><tei:title level="m">Die letzten fünf Sonaten von Beethoven ... Op.
            110</tei:title></tei:rs>, “payable at the start of work on the sonata” as per his
          contract, <tei:ref type="correspondence" cRef="OC-52-494">OC 52/494</tei:ref>, August 25,
          1912.</tei:note></tei:ab>

      <tei:ab type="formpart" rend="printed">Name, Wohnort und Wohnung des Absenders<tei:supplied
          reason="punctuation">:</tei:supplied>
        <tei:lb/><tei:seg type="entry" rend="stamp"><tei:rs type="organization" key="entity-002467"
            >Kais. Kön. Privilegirte Österreichische Länderbank</tei:rs></tei:seg>
      </tei:ab>

    </tei:div>


    <tei:div type="translation">

      <tei:note type="editorial" place="inline">printed coupon with handwritten and stamped entries,
        all in a decorative frame</tei:note>
      <tei:lb/>
      <tei:note type="editorial" place="inline">Roman type = printed; Italic type = handwritten or
        stamped</tei:note>
      <tei:lb/>

      <tei:ab type="formpart" rend="printed">Portion can be detached by recipient <tei:lb/></tei:ab>

      <tei:ab type="formpart" rend="printed">Stamp of the issuing post office<tei:supplied
          reason="punctuation">:</tei:supplied>
        <tei:lb/><tei:seg type="entry" rend="stamp">|| 3 VIENNA | 17. II. 13 | * TRANSFER
          ACCEPTANCE. * ||</tei:seg>
      </tei:ab>

      <tei:ab type="formpart" rend="printed">Sum transferred<tei:supplied reason="punctuation"
          >:</tei:supplied>
        <tei:seg type="entry" rend="ms">600</tei:seg> Kronen – Heller<tei:ptr corresp="#r0001-fn01"
          type="footnote"/></tei:ab>

      <tei:ab type="formpart" rend="printed">Name, place and address of the sender<tei:supplied
          reason="punctuation">:</tei:supplied>
        <tei:lb/><tei:seg type="entry" rend="stamp"><tei:rs type="organization" key="entity-002467"
            >Imperial-Royal privileged Austrian Provincial Bank</tei:rs></tei:seg>
      </tei:ab>


    </tei:div>

