  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Oppel to Schenker, dated January 13, 1926</dc:title>

      <dcterms:created>1926-01-13T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-07-23</dcterms:dateSubmitted>
      <dc:description>Oppel shares his thoughts on recent writings on Bach, including books by
        Wilhelm Werker and Fritz Jöde.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="header" rend="center"><tei:hi rend="bold">Postkarte</tei:hi></tei:fw><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine>Wien III / Östreich</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| KIEL | 13.1.26. | 6-7 N | 8 1 9 ||</tei:fw>
          <tei:lb/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#RO"/><tei:rs type="place" key="entity-002757"
                >Kiel</tei:rs>, <tei:date when="1924-12-31">13. I 26</tei:date>. Feldstr 77<tei:hi
                rend="supralinear">IV</tei:hi></tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute>Mein lieber Herr <tei:rs type="person" key="entity-000632"
            >Schenker</tei:rs><tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this postcard is recorded in Schenker’s diary for January 15, 1926: “Von Dr. Oppel (K):
            verspricht, das Buch von Jöde zu schicken u. nennt das Datum seiner Abhandlung.” (“From
            Dr. Oppel (postcard): promises to send Jöde's book, and gives the date of his essay.”).
            — Paragraph-breaks are editorial, based on em-dashes in the
          original.</tei:note></tei:salute>
      </tei:opener>

      <tei:p>ja, <tei:rs type="person" key="entity-000959">Werker</tei:rs> ist nichts, leere
          Mechanik.<tei:note xml:id="r0001-fn02" type="editorial" place="foot">The return of
          Werker’s study of Bach’s <tei:title level="m">Well-tempered Clavier</tei:title> is
          recorded in Schenker’s diary for January 11, 1926: “Nach Tisch an Oppel recomm. Werker u.
          die Abhandlung zurück” (“After lunch, to Oppel, by registered post, Werker and [Oppel's]
          essay returned”).</tei:note> M. Aufsatz stand im <tei:bibl><tei:rs type="journal"
            key="entity-002536"><tei:title>Bachjahrbuch</tei:title></tei:rs>
          <tei:hi rend="underline">18. Jahrgg 1921</tei:hi></tei:bibl>. – </tei:p>

      <tei:p><tei:rs type="person" key="entity-000951">Dr Weisse</tei:rs> hat noch nicht geschr,
        ebensowenig <tei:rs type="person" key="entity-000971">Wittgenstein</tei:rs>. – </tei:p>

      <tei:p>Jetzt ist erschienen: <tei:bibl><tei:author><tei:rs type="person" key="entity-000405"
                ><tei:hi rend="underline">Fritz Jöde</tei:hi></tei:rs></tei:author>: <tei:title>die
            Kunst</tei:title>
          <tei:milestone unit="folio" n="verso"/>
          <tei:title>Bach’s, dargestellt a. s. Inventionen</tei:title>, (gut, in Anlehnung an
            <tei:rs type="person" key="entity-000326">Halm</tei:rs>, u <tei:rs type="person"
            key="entity-000495">Kurth</tei:rs>) Verlag Kallmayr, Wolfenbüttel, 1926</tei:bibl>; er
        führt darin auch mit <tei:rs type="person" key="entity-000695">Reger</tei:rs> ab. Wenn ichs
        ausgelesen, schicke ich Ihnen. Im allgem. habe ich jetzt den Eindruck von allen
          Publik<tei:supplied reason="abbreviation">ationen</tei:supplied> bei uns, dass man doch
        überall v. <tei:rs type="person" key="entity-000712">Riemann</tei:rs> abrückt, u. <tei:rs
          type="person" key="entity-000484">Kretzschmar</tei:rs>
        <tei:add place="interlinear-above">etc</tei:add>, u. dass eine gesunde Auffassung v. Musik
        wieder l<tei:supplied>an</tei:supplied>gs<tei:supplied>a</tei:supplied>m Platz <tei:unclear
          reason="reading">macht</tei:unclear>. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">Mit herzl. Grüssen Ihnen beiden </tei:salute>
        <tei:salute rend="indent-20">Ihr treuer</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643"
          >RO</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="header" rend="center"><tei:hi rend="bold">Postcard</tei:hi></tei:fw><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine>Vienna III, Austria</tei:addrLine>
            <tei:addrLine>Keilgasse 8</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| KIEL | 13.1.26. | 6-7 N | 8 1 9 ||</tei:fw>
          <tei:lb/>
          <tei:address>
            <tei:addrLine><tei:handShift new="#RO"/><tei:rs type="place" key="entity-002757"
                >Kiel</tei:rs>, <tei:date when="1924-12-31">January 13, 1926</tei:date>. Feldstr
              77/4</tei:addrLine>
          </tei:address>
        </tei:fw>
        <tei:salute>My dear Mr. <tei:rs type="person" key="entity-000632">Schenker,</tei:rs><tei:ptr
            corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>Yes, <tei:rs type="person" key="entity-000959">Werker</tei:rs> is nothing, empty
          mechanics.<tei:ptr corresp="#r0001-fn02" type="footnote"/> My article was published in the
            <tei:bibl><tei:rs type="journal" key="entity-002536"><tei:title level="j"
              >Bach-Jahrbuch</tei:title></tei:rs>, <tei:hi rend="underline">vol. 18
          (1921)</tei:hi></tei:bibl>. – </tei:p>

      <tei:p><tei:rs type="person" key="entity-000951">Dr. Weisse</tei:rs> has not yet written, nor
        has <tei:rs type="person" key="entity-000971">Wittgenstein</tei:rs>. –</tei:p>

      <tei:p><tei:bibl><tei:author><tei:rs type="person" key="entity-000405"><tei:hi
                rend="underline">Fritz Jöde</tei:hi></tei:rs></tei:author>’s <tei:title level="m"
            >Die Kunst</tei:title>
          <tei:milestone unit="folio" n="verso"/>
          <tei:title level="m">Bachs, dargestellt an seinen Inventionen</tei:title> (Wolfenbüttel:
          Kallmeyer, 1926)</tei:bibl> is good in comparison to <tei:rs type="person"
          key="entity-000326">Halm</tei:rs> and <tei:rs type="person" key="entity-000495"
          >Kurth</tei:rs>; he also deals dismissively with <tei:rs type="person" key="entity-000695"
          >Reger</tei:rs>. When I have finished reading it, I shall send it to you. In general, I
        now have the impression that all our publications are moving away from <tei:rs type="person"
          key="entity-000712">Riemann</tei:rs> and <tei:rs type="person" key="entity-000484"
          >Kretzschmar</tei:rs>, <tei:add place="interlinear-above">etc.</tei:add>, and that a
        healthy interpretation of music is slowly emerging.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-10">With cordial greetings to the two of you,</tei:salute>
        <tei:salute rend="indent-20">Your faithful</tei:salute>
        <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643"
          >RO</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
