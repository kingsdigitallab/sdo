  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Handwritten letter from Breitkopf &amp; Härtel to Schenker, dated April 23,
        1901</dc:title>

      <dcterms:created>1901-04-23T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-02</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel agree to supply Schenker with complimentary copies of
        any works he needs.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:note type="editorial" place="inline">in a decorative printed letterhead:</tei:note>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#print"/><tei:hi rend="bold">BREITKOPF &amp;
              HÄRTEL</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
            DEN <tei:handShift new="#BHsten"/><tei:date when="1901-04-23">23. April
            1901</tei:date>.</tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#print"/>NÜRNBERGER STR.
            36.</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute><tei:handShift new="#BHsten"/>Sehr geehrter <tei:rs type="person"
            key="entity-000632">Herr</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">Die uns von Ihnen zuviel gezahlten 6 M hatten wir Ihrem Konto
        gutgeschrieben, es ist aber nach Ihrer gefälligen Zuschrift vom <tei:date when="1901-04-19"
          >19. April</tei:date><tei:note xml:id="r0001-fn01" type="editorial" place="foot">The
          letter from Schenker is not known to survive. Neither Schenker’s letter nor that of
          Breitkopf is recorded in Schenker’s diary.</tei:note> besser, wenn wir sie Ihnen heute bar
        wieder zustellen. </tei:p>

      <tei:p rend="first">Übrigens sind wir sehr gern bereit, diejenigen Exemplare Ihrer Werke, die
        Sie zur Einführung für Künstler<tei:note xml:id="r0001-fn02" type="editorial" place="foot"
          >i.e. invitations to pianists and singers to perform his compositions.</tei:note>
        verwenden, Ihnen kostenfrei zu überlassen. Wir würden diese Exemplare bei der Abrechnung als
        Freiexemplare verbuchen. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-40">Hochachtungsvoll ergebenst</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten"/>Herrn Dr. H. Schenker</tei:addrLine>
          <tei:addrLine>Wien III/3. Reisnerstr. 38.</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:note type="editorial" place="inline">in a decorative printed letterhead:</tei:note>
          <tei:lb/>
          <tei:addrLine><tei:handShift new="#print"/><tei:hi rend="bold">BREITKOPF &amp;
              HÄRTEL</tei:hi></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>,
              <tei:handShift new="#BHsten"/><tei:date when="1901-04-23">April 23,
            1901</tei:date></tei:addrLine>
          <tei:addrLine rend="indent-50"><tei:handShift new="#print"/>NÜRNBERGER STRASSE
            36</tei:addrLine>
        </tei:address><tei:lb/>
        <tei:salute><tei:handShift new="#BHsten"/>Dear <tei:rs type="person" key="entity-000632"
            >Sir</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">The 6 marks you overpaid us have been credited to your account, but
        following your kind letter of <tei:date when="1901-04-19">April 19</tei:date>,<tei:ptr
          corresp="#r0001-fn01" type="footnote"/> it seems better to return the amount to you today
        in cash. </tei:p>

      <tei:p rend="first">Furthermore, we are glad to provide you with those copies of your works
        that you use for introduction to artists,<tei:ptr corresp="#r0001-fn02" type="footnote"/>
        free of charge. We would record these copies as complimentary copies in our records.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-40">Respectfully, <tei:supplied reason="clarity"
            >your</tei:supplied> most devoted,</tei:salute>
        <tei:signed rend="indent-50">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHsten"/>Dr. H. Schenker</tei:addrLine>
          <tei:addrLine>Vienna III/3, Reisnerstrasse 38</tei:addrLine>
        </tei:address>
      </tei:closer>


    </tei:div>
  </sdo:record>
