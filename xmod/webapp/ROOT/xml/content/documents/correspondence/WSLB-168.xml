    <tei:div type="translation">

      <tei:note type="editorial">Roman type = printed; Italic type = teletype</tei:note>
      <tei:lb/>
      <tei:note type="editorial">top-left panel:</tei:note>

      <tei:ab type="formpart" rend="printed">The dates in the official receipt of the telegram
        prepared using the teletype mean: 1. the name of the issuing officer; 2. the issue number,
        3. the number of words (perhaps in form of a fraction[?]), 4. the day of the week, and 5.
        the hour and minute of issue.</tei:ab>

      <tei:ab type="formpart" rend="printed">Official declarations:</tei:ab>

      <tei:note type="editorial">top-center panel:</tei:note>

      <tei:ab type="formpart" rend="printed">Category: <tei:handShift new="#unk"/><tei:seg
          type="entry" rend="ms">10</tei:seg> – Receipt number: <tei:handShift new="#unk"/><tei:seg
          type="entry" rend="ms">21/208</tei:seg></tei:ab>

      <tei:ab type="formpart" rend="printed">
        <tei:address>
