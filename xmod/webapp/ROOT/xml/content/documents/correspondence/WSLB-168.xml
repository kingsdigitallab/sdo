    <tei:div type="transcription">

      <tei:note type="editorial">Roman type = printed; Italic type = teletype</tei:note>
      <tei:lb/>
      <tei:note type="editorial">top-left panel:</tei:note>

      <tei:ab type="formpart" rend="printed">Die Daten im dienstlichen Eingange der mittels
        Typendruckapparates ausgefertigten Telegramme bedeuten: 1. den Namen des Aufgabeamtes, 2.
        die Aufgabenummer, 3. die Wortzahl (eventuell in Bruchform), 4. den Monatstag und 5. die
        Stunde und Minute der Aufgabe.</tei:ab>

      <tei:ab type="formpart" rend="printed">Dienstliche Angaben:</tei:ab>

      <tei:note type="editorial">top-center panel:</tei:note>

      <tei:ab type="formpart" rend="printed">Gattung: <tei:handShift new="#unk"/><tei:seg
          type="entry" rend="ms">10</tei:seg> – Eingangsnummer: <tei:handShift new="#unk"/><tei:seg
          type="entry" rend="ms">21/208</tei:seg></tei:ab>

      <tei:ab type="formpart" rend="printed">
        <tei:address>
          <tei:addrLine>
            <tei:seg type="entry" rend="ms"><tei:handShift new="#HS"/>direktor hertzka wien
              rm1</tei:seg>
          </tei:addrLine>
          <tei:addrLine><tei:seg type="entry" rend="ms">reichrathstrasse 9</tei:seg></tei:addrLine>
          <tei:addrLine><tei:seg type="entry" rend="stamp">universal edition
            =</tei:seg></tei:addrLine>
        </tei:address>
      </tei:ab>

      <tei:ab type="formpart" rend="printed">Telegramm aus <tei:note type="editorial" place="inline"
          >[blank]</tei:note></tei:ab>

      <tei:note type="editorial">top-right panel:</tei:note>

      <tei:ab type="formpart" rend="printed">Die Telegraphenverwaltung übernimmt hinsichtlich der
        ihr zur Beförderung oder Bestellung übergebenen Telegramme keine wie immer geartete
        Verantwortung.</tei:ab>

      <tei:ab type="formpart" rend="printed">Aufgenommen von ... auf Ltg. Nr. <tei:handShift
          new="#tel"/><tei:seg type="entry" rend="ms">J-208</tei:seg> am <tei:handShift new="#tel"
          /><tei:seg type="entry" rend="ms">19. JULI- N</tei:seg> durch <tei:handShift new="#tel"
          /><tei:seg type="entry" rend="ms">LOBPREIS</tei:seg></tei:ab>

      <tei:note type="editorial">middle panel:</tei:note>

      <tei:ab type="formpart" rend="printed"><tei:handShift new="#tel"/><tei:seg type="entry"
          rend="ms">de fondo 100 19/18 19 11 m = </tei:seg></tei:ab>

      <tei:note type="editorial">bottom panel:</tei:note>

      <tei:ab type="formpart" rend="printed">
        <tei:seg type="entry" rend="ms"><tei:hi rend="bold">notentext und wichtiger brief<tei:note xml:id="r0001-fn01" type="editorial" place="foot">= <tei:ref type="correspondence" cRef="WSLB-167">WSLB 167</tei:ref>, July 19, 1913. </tei:note>
            unterwegs urgiret dringendst<tei:lb/> correkturen schenker ="</tei:hi>
        </tei:seg>
      </tei:ab>

      <tei:closer>
        <tei:fw type="footer">D. S. Nr. 759. (.1910.)</tei:fw>
      </tei:closer>

