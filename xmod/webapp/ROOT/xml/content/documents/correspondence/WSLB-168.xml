      <tei:note type="editorial">top-right panel:</tei:note>

      <tei:ab type="formpart" rend="printed">The telegram administration accepts no responsibility
        whatsoever for the telegrams givien to them for transmission or delivery.</tei:ab>

      <tei:ab type="formpart" rend="printed">Received from ... on line no. <tei:handShift new="#tel"
          /><tei:seg type="entry" rend="ms">J-208</tei:seg> on the <tei:handShift new="#tel"/><tei:seg
          type="entry" rend="ms">19TH JULY- A.M.</tei:seg> via <tei:handShift new="#tel"/><tei:seg
          type="entry" rend="ms">LOBPREIS</tei:seg></tei:ab>

      <tei:note type="editorial">middle panel:</tei:note>

      <tei:ab type="formpart" rend="printed"><tei:handShift new="#tel"/><tei:seg type="entry"
