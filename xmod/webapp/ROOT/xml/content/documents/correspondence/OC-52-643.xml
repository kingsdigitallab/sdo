  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-008513">MühlauWG ~
        ROppel</tei:rs>
      <tei:rs key="entity-005447" type="corr-item-type" role="corr-item-type">Receipt</tei:rs>


      <dc:title>Handwritten receipt from Walter Mühlau to “Herr Timm,” dated March 15, 1925</dc:title>

      <dcterms:created>1925-03-15T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-07-23</dcterms:dateSubmitted>
      <dc:description>Receipt for payment by Herr Timm for issues 7-10 of Der
        Tonwille.</dc:description>
      <dc:subject/>


    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:note type="editorial" place="inline">Roman type = printed; Italic type = handwritten
          (by a Mühlau employee)</tei:note><tei:lb/>
        <tei:note type="editorial" place="inline">left panel, printed sideways:</tei:note><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/><tei:rs type="place" key="entity-008512"
              >Walter G. Mühlau</tei:rs></tei:addrLine>
          <tei:addrLine>Buch- und Musikalienhandlung</tei:addrLine>
          <tei:addrLine>Kiel, Brunswiker Straße 29 a</tei:addrLine>
        </tei:address>
      </tei:opener>

      <tei:note type="editorial" place="inline">main panel:</tei:note>
      <tei:lb/>

      <tei:byline rend="indent-80"><tei:handShift new="#printed"/>Nr. <tei:handShift new="#unkWM"
          /><tei:note type="editorial" place="inline">blank</tei:note></tei:byline>
      <tei:lb/>

      <tei:fw type="header" rend="left"><tei:handShift new="#printed"/><tei:hi rend="bold"
          >Quittung</tei:hi><tei:note xml:id="r0001-fn01" type="editorial" place="foot">This receipt
          is one of three from the Walter Mühlau store in Kiel that are preserved, the others being
            <tei:ref type="correspondence" cRef="OC-52-641">OC 52/641</tei:ref> and <tei:ref
            type="correspondence" cRef="OC-52-642">OC 52/642</tei:ref>, for payments for issues 1–10
          by the Musikwissenschaftliches Seminar, Kiel on January 13, and 7, 8/9, and 10 by Oppel
          himself on March 11. Oppel had been aiming to recruit twenty new subscribers to <tei:title
            level="j">Der Tonwille</tei:title>, as part of a push on Schenker’s part, in which he
          enlisted many of his pupils, to increase sales of the work. These three receipts were
          evidence sent to Schenker of Oppel’s efforts on this front.</tei:note></tei:fw>
      <tei:lb/>

      <tei:ab rend="printed">Mark <tei:hi rend="ms">Fünf und 50 gr</tei:hi></tei:ab>
      <tei:lb/>

      <tei:ab rend="printed">Von <tei:hi rend="ms">Herrn Timm</tei:hi></tei:ab>
      <tei:lb/>

      <tei:ab rend="printed">für <tei:hi rend="ms">1 Schenker <tei:rs type="work"
            key="entity-001739">Tonwille</tei:rs></tei:hi></tei:ab>

      <tei:ab>
        <tei:table rows="2" cols="4">
          <tei:row role="data">
            <tei:cell role="data"><tei:hi rend="italic">H.</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">7</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">8/9</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">10</tei:hi></tei:cell>
          </tei:row>

          <tei:row role="data">
            <tei:cell role="data"/>
            <tei:cell role="data"><tei:hi rend="italic">1.50</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">2.–</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">1.52</tei:hi></tei:cell>
          </tei:row>
        </tei:table>
      </tei:ab>
      <tei:lb/>

      <tei:ab rend="printed">erhalten zu haben, bescheinigt hiermit</tei:ab>
      <tei:lb/>

      <tei:closer>
        <tei:signed><tei:handShift new="#MN"/><tei:hi rend="italic"><tei:unclear reason="reading"
              >Md</tei:unclear> Noack</tei:hi></tei:signed>
        <tei:signed><tei:handShift new="#printed"/><tei:rs type="place" key="entity-008512">Walter
            G. Mühlau</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine>Kiel, den <tei:handShift new="#unkWM"/><tei:hi rend="italic"><tei:date
            when="1925-03-15">15. III 1925</tei:date></tei:hi></tei:addrLine>
          <tei:addrLine><tei:handShift new="#printed"/>Brunswiker Straße 29 a</tei:addrLine>
          <tei:addrLine>Fernsprecher 6220</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>



    <tei:div type="translation">

      <tei:opener>
        <tei:note type="editorial" place="inline">Roman type = printed; Italic type = handwritten
          (by a Mühlau employee)</tei:note><tei:lb/>
        <tei:note type="editorial" place="inline">left panel, printed sideways:</tei:note><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/><tei:rs type="place" key="entity-008512"
              >Walter G. Mühlau</tei:rs></tei:addrLine>
          <tei:addrLine>Book and Music Store</tei:addrLine>
          <tei:addrLine>Kiel, Brunswiker Straße 29 a</tei:addrLine>
        </tei:address>
      </tei:opener>

      <tei:note type="editorial" place="inline">main panel:</tei:note>
      <tei:lb/>

      <tei:byline rend="indent-80"><tei:handShift new="#printed"/>No. <tei:note type="editorial" place="inline">blank</tei:note></tei:byline>
      <tei:lb/>

      <tei:fw type="header" rend="left"><tei:handShift new="#printed"/><tei:hi rend="bold"
          >Receipt</tei:hi><tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:fw>
      <tei:lb/>

      <tei:ab rend="printed">Marks <tei:hi rend="ms">Five and 50 groschen</tei:hi></tei:ab>
      <tei:lb/>

      <tei:ab rend="printed">from <tei:hi rend="ms">Mr. Timm</tei:hi></tei:ab>
      <tei:lb/>

      <tei:ab rend="printed">for <tei:hi rend="ms">1 Schenker <tei:rs type="work"
            key="entity-001739">Tonwille</tei:rs></tei:hi></tei:ab>

      <tei:ab>
        <tei:table rows="2" cols="4">
          <tei:row role="data">
            <tei:cell role="data"><tei:hi rend="italic">issues</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">7</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">8/9</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">10</tei:hi></tei:cell>
          </tei:row>

          <tei:row role="data">
            <tei:cell role="data"/>
            <tei:cell role="data"><tei:hi rend="italic">1.50</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">2.–</tei:hi></tei:cell>
            <tei:cell role="data"><tei:hi rend="italic">1.52</tei:hi></tei:cell>
          </tei:row>
        </tei:table>
      </tei:ab>
      <tei:lb/>

      <tei:ab rend="printed">has been received and is attested hereto</tei:ab>
      <tei:lb/>

      <tei:closer>
        <tei:signed><tei:handShift new="#MN"/><tei:hi rend="italic"><tei:unclear
              reason="original_unclear">Md</tei:unclear> Noack</tei:hi></tei:signed>
        <tei:signed><tei:handShift new="#printed"/><tei:rs type="place" key="entity-008512">Walter
            G. Mühlau</tei:rs></tei:signed><tei:lb/>
        <tei:address>
          <tei:addrLine>Kiel, <tei:handShift new="#unkWM"/><tei:hi rend="italic"><tei:date
                when="1925-03-15">March 15, 1925</tei:date></tei:hi></tei:addrLine>
          <tei:addrLine><tei:handShift new="#printed"/>Brunswiker Straße 29 a</tei:addrLine>
          <tei:addrLine>Fernsprecher 6220</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>
