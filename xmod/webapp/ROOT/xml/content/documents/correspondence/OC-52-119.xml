  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Alfred Kalmus (UE) to Schenker, dated June 16,
        1913</dc:title>

      <dcterms:created>1913-06-16T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-07-04</dcterms:dateSubmitted>
      <dc:description>Universal Edition sends the next batch of galley-proofs [for Schenker's
        elucidatory edition of Op. 109], and explains why marginal bar-numbers will not appear
        marginally until the page-proofs.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000420">Alfred Kalmus</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#printed"/>VA <tei:handShift new="#TPueGP"/>GP</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPueGP"/><tei:date
            when="1913-06-16">16. Juni 1913</tei:date>.</tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-30">Wohlgeboren Herrn Prof. <tei:persName>Heinrich
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:placeName><tei:hi rend="underline"
              >Wien</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueGP"/>Sehr geehrter Herr <tei:rs key="entity-000632"
            type="person">Professor</tei:rs>,<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Receipt of this letter is not recorded in Schenker's diary.
          </tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Wir erlauben uns Ihnen gleichzeitig Spalte<tei:add
          place="interlinear-above">n</tei:add> 21–40 der <tei:rs type="work" key="entity-001734"
            ><tei:title>Beethoven Sonate op. 109</tei:title></tei:rs> samt Manuskript zu übersenden
        und erbitten uns dieselben nach Korrektur wieder retour. Wie die Druckerei uns mitteilt,
        werden die Marginalien erst im umbrochenen Satz eingefügt und nicht schon in der
        Spalten-Korrektur, weil sonst die Marginalien beim Umbruch neuerliche Korrektur verursachen,
        da sie ja immer am äusseren Rand der Seite stehen müssen und erst durch den Umbruch bestimmt
        werden kann, ob die Seite rechts oder links zu stehen kommt. </tei:p>

      <tei:p rend="first">Die Druckerei hat uns versprochen, Korrektur-Abzüge des restlichen Teiles
        bis Mitte dieser Woche einzusenden, sodass der weiteren Fertigstellung dann nichts mehr im
        Wege steht. </tei:p>

      <tei:p rend="first">Wir empfehlen uns</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-60"><tei:handShift new="#stamp"/>„<tei:rs type="organization"
            key="entity-002408">Universal-Edition</tei:rs>“ Actiengesellschaft</tei:signed>
        <tei:signed rend="indent-90"><tei:handShift new="#AK"/><tei:rs key="entity-000420"
            type="person">Kalmus</tei:rs></tei:signed>
      </tei:closer>

      <tei:postscript>
        <tei:p><tei:handShift new="#unkUE"/>Herr <tei:rs type="person" key="entity-000356">Direktor
            Hertzka</tei:rs> weilt zur Zeit in <tei:rs type="place" key="entity-002477"
            >Paris</tei:rs>.</tei:p>
      </tei:postscript>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Josef Aibl Publishers &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#printed"/>VA <tei:handShift new="#TPueGP"/>GP</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPueGP"/><tei:date
            when="1913-06-16">June 16, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-30">Prof. <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-70"><tei:placeName><tei:hi rend="underline"
              >Vienna</tei:hi></tei:placeName></tei:addrLine>
        </tei:address>
        <tei:salute><tei:handShift new="#TPueGP"/>Dear <tei:rs key="entity-000632" type="person"
            >Professor</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">We take the liberty of sending you simultaneously columns 21–40 of your
          <tei:rs type="work" key="entity-001734"><tei:title level="m">Beethoven Sonata
            Op.109</tei:title></tei:rs> together with the manuscript, and ask that you return the
        same to us after making corrections. As the printers inform us, the marginalia will not be
        included until page make-up, and not before then in the galley-proofs, because otherwise the
        marginalia <tei:supplied reason="clarity">would</tei:supplied> need correcting again at
        page-make-up stage, since they must always appear at the outer edge of the page, and only
        during the page make-up can it be determined whether the page falls on the right or left
        side.</tei:p>

      <tei:p rend="first">The printers have promised us they will send proof sheets for the
        remaining part by the middle of this week, so that nothing will then stand in the way of
        further completion.</tei:p>

      <tei:p rend="first">We remain,</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">With kind regards,</tei:salute>
        <tei:signed rend="indent-60"><tei:handShift new="#stamp"/><tei:rs type="organization"
            key="entity-002408">Universal Edition</tei:rs> &amp; Co.</tei:signed>
        <tei:signed rend="indent-90"><tei:handShift new="#AK"/><tei:rs key="entity-000420"
            type="person">Kalmus</tei:rs></tei:signed>
      </tei:closer>

      <tei:postscript>
        <tei:p><tei:handShift new="#unkUE"/><tei:rs type="person" key="entity-000356">Director
            Hertzka</tei:rs> is at present in <tei:rs type="place" key="entity-002477"
            >Paris</tei:rs>.</tei:p>
      </tei:postscript>

    </tei:div>
