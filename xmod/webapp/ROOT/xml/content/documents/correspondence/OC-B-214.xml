  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Typewritten letter from Breitkopf &amp; Härtel to Schenker, dated May 15,
        1913</dc:title>

      <dcterms:created>1913-05-15T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-21</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel informs Schenker of the re-use of the plates for Beethoven
        piano works.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:note type="editorial" place="inline">printed letterhead in a single
              rule-frame:</tei:note></tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline">prowling bear, with
                “<tei:handShift new="#pr"/>B &amp; H”</tei:note>
            <tei:hi rend="bold">BREITKOPF &amp; HÄRTEL</tei:hi></tei:addrLine>
          <tei:addrLine><tei:hi rend="bold">BERLIN BRÜSSEL * LEIPZIG * LONDON NEW
            YORK</tei:hi></tei:addrLine>
        </tei:address><tei:lb/>
        <tei:dateline><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>, <tei:handShift
            new="#BHtp"/>den <tei:date when="1913-05-15">15. Mai 1913.</tei:date></tei:dateline><tei:lb/>
        <tei:byline><tei:note type="editorial" place="inline">initialled in top-left
            corner:</tei:note><tei:handShift new="#BHtp"/>W. <tei:handShift new="#stamp"
          />(M)</tei:byline><tei:lb/><tei:lb/>
        <tei:salute rend="indent-20"><tei:handShift new="#BHtp"/>Sehr geehrter Herr <tei:rs
            type="person" key="entity-000632">Doktor</tei:rs>!<tei:note xml:id="r0001-fn01"
            type="editorial" place="foot">Receipt of this letter is not recorded in Schenker’s
            diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Auf Ihre gefällige Anfrage<tei:note xml:id="r0001-fn02" type="editorial"
          place="foot">Writing of this inquiry is not recorded in Schenker’s diary.</tei:note>
        beehren wir uns zu erwidern, dass zu der 1898 hergestellten Urtextausgabe von <tei:rs
          type="person" key="entity-000055">Beethoven</tei:rs> Klaviersonaten dieselben Platten
        verwendet wurden, die früher für die Gesamtausgabe von <tei:rs type="person"
          key="entity-000055">Beethoven</tei:rs>s Werken gedient haben.<tei:note xml:id="r0001-fn03"
          type="editorial" place="foot">“dieselben Platten verwendet wurden” and “für die
          Gesamtausgabe” (“the same plates used”, “were” and “for the complete edition”) underlined
          in pencil by Schenker.</tei:note> Herr Professor Dr. Krebs ist bei der Revision auf das
        Quellenmaterial zurückgegangen und hat in seinem jeden der 3 Bände beigegebenen
        Revisionsbericht ausfürhliche Auskunft gegeben. Ein Revisionsbericht zur Gesamtausgabe ist
        nicht erschienen.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">Hochachtungsvoll ergeben </tei:salute>
        <tei:signed rend="indent-60">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHtp"/>Herrn Dr. H. Schenker,</tei:addrLine>
          <tei:addrLine rend="indent-10"><tei:hi rend="underline">Wien III,</tei:hi></tei:addrLine>
          <tei:addrLine>Reisnerstr. 38.</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:note type="editorial" place="inline">printed letterhead in a single
              rule-frame:</tei:note></tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline">prowling bear, with
                “<tei:handShift new="#pr"/>B &amp; H”</tei:note>
            <tei:hi rend="bold">BREITKOPF &amp; HÄRTEL</tei:hi></tei:addrLine>
          <tei:addrLine><tei:hi rend="bold">BERLIN BRUSSELS * LEIPZIG * LONDON NEW
            YORK</tei:hi></tei:addrLine>
        </tei:address><tei:lb/>
        <tei:dateline><tei:rs type="place" key="entity-002479">LEIPZIG</tei:rs>, <tei:handShift
            new="#BHtp"/><tei:date when="1913-05-15">May 15, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:byline><tei:note type="editorial" place="inline">initialled in top-left
            corner:</tei:note><tei:handShift new="#BHtp"/>W. <tei:handShift new="#stamp"
          />(M)</tei:byline><tei:lb/><tei:lb/>
        <tei:salute rend="indent-20"><tei:handShift new="#BHtp"/>Dear <tei:rs type="person"
            key="entity-000632">Dr. <tei:supplied reason="identity"
            >Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"
          /></tei:salute>
      </tei:opener>

      <tei:p rend="first">In response to your kind inquiry,<tei:ptr corresp="#r0001-fn02"
          type="footnote"/> we have the honor of informing you that the same plates used for the
        1898 <tei:hi rend="italic">Urtext</tei:hi> edition of <tei:rs type="person"
          key="entity-000055">Beethoven</tei:rs>’s piano sonatas were the ones previously used for
        the complete edition of <tei:rs type="person" key="entity-000055">Beethoven</tei:rs>’s
          works.<tei:ptr corresp="#r0001-fn03" type="footnote"/> Professor Krebs referred to the
        source material during the revision and has provided detailed information in the editor’s
        report included in each of the three volumes. An editor’s report for the collected edition
        has not been published.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">Respectfully, <tei:supplied>your</tei:supplied> devoted </tei:salute>
        <tei:signed rend="indent-60">
          <tei:handShift new="#BH"/><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed><tei:lb/><tei:lb/>
        <tei:address>
          <tei:addrLine><tei:handShift new="#BHtp"/>Dr. H. Schenker</tei:addrLine>
          <tei:addrLine rend="indent-10"><tei:hi rend="underline">Vienna III</tei:hi></tei:addrLine>
          <tei:addrLine>Reisnerstrasse 38</tei:addrLine>
        </tei:address>
      </tei:closer>

    </tei:div>
