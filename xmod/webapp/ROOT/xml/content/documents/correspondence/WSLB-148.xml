  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002702">UE ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



      <dc:title>Handwritten postcard from Schenker to Hertzka (UE), dated February 24,
        1913</dc:title>

      <dcterms:created>1913-02-24T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-12</dcterms:dateSubmitted>
      <dc:description>Schenker asks Hertzka for an appointment in late February or early
        March.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000632">Heinrich Schenker</marcrel:correspondent>
      <marcrel:recipient key="entity-000356">Emil Hertzka</marcrel:recipient>
      <marcrel:recipient key="entity-002408">Universal Edition</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">Absender:</tei:supplied>
              <tei:handShift new="#HS"/><tei:hi rend="lateinschr">H Schenker</tei:hi>
            </tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">III, Reisnerstr. 38</tei:hi></tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">An:</tei:supplied> H <tei:hi
                rend="lateinschr">Director Emil Hertzka</tei:hi></tei:addrLine>
            <tei:addrLine><tei:hi rend="lateinschr">I, Reichsrathsstr.</tei:hi> 9</tei:addrLine>
            <tei:addrLine>„<tei:hi rend="lateinschr">Universal-Edition</tei:hi>“</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| <tei:gap reason="illegible"/> WIEN 16 | 25. II. 13 6 | <tei:gap
              reason="illegible"/> ||</tei:fw>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>Sehr geehrter Herr <tei:rs key="entity-000356"
            type="person">Direktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial"
            place="foot">Writing of this postcard is not recorded in Schenker’s
          diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p>Eine <tei:rs type="person" key="entity-000861">Schülerin</tei:rs><tei:note
          xml:id="r0001-fn02" type="editorial" place="foot">Mrs. Stirling was absent from lessons
          from February 28 through April 4 (lessonbook 1912/1913). </tei:note> von mir die <tei:hi
          rend="underline">Dienstag</tei:hi> u. <tei:hi rend="underline">Freitag</tei:hi>
          11–12<tei:hi rend="supralinear">h</tei:hi> zu mir kommt, fährt am 1<tei:hi
          rend="supralinear">ten</tei:hi> nach <tei:rs type="place" key="entity-004639"><tei:hi
            rend="lateinschr">Aegypten</tei:hi></tei:rs> für paar Wochen. Ich bitte Sie also, von
        diesem günstigen Zufall Gebrauch zu machen, u. mir zu schreiben, ob ich Sie z.B. schon am
          <tei:hi rend="underline">Freitag</tei:hi>
        <tei:hi rend="underline">28 <tei:hi rend="supralinear">d.M.</tei:hi></tei:hi> (die Dame
        reist Donnerstag), oder Dienstag den <tei:date when="1913-03-04">4. März</tei:date> in Ihrem
        Bureau <tei:hi rend="underline">um 11<tei:hi rend="supralinear">h</tei:hi></tei:hi> sprechen
          kann.<tei:note xml:id="r0001-fn03" type="editorial" place="foot">“28 <tei:hi
            rend="supralinear">d.M.</tei:hi>” ("28 of this month”) and “um 11<tei:hi
            rend="supralinear">h</tei:hi>“ (“at 11 a. m.”) both underlined in crayon, so either by
          Schenker or by the recipient.</tei:note></tei:p>

      <tei:closer>
        <tei:salute rend="indent20">Mit besten Grüßen</tei:salute>
        <tei:salute rend="indent-70">I<tei:supplied>h</tei:supplied>r
            ergeb<tei:supplied>ener</tei:supplied></tei:salute>
        <tei:signed rend="indent-50">
          <tei:rs key="entity-000632" type="person"><tei:hi rend="lateinschr">H
            Schenker</tei:hi></tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-02-24">24. 2. 1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:note type="editorial" place="inline">All in a decorative rule-frame</tei:note><tei:lb/>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">From:</tei:supplied>
              <tei:handShift new="#HS"/>H. Schenker </tei:addrLine>
            <tei:addrLine><tei:supplied reason="identity">Vienna</tei:supplied> III, Reisnerstraße
              38</tei:addrLine>
          </tei:address>
          <tei:address>
            <tei:addrLine><tei:supplied reason="clarity">To:</tei:supplied> Director Emil
              Hertzka</tei:addrLine>
            <tei:addrLine><tei:supplied reason="identity">Vienna</tei:supplied> I, Reichsrathsstraße
              9</tei:addrLine>
            <tei:addrLine>Universal Edition</tei:addrLine>
          </tei:address><tei:lb/>
          <tei:fw type="postmark">|| <tei:gap reason="illegible"/> VIENNA 16 | 25. II. 13 6 |
              <tei:gap reason="illegible"/> ||</tei:fw>
          <tei:milestone unit="folio" n="verso"/>
        </tei:fw>
        <tei:salute><tei:handShift new="#HS"/>Dear <tei:rs key="entity-000356" type="person"
            >Director</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>A <tei:rs type="person" key="entity-000861">female pupil</tei:rs> of mine<tei:ptr
          corresp="#r0001-fn02" type="footnote"/> who comes to me on <tei:hi rend="underline"
          >Tuesdays</tei:hi> and <tei:hi rend="underline">Fridays</tei:hi> 11–12 departs for <tei:rs
          type="place" key="entity-004639">Egypt</tei:rs> on <tei:supplied>March</tei:supplied> 1
        for a few weeks. So please take advantage of this fortunate turn of events and write to me
        whether I can speak with you e.g. as early as <tei:hi rend="underline">Friday
            <tei:supplied>February</tei:supplied> 28 of this month</tei:hi> (the lady travels on
        Thursday), or Tuesday <tei:date when="1913-03-04">March 4</tei:date> in your office at
          <tei:hi rend="underline">11 a. m.</tei:hi><tei:ptr corresp="#r0001-fn03" type="footnote"/>
      </tei:p>

      <tei:closer>
        <tei:salute rend="indent20">With best wishes</tei:salute>
        <tei:salute rend="indent-70">Your devoted</tei:salute>
        <tei:signed rend="indent-50">
          <tei:rs key="entity-000632" type="person">H. Schenker</tei:rs>
        </tei:signed><tei:lb/><tei:lb/>
        <tei:dateline><tei:date when="1913-02-24">February 24, 1913</tei:date></tei:dateline>
      </tei:closer>

    </tei:div>

