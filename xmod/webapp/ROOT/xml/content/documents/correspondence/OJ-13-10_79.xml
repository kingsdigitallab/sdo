  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten picture postcard from Ulrich, Walter and Reinhard Oppel to Schenker,
        dated August 7, 1929</dc:title>

      <dcterms:created>1929-08-07T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-08-22</dcterms:dateSubmitted>
      <dc:description>The Oppels send greetings from the city of Ulm.</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-000644">Ulrich Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-003957">Walter Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:note type="editorial" place="inline">picture: church with three spires, captioned:
            “Ulm a. D. Münster”</tei:note><tei:lb/>
          <tei:fw type="envelope">
            <tei:milestone unit="folio" n="recto"/><tei:lb/>
            <tei:address>
              <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof H.
                Schenker</tei:addrLine>
              <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
              <tei:addrLine>Galtür / Paznaun</tei:addrLine>
              <tei:addrLine>Tirol / Östr</tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark">
              <tei:note type="editorial" place="inline">illegible</tei:note></tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:dateline rend="indent-80"><tei:handShift new="#UO"/><tei:date when="1929-08-07">7.
              VIII. 29.</tei:date></tei:dateline>
          <tei:salute>Liebe <tei:rs type="person" key="entity-000771">Frau Professor</tei:rs> u.
              <tei:rs type="person" key="entity-000632">Herr Professor</tei:rs>,<tei:note
              xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this picture postcard is
              recorded in Schenker’s diary for August 8, 1929: “Von Oppel (Ansichtsk.): Grüße aus
              Ulm.” (“From Oppel (picture postcard): greetings from Ulm.”).</tei:note></tei:salute>
        </tei:opener>

        <tei:p>Eben sitzen wir in <tei:rs type="place" key="entity-002683">Ulm</tei:rs> beim
          Mittagessen, um unseren Hunger zu stillen, den man bei der Besteigung des Münsters
          bekommt. Aber es war sehr schön. Die Aussicht war grossartig. Auch der Innenraum hat uns
          prachtvoll gefallen. Heute Mittag geht’s weiter in Richtung <tei:rs type="place"
            key="entity-002495">Frankfurt</tei:rs>. </tei:p>

        <tei:closer>
          <tei:salute>Leben Sie wohl und</tei:salute>
          <tei:salute>seien Sie herzlichst gegrüsst</tei:salute>
          <tei:salute>von</tei:salute>
          <tei:signed><tei:rs type="person" key="entity-000644">Ulrich Oppel</tei:rs>.</tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_2">
        <tei:opener/>
        <tei:p/>
        <tei:closer>
          <tei:salute><tei:handShift new="#WO"/>Herzliche Grüße sendet Ihnen</tei:salute>
          <tei:signed><tei:rs type="person" key="entity-003957">Walter Oppel</tei:rs>.</tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_3">
        <tei:opener/>
        <tei:p/>
        <tei:closer>
          <tei:salute><tei:handShift new="#RO"/>herzl. Grüsse Ihnen beiden.</tei:salute>
          <tei:signed><tei:rs type="person" key="entity-000643">RO</tei:rs>.</tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>


    <tei:div type="translation">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:note type="editorial" place="inline">picture: church with three spires, captioned:
            “Ulm on the Danube. Minster”</tei:note><tei:lb/>
          <tei:fw type="envelope">
            <tei:milestone unit="folio" n="recto"/><tei:lb/>
            <tei:address>
              <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. H.
                Schenker</tei:addrLine>
              <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
              <tei:addrLine>Galtür, Paznaun</tei:addrLine>
              <tei:addrLine>Tyrol, Austria</tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark">
              <tei:note type="editorial" place="inline">illegible</tei:note></tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:dateline rend="indent-80"><tei:handShift new="#UO"/><tei:date when="1929-08-07"
              >August 7, 1929</tei:date></tei:dateline>
          <tei:salute>Dear <tei:rs type="person" key="entity-000632">Professor</tei:rs> and <tei:rs
              type="person" key="entity-000771">Mrs. </tei:rs>
            <tei:supplied reason="identity">Schenker</tei:supplied>,<tei:ptr corresp="#r0001-fn01"
              type="footnote"/></tei:salute>
        </tei:opener>

        <tei:p>We are just now having lunch in <tei:rs type="place" key="entity-002683"
          >Ulm</tei:rs>, to still the hunger one gets by climbing the church <tei:supplied
            reason="clarity">tower</tei:supplied>. But it was very beautiful. The view was
          magnificent. Even the interior made a magnificent impression on us. This afternoon we are
          travelling on in the direction of <tei:rs type="place" key="entity-002495"
            >Frankfurt</tei:rs>.</tei:p>

        <tei:closer>
          <tei:salute>Be well and accept</tei:salute>
          <tei:salute>the most cordial greetings</tei:salute>
          <tei:salute>from</tei:salute>
          <tei:signed><tei:rs type="person" key="entity-000644">Ulrich Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_2">
        <tei:opener/>
        <tei:p/>
        <tei:closer>
          <tei:salute><tei:handShift new="#WO"/>Cordial greetings to you from</tei:salute>
          <tei:signed><tei:rs type="person" key="entity-003957">Walter Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <tei:div type="part_3">
        <tei:opener/>
        <tei:p/>
        <tei:closer>
          <tei:salute><tei:handShift new="#RO"/>Cordial greetings to the two of you</tei:salute>
          <tei:signed><tei:rs type="person" key="entity-000643">RO</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>

