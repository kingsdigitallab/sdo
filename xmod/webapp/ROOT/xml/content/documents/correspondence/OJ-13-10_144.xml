  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>

      <dc:title>Handwritten postcard from Reinhard Oppel and others to Schenker, dated December 28,
        1931</dc:title>

      <dcterms:created>1931-12-28T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2026-02-13</dcterms:dateSubmitted>
      <dc:description>Oppel, his wife, and two of his sons send the Schenkers greetings for the New
        Year.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-000644">Ulrich Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-003957">Walter Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-005266">Elfriede Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >Postkarte</tei:hi></tei:fw><tei:lb/>
          <tei:fw type="envelope">
            <tei:address>
              <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                  D<tei:hi rend="supralinear">r</tei:hi> Heinrich Schenker</tei:addrLine>
              <tei:addrLine><tei:handShift new="#pr"/>in <tei:handShift new="#RO"/>Wien III /
                Östreich</tei:addrLine>
              <tei:addrLine>Keilgasse 8<tei:hi rend="supralinear">12</tei:hi></tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark"> || LEIPZIG <tei:gap reason="illegible"/> | 28. 12. 31. | * * e
              ||</tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:salute><tei:handShift new="#RO"/><tei:date when="1931-12-28">28. XII. 31</tei:date>.
            Mein lieber Herr <tei:rs type="person" key="entity-000632">Professor
              Schenker</tei:rs>,<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt
              of this postcard is recorded in Schenker’s diary for December 29, 1931: “Von Oppel
              (K.): das ganze Haus schickt Wünsche” (“From Oppel (postcard): the entire family sends
              greetings.”).</tei:note></tei:salute>
        </tei:opener>

        <tei:p>herzlichen Dank für den Weinachtsbrief und die guten Wünsche für uns alle!<tei:note
            xml:id="r0001-fn02" type="editorial" place="foot">Schenker’s diary for December 24
            records: “An Oppel (Br.): Erwiderung der Wünsche; über Weisse, Jonas, Furtwängler.” (“To
            Oppel (letter): reply to his greetings; about Weisse, Jonas, Furtwängler.).</tei:note>
          Wir haben ein paar schöne, friedliche Tage erlebt. Heute Abend führt <tei:rs type="person"
            key="entity-003957">Walter</tei:rs> wieder fort.</tei:p>

        <tei:closer>
          <tei:salute>Mit den herzlichsten Grüssen an Sie beide</tei:salute>
          <tei:salute rend="indent-40">Ihr treuer</tei:salute>
          <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
              Oppel</tei:rs> und</tei:signed>
          <tei:signed rend="indent-40">das „Licht“ <tei:rs type="person" key="entity-008523"
              >Bepo</tei:rs>.</tei:signed>
        </tei:closer>
      </tei:div>

      <!-- -->
      <!-- WALTER -->
      <!-- -->


      <tei:div type="part_2">
        <tei:opener>
          <tei:salute><tei:handShift new="#WO"/> Lieber Herr <tei:rs type="person"
              key="entity-000632">Professor</tei:rs>!</tei:salute>
        </tei:opener>

        <tei:p>Nun bin ich für ein paar Tage in unsrem <tei:rs type="place" key="entity-002479"
            >Leipzig</tei:rs>er Heim gewesen und muß heute Abend wieder nach <tei:rs type="place"
            key="entity-002589">Hamburg</tei:rs> zum morgigen Dienstantritt. Zu Haus ist es doch
          schöner als immer in der Fremde.</tei:p>

        <tei:closer>
          <tei:salute>Mit herzlichen Grüßen Ihnen und</tei:salute>
          <tei:salute><tei:rs type="person" key="entity-000771">Ihre Gattin</tei:rs></tei:salute>
          <tei:signed rend="indent-40"> der „Torpedo“ (<tei:rs type="person" key="entity-000644"
              >Walter</tei:rs>)</tei:signed>
        </tei:closer>
      </tei:div>

      <!-- -->
      <!-- ULRICH -->
      <!-- -->

      <tei:div type="part_3">
        <tei:opener>
          <tei:salute><tei:handShift new="#UO"/> Lieber Herr <tei:rs type="person"
              key="entity-000632">Professor</tei:rs>!</tei:salute>
        </tei:opener>

        <tei:p>Aus den Ferien recht herzlichen Grüße Ihnen und <tei:rs type="person"
            key="entity-000771">Ihrer Gattin</tei:rs>. Weihnachtstage waren recht nett zu Haus u. in
          Büttenfeld. Sonnabend geht es zurück nach <tei:rs type="place" key="entity-002501"
            >Berlin</tei:rs>. </tei:p>

        <tei:closer>
          <tei:salute>Ein recht frohes neues Jahr</tei:salute>
          <tei:salute>wünscht Ihnen beiden</tei:salute>
          <tei:salute rend="indent-30">Ihr</tei:salute>
          <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000644">Ulrich</tei:rs>
            („Panzerschiff“)</tei:signed>
        </tei:closer>
      </tei:div>


      <!-- -->
      <!-- ELFRIEDE -->
      <!-- -->


      <tei:div type="part_4">
        <tei:opener/>

        <tei:p/>

        <tei:closer>
          <tei:salute><tei:handShift new="#EO"/>Alles Gute fürs</tei:salute>
          <tei:salute>Neujahr und</tei:salute>
          <tei:salute>herzliche Grüße</tei:salute>
          <tei:signed>Frau <tei:rs type="person" key="entity-005266">Elfr.
            Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>


    <tei:div type="translation">

      <tei:div type="part_1">
        <tei:opener>
          <tei:milestone unit="folio" n="recto"/><tei:lb/>
          <tei:fw type="header" rend="center"><tei:handShift new="#pr"/><tei:hi rend="bold"
              >Postcard</tei:hi></tei:fw><tei:lb/>
          <tei:fw type="envelope">
            <tei:address>
              <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof.
                Heinrich Schenker</tei:addrLine>
              <tei:addrLine><tei:handShift new="#pr"/>in <tei:handShift new="#RO"/>Vienna III /
                Austria</tei:addrLine>
              <tei:addrLine>Keilgasse 8<tei:hi rend="supralinear">12</tei:hi></tei:addrLine>
            </tei:address>
            <tei:lb/>
            <tei:fw type="postmark"> || LEIPZIG <tei:gap reason="illegible"/> | 28. 12. 31. | * * e
              ||</tei:fw>
            <tei:lb/>
          </tei:fw>
          <tei:milestone unit="folio" n="verso"/><tei:lb/>
          <tei:salute><tei:handShift new="#RO"/><tei:date when="1931-12-28">December 28,
              1931</tei:date>. My dear <tei:rs type="person" key="entity-000632">Professor
              Schenker</tei:rs>,<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
        </tei:opener>

        <tei:p>Most cordial thanks for the Christmas letter and the good wishes to all of
            us!<tei:ptr corresp="#r0001-fn02" type="footnote"/> We have enjoyed a few lovely,
          peaceful days. This evening <tei:rs type="person" key="entity-003957">Walter</tei:rs> is
          leaving again.</tei:p>

        <tei:closer>
          <tei:salute>With most cordial greetings to you both,</tei:salute>
          <tei:salute rend="indent-40">Your faithful</tei:salute>
          <tei:signed rend="indent-60"><tei:rs type="person" key="entity-000643">Reinhard
              Oppel</tei:rs> and</tei:signed>
          <tei:signed rend="indent-40">the "Light" <tei:rs type="person" key="entity-008523"
              >Bepo</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

      <!-- -->
      <!-- WALTER -->
      <!-- -->


      <tei:div type="part_2">
        <tei:opener>
          <tei:salute><tei:handShift new="#WO"/> Dear <tei:rs type="person" key="entity-000632"
              >Professor</tei:rs>,</tei:salute>
        </tei:opener>

        <tei:p>I have been here for several days now at our home in <tei:rs type="place"
            key="entity-002479">Leipzig</tei:rs> and must return this evening to <tei:rs
            type="place" key="entity-002589">Hamburg</tei:rs> for the start of work tomorrow. It is
          a lot nicer at home than it ever is abroad.</tei:p>

        <tei:closer>
          <tei:salute>With cordial greetings to you and </tei:salute>
          <tei:salute><tei:rs type="person" key="entity-000771">your wife</tei:rs></tei:salute>
          <tei:signed rend="indent-40"> the "Torpedo" (<tei:rs type="person" key="entity-000644"
              >Walter</tei:rs>)</tei:signed>
        </tei:closer>
      </tei:div>

      <!-- -->
      <!-- ULRICH -->
      <!-- -->

      <tei:div type="part_3">
        <tei:opener>
          <tei:salute><tei:handShift new="#UO"/> Dear <tei:rs type="person" key="entity-000632"
              >Professor</tei:rs>,</tei:salute>
        </tei:opener>

        <tei:p>From the holidays, very cordial greetings to you and <tei:rs type="person"
            key="entity-000771">your wife</tei:rs>. The Christmas days were nice indeed, here at
          home and in Büttenfeld. I am off to <tei:rs type="place" key="entity-002501"
            >Berlin</tei:rs> on Saturday.</tei:p>

        <tei:closer>
          <tei:salute>Truly happy New Year wishes</tei:salute>
          <tei:salute>to you both from </tei:salute>
          <tei:salute rend="indent-30">your</tei:salute>
          <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000644">Ulrich</tei:rs>
            ("Armored Vessel")</tei:signed>
        </tei:closer>
      </tei:div>


      <!-- -->
      <!-- ELFRIEDE -->
      <!-- -->


      <tei:div type="part_4">
        <tei:opener/>

        <tei:p/>

        <tei:closer>
          <tei:salute><tei:handShift new="#EO"/>All good wishes for</tei:salute>
          <tei:salute>the New Year and</tei:salute>
          <tei:salute>cordial greetings</tei:salute>
          <tei:signed>Mrs. <tei:rs type="person" key="entity-005266">Elfriede
            Oppel</tei:rs></tei:signed>
        </tei:closer>
      </tei:div>

    </tei:div>

  </sdo:record>
