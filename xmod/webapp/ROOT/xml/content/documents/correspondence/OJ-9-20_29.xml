  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-005545">Breitkopf&amp;Härtel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

      <dc:title>Printed letter from Breitkopf &amp; Härtel to Schenker, dated October 6,
        1902</dc:title>

      <dcterms:created>1902-10-06T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-03</dcterms:dateSubmitted>
      <dc:description>Breitkopf &amp; Härtel acknowledge receipt of the manuscript [of a Schenker
        composition].</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002890">Breitkopf &amp; Härtel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:dateline rend="indent-40"><tei:handShift new="#print"/><tei:rs type="place"
            key="entity-002479">Leipzig</tei:rs>, <tei:handShift new="#BHsten"/><tei:date
            when="1902-10-06">6. Okt. <tei:handShift new="#print"/>190<tei:handShift new="#BHsten"
            />2</tei:date></tei:dateline><tei:lb/>
        <tei:salute rend="indent-10"><tei:handShift new="#print"/>Sehr geehrter <tei:rs
            type="person" key="entity-000632">Herr</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p>Sie hatten die Güte, uns zum Zwecke des Verlages eine Handschrift<tei:note
          xml:id="r0001-fn01" type="editorial" place="foot">Presumably the <tei:title level="m">Drei
            Gesänge für eine tiefere Stimme mit Pianoforte Begleitung</tei:title>, Op. 6,
          unpublished, on which Breitkopf wrote on October 28, 1902 (<tei:ref type="correspondence"
            cRef="OJ-9-20_30">OJ 9/20, [30]</tei:ref>).</tei:note> mit Begleitbrief zu übersenden.
        Gern werden wir uns näher damit beschäftigen, inzwischen bestätigen wir Ihnen umgehend den
        richtigen Erhalt. </tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">Hochachtungsvoll</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:dateline rend="indent-40"><tei:handShift new="#print"/><tei:rs type="place"
            key="entity-002479">Leipzig</tei:rs>, <tei:handShift new="#BHsten"/><tei:date
            when="1902-10-06">October 6, <tei:handShift new="#print"/>190<tei:handShift
              new="#BHsten"/>2</tei:date></tei:dateline><tei:lb/>
        <tei:salute rend="indent-10"><tei:handShift new="#print"/>Dear <tei:rs type="person"
            key="entity-000632">Sir</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p>You were kind enough to send us a manuscript<tei:ptr corresp="#r0001-fn01"
          type="footnote"/> along with a cover letter for the purpose of publication. We will be
        happy to look into it further, and, in the meantime, confirm that we have received it in
        good order.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-60">Respectfully,</tei:salute>
        <tei:signed rend="indent-50"><tei:rs type="organization" key="entity-002890">Breitkopf &amp;
            Härtel</tei:rs></tei:signed>
      </tei:closer>


    </tei:div>
