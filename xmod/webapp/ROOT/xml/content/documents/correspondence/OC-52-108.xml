      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Typewritten letter from Hertzka (UE) to Schenker, dated February 15, 1913</dc:title>

      <dcterms:created>1913-02-15T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-20</dcterms:dateSubmitted>
      <dc:description>Hertzka thanks Schenker for delivery of the Introduction to his elucidatory
        edition of Beethoven sonata Op. 109, and authorizes payment of the first half honorarium
        (600 Kr) for the start of work on Op. 110. He hopes to send the MS of Op. 109 to the
        printers in 8-10 days, and to meet with Schenker in person soon.</dc:description>
      <dc:subject/>

      <marcrel:correspondent key="entity-002408">Universal Edition</marcrel:correspondent>
      <marcrel:correspondent key="entity-000356">Emil Hertzka</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>

    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>„Universal-Edition“ A.-G.</tei:addrLine>
          <tei:addrLine>(Jos. Aibl Verlag, G.m.b.H.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520.</tei:addrLine>
          <tei:addrLine>Wien I. Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Wien</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-02-15">15. Februar 1913</tei:date>.</tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Wohlgeboren Herrn Prof. Dr. <tei:persName>Heinrich
              Schenker</tei:persName></tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:rs type="place" key="entity-002484"><tei:hi
                rend="underline">Wien</tei:hi></tei:rs></tei:addrLine>
        </tei:address>
        <tei:salute>Sehr geehrter Herr <tei:rs key="entity-000632" type="person"
            >Doktor</tei:rs>!<tei:note xml:id="r0001-fn01" type="editorial" place="foot">Receipt of
            this letter is not recorded in Schenker’s diary.</tei:note></tei:salute>
      </tei:opener>

      <tei:p rend="first">Bestens dankend, bestätige ich die spezielle Einführung zu <tei:rs
          type="work" key="entity-001734">op. 109</tei:rs><tei:note xml:id="r0001-fn02"
          type="editorial" place="foot">In response to <tei:ref type="correspondence"
            cRef="WSLB-147">WSLB 147</tei:ref>, February 14, 1913. </tei:note> und lasse Ihnen
        gleichzeitig <tei:add place="interlinear-above"><tei:handShift new="#EH"/>durch der <tei:rs
            type="organization" key="entity-002467">Länderbank</tei:rs></tei:add>
        <tei:handShift new="#TPueW"/>die bei Inangriffnahme von <tei:rs type="work"
          key="entity-001735">op. 110</tei:rs> fälligen 600 Kronen zugehen.<tei:note
          xml:id="r0001-fn03" type="editorial" place="foot">See bank documents <tei:ref
            type="correspondence" cRef="OC-52-109">OC 52/109</tei:ref> and <tei:ref
            type="correspondence" cRef="OC-52-110">OC 52/110</tei:ref>, February 17,
          1913.</tei:note></tei:p>

      <tei:p rend="first">Ich bin erst seit wenigen Tagen wieder in Wien und kann Ihnen daher auch
        nicht annähernd sagen, wie die Drucklegung von <tei:rs type="work" key="entity-001734">op.
          109</tei:rs> disponiert wird. Ich hoffe, dass ich in 8–10 Tagen so weit sein werde, um das
        Manuskript in die Druckerei geben zu können, denn es ist ja doch sehr notwendig, dass wir
        uns über die einheitliche, allerzweckmässigste Art der Herausgabe vollständig klar werden. </tei:p>

      <tei:p rend="first">Ich hoffe, dass ich bald das Vergnügen haben werde mit Ihnen nun auch
        wieder persönlich zusammen zu kommen<tei:note xml:id="r0001-fn04" type="editorial"
          place="foot">As suggested in Hertzka’s letter <tei:ref type="correspondence"
            cRef="OC-52-496">OC 52/496</tei:ref>, of February 5, 1913.</tei:note> und begrüsse Sie
        inzwischen in aufrichtiger Hochschätzung </tei:p>

      <tei:closer>
        <tei:salute rend="indent-80">ergebenst</tei:salute>
        <tei:signed><tei:handShift new="#stamp"/><tei:rs type="organization" key="entity-002408"
            >Universal-Edition</tei:rs> Aktiengesellschaft</tei:signed>
        <tei:signed rend="indent-90"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#printed"/>Universal Edition &amp; Co.</tei:addrLine>
          <tei:addrLine>(Josef Aibl Publishers &amp; Co.)</tei:addrLine>
          <tei:addrLine>Leipzig, Sternwartestrasse 1520</tei:addrLine>
          <tei:addrLine>Vienna I, Reichsratsstrasse 9</tei:addrLine>
          <tei:addrLine><tei:note type="editorial" place="inline"><tei:hi rend="italic"
                >etc.</tei:hi></tei:note></tei:addrLine>
          <tei:lb/>
        </tei:address>
        <tei:byline><tei:handShift new="#TPueW"/>W</tei:byline><tei:lb/>
        <tei:dateline rend="indent-70"><tei:handShift new="#printed"/>
          <tei:placeName>Vienna</tei:placeName>, <tei:handShift new="#TPueW"/><tei:date
            when="1913-02-15">February 15, 1913</tei:date></tei:dateline><tei:lb/>
        <tei:address>
          <tei:addrLine rend="indent-20">Professor <tei:persName>Heinrich Schenker</tei:persName>,
            Esq.</tei:addrLine>
          <tei:addrLine rend="indent-80"><tei:rs type="place" key="entity-002484"><tei:hi
                rend="underline">Vienna</tei:hi></tei:rs></tei:addrLine>
        </tei:address>
        <tei:salute>Dear <tei:rs key="entity-000632" type="person">Dr. <tei:supplied
              reason="identity">Schenker</tei:supplied></tei:rs>,<tei:ptr corresp="#r0001-fn01"
            type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p rend="first">I confirm with thanks <tei:supplied reason="clarity">receipt
          of</tei:supplied> the special Introduction to <tei:rs type="work" key="entity-001734"
            ><tei:title level="m">Op. 109</tei:title></tei:rs>,<tei:ptr corresp="#r0001-fn02"
          type="footnote"/> and am at the same time transferring to you <tei:add
          place="interlinear-above"><tei:handShift new="#EH"/>through the <tei:rs
            type="organization" key="entity-002467">Provincial Bank</tei:rs></tei:add>
        <tei:handShift new="#TPueW"/>the 600 Kronen that are due to you at the start of work on
          <tei:rs type="work" key="entity-001735"><tei:title level="m">Op.
          110</tei:title></tei:rs>.<tei:ptr corresp="#r0001-fn03" type="footnote"/></tei:p>

      <tei:p rend="first">I have been back in Vienna only a few days and cannot therefore tell you
        precisely when the production work on <tei:rs type="work" key="entity-001734"><tei:title
            level="m">Op. 109</tei:title></tei:rs> will be scheduled. I hope to be far enough on in
        eight-to-ten days to be able to hand the manuscript over to the printers, for it is indeed
        crucial that we be completely clear as to the uniform and most appropriate manner of
        publishing your edition. </tei:p>

      <tei:p rend="first">I hope that I shall soon have the pleasure to get together with you once
        again in person,<tei:ptr corresp="#r0001-fn04" type="footnote"/> and I send you in the
        meantime my greetings in true admiration,</tei:p>

      <tei:closer>
        <tei:salute rend="indent-80">Your most devoted</tei:salute>
        <tei:signed><tei:handShift new="#stamp"/><tei:rs type="organization" key="entity-002408"
            >Universal Edition</tei:rs> &amp; Co.</tei:signed>
        <tei:signed rend="indent-90"><tei:handShift new="#EH"/><tei:rs key="entity-000356"
            type="person">Hertzka</tei:rs></tei:signed>
      </tei:closer>


    </tei:div>
