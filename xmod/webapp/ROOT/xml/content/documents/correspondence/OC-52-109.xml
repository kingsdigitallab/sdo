  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002707">Österreichische
        Länderbank ~ HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002700">Hertzka ~
        HSchenker</tei:rs>
      <tei:rs role="correspondence" type="correspondence" key="entity-002701">UE ~
        H+JSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002746">Bank document</tei:rs>




      <dc:title>Notice of bank transaction from the Austrian Provincial Bank to Schenker, dated
        February 17, 1913</dc:title>

      <dcterms:created>1913-02-17T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-06-22</dcterms:dateSubmitted>
      <dc:description>Payment notification of 600 Kronen [from UE via Österreichische
        Länderbank]</dc:description>
      <dc:subject/>


      <marcrel:correspondent key="entity-000356">Hertzka</marcrel:correspondent>
      <marcrel:correspondent key="entity-002408">UE</marcrel:correspondent>
      <marcrel:correspondent key="entity-002467">Österreichische Länderbank</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:note type="editorial" place="inline">printed form with handwritten and stamped
        insertions</tei:note>
      <tei:lb/>
      <tei:note type="editorial" place="inline">Roman type = printed; Italic type = handwritten or
        stamped</tei:note>
      <tei:lb/>
      <tei:ab type="formpart" rend="printed">
        <tei:address>
          <tei:addrLine>KAIS. KÖN. PRIVILEGIRTE</tei:addrLine>
          <tei:addrLine>ÖSTERREICHISCHE LÄNDERBANK.</tei:addrLine>
          <tei:addrLine>
            <tei:note type="editorial" place="inline">etc.</tei:note>
          </tei:addrLine>
        </tei:address>
      </tei:ab>

      <tei:ab type="formpart" rend="printed-indent-50">WIEN, am <tei:seg type="entry" rend="ms">17.
          Feber 1913</tei:seg></tei:ab>

      <tei:ab type="formpart" rend="printed">
        <tei:seg type="entry" rend="ms">
          <tei:address>
            <tei:addrLine>Herrn Prof. D<tei:hi rend="supralinear">r.</tei:hi> Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine rend="indent-70">
              <tei:hi rend="underline">Wien III</tei:hi>
            </tei:addrLine>
            <tei:addrLine rend="indent-70">Reisnerstr. 38</tei:addrLine>
          </tei:address>
        </tei:seg>
      </tei:ab>

      <tei:ab type="formpart" rend="printed">Im Auftrage <tei:seg type="entry" rend="ms"
          >Universal-Edition A. G.</tei:seg><tei:note xml:id="r0001-fn01" type="editorial"
          place="foot">Receipt of this notification is not recorded in Schenker’s
        diary.</tei:note></tei:ab>
      <tei:ab type="formpart" rend="printed">und für Rechnung <tei:note type="editorial"
          place="inline">entry left blank</tei:note> Wien</tei:ab>
      <tei:ab type="formpart" rend="printed">senden wir Ihnen <tei:seg type="entry" rend="stamp">PER
          POSTANWEISUNG</tei:seg>
      </tei:ab>
      <tei:ab type="formpart" rend="stamped">
        <tei:seg type="entry" rend="ms">K. 600.–</tei:seg>
      </tei:ab>
      <tei:ab type="formpart" rend="printed">worüber wir uns Ihre gefl. Empfangsanzeige
          erbitten.<tei:note xml:id="r0001-fn02" type="editorial" place="foot"
            >See <tei:ref type="correspondence" cRef="OC-52-110">OC 52/110</tei:ref>.</tei:note></tei:ab>

      <tei:closer>
        <tei:salute rend="indent-70"><tei:handShift new="#pr"/>Achtungsvoll</tei:salute>
        <tei:salute rend="indent-50">Für die Bank-Abteilung der </tei:salute>
        <tei:signed rend="indent-40"><tei:handShift new="#stamp"/><tei:rs type="organization"
            key="entity-002467">KAIS. KÖN. PRIVILEGIRTE ÖSTERREICHISCHE
          LÄNDERBANK</tei:rs></tei:signed>
        <tei:signed rend="indent-50"><tei:handShift new="#unkLB"/><tei:unclear reason="reading"
            >Zelzer</tei:unclear>
        </tei:signed>
      </tei:closer>

      <tei:postscript>
        <tei:p><tei:handShift new="#pr"/>NB. Briefe, aus denen eine Verbindlichkeit für die Bank
          resultiert, werden firmamäßig (§ 37 der Statuten) gefertigt.</tei:p>
      </tei:postscript>

    </tei:div>


    <tei:div type="translation">

      <tei:note type="editorial" place="inline">printed form with handwritten and stamped
        insertions</tei:note>
      <tei:lb/>
      <tei:note type="editorial" place="inline">Roman type = printed; Italic type = handwritten or
        stamped</tei:note>
      <tei:lb/>
      <tei:ab type="formpart" rend="printed">
        <tei:address>
          <tei:addrLine>IMPERIAL-ROYAL PRIVILEGED </tei:addrLine>
          <tei:addrLine>AUSTRIAN PROVINCIAL BANK</tei:addrLine>
          <tei:addrLine>
            <tei:note type="editorial" place="inline">etc.</tei:note>
          </tei:addrLine>
        </tei:address>
      </tei:ab>

      <tei:ab type="formpart" rend="printed-indent-50">VIENNA, <tei:seg type="entry" rend="ms"
          >February 17, 1913</tei:seg></tei:ab>

      <tei:ab type="formpart" rend="printed">
        <tei:seg type="entry" rend="ms">
          <tei:address>
            <tei:addrLine>Prof. Heinrich Schenker, Esq.</tei:addrLine>
            <tei:addrLine rend="indent-70">
              <tei:hi rend="underline">Vienna III</tei:hi>
            </tei:addrLine>
            <tei:addrLine rend="indent-70">Reisnerstraße 38</tei:addrLine>
          </tei:address>
        </tei:seg>
      </tei:ab>

      <tei:ab type="formpart" rend="printed">On instructions from <tei:seg type="entry" rend="ms"
          >Universal Edition &amp; Co.</tei:seg><tei:ptr corresp="#r0001-fn01" type="footnote"
        /></tei:ab>
      <tei:ab type="formpart" rend="printed">and to the account of <tei:note type="editorial"
          place="inline">entry left blank</tei:note> Vienna</tei:ab>
      <tei:ab type="formpart" rend="printed">we are sending to you <tei:seg type="entry"
          rend="stamp">BY POSTAL MONEY ORDER</tei:seg>
      </tei:ab>
      <tei:ab type="formpart" rend="stamped">
        <tei:seg type="entry" rend="ms">600.– Kronen</tei:seg>
      </tei:ab>
      <tei:ab type="formpart" rend="printed">for which we request your written acknowledgement of
          receipt.<tei:ptr corresp="#r0001-fn02" type="footnote"/></tei:ab>

      <tei:closer>
        <tei:salute rend="indent-70"><tei:handShift new="#pr"/>Respectfully,</tei:salute>
        <tei:salute rend="indent-50">For the bank division of the </tei:salute>
        <tei:signed rend="indent-40"><tei:handShift new="#stamp"/><tei:rs type="organization"
            key="entity-002467">IMPERIAL-ROYAL PRIVILEGED AUSTRIAN PROVINCIAL
          BANK</tei:rs></tei:signed>
        <tei:signed rend="indent-50"><tei:handShift new="#unkLB"/><tei:unclear
            reason="original_unclear">Zelzer</tei:unclear>
        </tei:signed>
      </tei:closer>

      <tei:postscript>
        <tei:p><tei:handShift new="#pr"/>NB. Letters from which a liability on the part of the Bank
          arises will be prepared in accordance with the company (§ 37 of the statutes)</tei:p>
      </tei:postscript>


    </tei:div>

  </sdo:record>
