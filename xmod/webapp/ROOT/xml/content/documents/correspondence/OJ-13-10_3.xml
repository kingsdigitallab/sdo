 <sdo:record ID="r0001">
  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>

   <dc:title>Handwritten letter from Oppel to Schenker, dated Aprll 29, 1914</dc:title>

   <dcterms:created>1914-04-29T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-04-21</dcterms:dateSubmitted>
   <dc:description>Oppel thanks Schenker for the advice he has given him about his most recent
    composition. He will send more in the autumn.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000643">Oppel</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">
   <tei:opener>
    <tei:dateline><tei:rs type="place" key="entity-002757">Kiel</tei:rs>, <tei:date
      when="1914-04-29">29. IV. 1914</tei:date>
    </tei:dateline>
    <tei:address rend="indent-60">
     <tei:addrLine>Feldstr 77<tei:hi rend="supralinear">IV.</tei:hi></tei:addrLine>
    </tei:address>
    <tei:salute rend="indent-10">Sehr geehrter Herr D<tei:hi rend="supralinear">r.</tei:hi>
     <tei:rs type="person" key="entity-000632">Schenker</tei:rs>![1]</tei:salute>
   </tei:opener>

   <tei:p>Arbeit </tei:p>

   <tei:p>Nun </tei:p>

   <tei:p>Überhaupt </tei:p>

   <tei:p>Auch </tei:p>

   <tei:p>Nun </tei:p>

   <tei:closer>
    <tei:salute rend="indent-10">Mit den besten Wünschen und Grüßen </tei:salute>
    <tei:salute rend="indent-10">bleibe ich Ihr </tei:salute>
    <tei:salute>sehr ergebener und dankbarer </tei:salute>
    <tei:signed rend="indent-20"><tei:rs type="person" key="entity-000643">Reinhard
     Oppel</tei:rs>.</tei:signed>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">
   <tei:opener>
    <tei:dateline><tei:rs type="place" key="entity-002757">Kiel</tei:rs>, <tei:date
      when="1914-04-29">29. April 29, 1914</tei:date>
    </tei:dateline>
    <tei:address rend="indent-60">
     <tei:addrLine>Feldstraße 77/4</tei:addrLine>
    </tei:address>
    <tei:salute rend="indent-10">Dear Dr. <tei:rs type="person" key="entity-000632"
      >Schenker</tei:rs>,[1]</tei:salute>
   </tei:opener>

   <tei:p>Arbeit </tei:p>

   <tei:p>Nun </tei:p>

   <tei:p>Überhaupt </tei:p>

   <tei:p>Auch </tei:p>

   <tei:p>Nun </tei:p>

   <tei:closer>
    <tei:salute rend="indent-10">Mit den besten Wünschen und Grüßen </tei:salute>
    <tei:salute rend="indent-10">bleibe ich Ihr </tei:salute>
    <tei:salute>sehr ergebener und dankbarer </tei:salute>
    <tei:signed rend="indent-20"><tei:rs type="person" key="entity-000643">Reinhard
     Oppel</tei:rs>.</tei:signed>
   </tei:closer>


