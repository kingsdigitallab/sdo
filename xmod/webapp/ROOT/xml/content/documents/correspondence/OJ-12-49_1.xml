 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002750">Note</tei:rs>



   <dc:title>Handwritten notelet from Mandyczewski to Schenker, dated November 9, 1898</dc:title>

   <dcterms:created>1898-11-09T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-24</dcterms:dateSubmitted>
   <dc:description>Mandyczewski comments on Otto Jahn's book [on Mozart?].</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000562">EMandyczewski</marcrel:correspondent>
   <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:salute><tei:handShift new="#EM"/>Meine Jugend, <tei:rs type="person" key="entity-000632"
      >Verehrtester</tei:rs>?<tei:note xml:id="r0001-fn01" type="editorial" place="foot">The
      superlative form of address suggests that the two men had been acquainted for some years. The
      question-mark implies that Schenker’s previous communication had referred to Mandyczewski’s
      youth, and quite possibly also the Jahn book.</tei:note></tei:salute>
   </tei:opener>

   <tei:p rend="indent-10">Ich wünsche mir doch für heute und auch für das Alter kein Rosenbett, und
    möchte mit keinem tauschen, der eines hat. <tei:hi rend="underline">die</tei:hi>
    <tei:hi rend="underline">Dornen</tei:hi>! Denken Sie nur! Und wer sich gar <tei:rs type="person"
     key="entity-003455">Jahn</tei:rs>s herrliches Buch<tei:note xml:id="r0001-fn02"
     type="editorial" place="foot">Presumably <tei:bibl><tei:author>Otto Jahn</tei:author>,
       <tei:title level="m">W. A. Mozart</tei:title> (Leipzig: Breitkopf &amp; Härtel,
      1856–59)</tei:bibl>, of which Schenker later owned the 3rd edition, ed. H. Deiters (1889);
     Schenker also owned his <tei:bibl><tei:title level="m">Gesammelte Aufsätze über
       Musik</tei:title> (ibid, 1866)</tei:bibl>: see <tei:bibl><tei:title level="m">Musik und
       Theater enthaltend die Bibliothek des Herrn †Dr. Heinrich Schenker, Wien</tei:title> (Vienna,
      Heinrich Hinterberger, [1936])</tei:bibl>.</tei:note> wirklich zu <tei:hi rend="underline"
     >Gemüthe</tei:hi> geführt hat, lernt leicht Bescheidenheit. </tei:p>

   <tei:closer>
    <tei:salute rend="indent-20">Herzlich dankend und grüßend</tei:salute>
    <tei:salute rend="indent-60">Ihr</tei:salute>
    <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1898-11-09">9. 11. 98.</tei:date></tei:dateline>
   </tei:closer>


  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:salute><tei:handShift new="#EM"/>My youth, <tei:rs type="person" key="entity-000632">Most
      revered</tei:rs>?<tei:ptr corresp="#r0001-fn01" type="footnote"/></tei:salute>
   </tei:opener>

   <tei:p rend="indent-10">I do not wish for myself, for today or for my old age, a bed of roses,
    and I would not like to change places with anyone who has one. <tei:hi rend="underline"
     >The</tei:hi>
    <tei:hi rend="underline">thorns</tei:hi>! Just think of it! And anyone who has ever taken
     <tei:rs type="person" key="entity-003455">Jahn</tei:rs>’s magnificent book<tei:ptr
     corresp="#r0001-fn02" type="footnote"/> to <tei:hi rend="underline">heart</tei:hi> will easily
    learn modesty. </tei:p>

   <tei:closer>
    <tei:salute rend="indent-20">With cordial thanks and greetings,</tei:salute>
    <tei:salute rend="indent-60">your</tei:salute>
    <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1898-11-09">November 9, 1898</tei:date></tei:dateline>
   </tei:closer>

  </tei:div>
 </sdo:record>
