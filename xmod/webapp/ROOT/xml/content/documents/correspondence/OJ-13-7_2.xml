  <sdo:record ID="r0001">

    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-008546">OchsS ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002744">Letter</tei:rs>



      <dc:title>Handwritten letter from Siegfried Ochs to Schenker, dated June 20, 1903</dc:title>

      <dcterms:created>1903-06-20T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-11-14</dcterms:dateSubmitted>
      <dc:description>Siegfried Ochs returns choral pieces of Schenker's as too short for
        performance.</dc:description>
      <dc:subject/>


      <marcrel:correspondent key="entity-000638">Siegfried Ochs</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#print"/>BENDLERSTR. 8.</tei:addrLine>
          <tei:addrLine>BERLIN, W. 10.</tei:addrLine>
          <tei:addrLine>(SPRECHSTUNDE: 10–12 VORM.)</tei:addrLine>
        </tei:address>
        <tei:dateline>DEN <tei:date when="1903-06-20"><tei:handShift new="#SO"/>20. Juni
              <tei:handShift new="#print"/>1903</tei:date></tei:dateline><tei:lb/>
        <tei:salute rend="indent-30"><tei:handShift new="#SO"/>Sehr geehrter <tei:rs type="person"
            key="entity-000632">Herr</tei:rs>!</tei:salute>
      </tei:opener>

      <tei:p rend="first">Ihre Chorstücke<tei:note xml:id="r0001-fn01" type="editorial" place="foot"
          >Schenker wrote three unaccompanied songs for mixed chorus, Op. 7 and four unaccompanied
          choruses for female voices, Op. 8, none dated; neither opus was published.</tei:note>
        erlaube ich mir, Ihnen heute wieder zurückzusenden, da ich, so hübsch ich die Compositionen
        finde, sie nicht zur Aufführung bringen kann. Wir haben für Werke so geringen Umfanges
        höchst selten auf unseren Programmen Platz.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">Mit den besten Empfehlungen</tei:salute>
        <tei:salute rend="indent-70">sehr ergebenst</tei:salute>
        <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000638">Siegfried
            Ochs</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:address>
          <tei:addrLine><tei:handShift new="#print"/>BENDLERSTRASSE 8</tei:addrLine>
          <tei:addrLine>BERLIN, W. 10</tei:addrLine>
          <tei:addrLine>(CONSULTING HOUR: 10–12 A. M.)</tei:addrLine>
        </tei:address>
        <tei:dateline><tei:date when="1903-06-20"><tei:handShift new="#SO"/>June 20, <tei:handShift
              new="#print"/>1903</tei:date></tei:dateline><tei:lb/>
        <tei:salute rend="indent-30"><tei:handShift new="#SO"/>Dear <tei:rs type="person"
            key="entity-000632">Sir</tei:rs>,</tei:salute>
      </tei:opener>

      <tei:p rend="first">I am taking the liberty of returning your choral pieces<tei:ptr
          corresp="#r0001-fn01" type="footnote"/> to you today because, as lovely as I find the
        compositions, I cannot get them performed. It is most rare that we have room on our programs
        for works of such small scope.</tei:p>

      <tei:closer>
        <tei:salute rend="indent-50">With kindest regards,</tei:salute>
        <tei:salute rend="indent-70"><tei:supplied>your</tei:supplied> very devoted</tei:salute>
        <tei:signed rend="indent-70"><tei:rs type="person" key="entity-000638">Siegfried
            Ochs</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>
