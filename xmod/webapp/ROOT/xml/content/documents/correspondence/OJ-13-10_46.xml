  <sdo:record ID="r0001">
    <sdo:itemDesc>
      <tei:rs role="correspondence" type="correspondence" key="entity-002734">Oppel ~
        HSchenker</tei:rs>
      <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002751">Picture
        postcard</tei:rs>

      <dc:title>Handwritten postcard from Reinhard, Walter &amp; Ulrich Oppel to Heinrich &amp;
        Jeanette Schenker, dated August 4, 1927</dc:title>

      <dcterms:created>1927-08-04T12:00:00Z</dcterms:created>
      <dcterms:dateSubmitted>2025-07-31</dcterms:dateSubmitted>
      <dc:description>Oppel and his sons report their safe arrival back in Heiterwang
        (Tyrol).</dc:description>
      <dc:subject/>



      <marcrel:correspondent key="entity-000643">Reinhard Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-003957">Walter Oppel</marcrel:correspondent>
      <marcrel:correspondent key="entity-000644">Ulrich Oppel</marcrel:correspondent>
      <marcrel:recipient key="entity-000632">HSchenker</marcrel:recipient>
      <marcrel:recipient key="entity-000771">JSchenker</marcrel:recipient>
    </sdo:itemDesc>


    <tei:div type="transcription">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">photograph, captioned: “Plansee gegen
          Heiterwangersee und Thaneller</tei:note><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>An: </tei:supplied><tei:handShift new="#RO"/>Herrn Prof
                D<tei:hi rend="supralinear">r.</tei:hi> Heinrich Schenker</tei:addrLine>
            <tei:addrLine><tei:hi rend="underline">Galtür</tei:hi> / Paznauntal</tei:addrLine>
            <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| REUTTE–INNSBRUCK | 4. <tei:gap reason="illegible"/> 27 |
              <tei:gap reason="illegible"/> ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1927-08-04">4. VIII 27 </tei:date>.
          Liebe <tei:rs type="person" key="entity-000632">Herr</tei:rs> u. <tei:rs type="person"
            key="entity-000771">Frau</tei:rs> Schenker,<tei:note xml:id="r0001-fn01"
            type="editorial" place="foot">Receipt of this postcard is not recorded in Schenker’s
            diary. — Thaneller: a mountain in the Lechtaler Alps, 2,431 meters above sea level,
            lying about a mile and a half southwest of Heiterwang.</tei:note></tei:salute>
      </tei:opener>

      <tei:p>Wir kamen gut zurück u. zehren noch von allen Eindrücken!</tei:p>

      <tei:closer>
        <tei:salute>Alles Gute u. die herzlichsten Grüsse!</tei:salute>
        <tei:salute>Ihre</tei:salute>
        <tei:signed><tei:rs type="person" key="entity-000643">Reinh. Oppel</tei:rs>, <tei:handShift
            new="#WO"/><tei:rs type="person" key="entity-003957">Walter</tei:rs>, <tei:handShift
            new="#UO"/><tei:rs type="person" key="entity-000644">Ulrich</tei:rs>.</tei:signed>
      </tei:closer>

    </tei:div>


    <tei:div type="translation">

      <tei:opener>
        <tei:milestone unit="folio" n="verso"/><tei:lb/>
        <tei:note type="editorial" place="inline">photograph, captioned: “Plansee toward
          Heiterwangersee and Thaneller”</tei:note><tei:lb/>
        <tei:milestone unit="folio" n="recto"/><tei:lb/>
        <tei:fw type="envelope">
          <tei:address>
            <tei:addrLine><tei:supplied>To: </tei:supplied><tei:handShift new="#RO"/>Prof. Heinrich
              Schenker</tei:addrLine>
            <tei:addrLine><tei:hi rend="underline">Galtür</tei:hi>, Paznaun Valley</tei:addrLine>
            <tei:addrLine>Alpenhaus Fluchthorn</tei:addrLine>
          </tei:address>
          <tei:lb/>
          <tei:fw type="postmark">|| REUTTE–INNSBRUCK | 4. <tei:gap reason="illegible"/> 27 |
              <tei:gap reason="illegible"/> ||</tei:fw>
          <tei:lb/>
        </tei:fw>
        <tei:salute><tei:handShift new="#RO"/><tei:date when="1927-08-08">August 4, 1927</tei:date>.
          Dear <tei:rs type="person" key="entity-000632">Mr.</tei:rs> and <tei:rs type="person"
            key="entity-000771">Mrs.</tei:rs> Schenker,<tei:ptr corresp="#r0001-fn01"
            type="footnote"/></tei:salute>
      </tei:opener>

      <tei:p>We got back safely and are relishing all the impressions!</tei:p>

      <tei:closer>
        <tei:salute>Best wishes and cordial greetings!</tei:salute>
        <tei:salute>Your</tei:salute>
        <tei:signed><tei:rs type="person" key="entity-000643">Reinh. Oppel</tei:rs>, <tei:handShift
            new="#WO"/><tei:rs type="person" key="entity-003957">Walter</tei:rs>, <tei:handShift
            new="#UO"/><tei:rs type="person" key="entity-000644">Ulrich</tei:rs></tei:signed>
      </tei:closer>

    </tei:div>

  </sdo:record>
