 <sdo:record ID="r0001">

  <sdo:itemDesc>
   <tei:rs role="correspondence" type="correspondence" key="entity-005513">Mandyczewski ~
    HSchenker</tei:rs>
   <tei:rs role="corr-item-type" type="corr-item-type" key="entity-002745">Postcard</tei:rs>



   <dc:title>Handwritten postcard from Mandyczewski to Schenker, dated February 27, 1925</dc:title>

   <dcterms:created>1925-02-27T12:00:00Z</dcterms:created>
   <dcterms:dateSubmitted>2025-10-27</dcterms:dateSubmitted>
   <dc:description>Mandyczewski will make the materials available to Schenker at a modest
    charge.</dc:description>
   <dc:subject/>



   <marcrel:correspondent key="entity-000562">EMandyczewski</marcrel:correspondent>
   <marcrel:recipient key="entity-000623">HSchenker</marcrel:recipient>
  </sdo:itemDesc>


  <tei:div type="transcription">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:fw type="header" rend="center"><tei:hi rend="bold">Post<tei:supplied reason="overstamped"
       >karte</tei:supplied></tei:hi></tei:fw><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:handShift new="#pr"/>An: <tei:handShift new="#EM"/>Herrn D<tei:hi
        rend="supralinear">r.</tei:hi>
       <tei:hi rend="lateinschr">Heinr. Schenker</tei:hi></tei:addrLine>
      <tei:addrLine rend="indent-60"><tei:handShift new="#pr"/>in <tei:handShift new="#EM"/><tei:hi
        rend="lateinschr">Wien</tei:hi> III</tei:addrLine>
      <tei:addrLine>Keilgasse 8</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 WIEN 1 | 27. II <tei:gap reason="illegible"/> | * 4a *
      ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| 1/1 WIEN 1 | <tei:gap reason="illegible"/> 5 | * <tei:gap
       reason="illegible"/> * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute><tei:rs type="person" key="entity-000632">Verehrtester</tei:rs>!<tei:note
      xml:id="r0001-fn01" type="editorial" place="foot">Receipt of this postcard is recorded in
      Schenker’s diary for February 28, 1925: “Von Mandyczewski K.): hat mich mißverstanden, hält
      die Blätter zur Verfügung – als hätte ich sie noch nicht.” (“From Mandyczewski (postcard): has
      misunderstood me, is willing to provide the leaves – as if I did not have them already.”). –
      Schenker’s preceding letter to Mandyczewski is recorded in his diary for September 26, 1925:
      “An Mandyczewski (Br.): bitte um die Erlaubnis, die Brahms-Quintenblätter facsimiliren u.
      beilegen zu dürfen.” (“To Mandyczewski (letter): I ask for permission to photograph the leaves
      of the Brahms Fifths <tei:supplied reason="clarity">manuscript</tei:supplied> and include
      them.”). – This clarifies that the leaves mentioned in Mandyczewski’s postcard are those of
      Brahms’s manuscript of parallel fifths and octaves in music of the 16th to 19th centuries on
      which Schenker worked with the help of <tei:rs type="person" key="entity-000643">Reinhard
       Oppel</tei:rs> between 1929 and 1933, with the eventual publication of <tei:bibl><tei:rs
        type="work" key="entity-003331"><tei:title level="m">Oktaven und Quinten u. A.</tei:title>
        (Vienna: Universal Edition, 1933)</tei:rs></tei:bibl>.</tei:note></tei:salute>
   </tei:opener>


   <tei:p rend="first">Es ist selbstverständlich Alles zu Ihren Diensten, ich werde nur um eine
    bescheidene Benützungsgebühr bitten. Lassen Sie mich etwa 2–3 Tage früher wissen, <tei:hi
     rend="underline">wann</tei:hi> Sie kommen, damit ich die Blätter bereit legen kann. </tei:p>

   <tei:closer>
    <tei:salute rend="indent-40">Bestens grüßend Ihr</tei:salute>
    <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1925-02-27">27/2 25</tei:date></tei:dateline>
   </tei:closer>

  </tei:div>


  <tei:div type="translation">

   <tei:opener>
    <tei:milestone unit="folio" n="recto"/><tei:lb/>
    <tei:fw type="header" rend="center"><tei:hi rend="bold">Post<tei:supplied reason="overstamped"
       >card</tei:supplied></tei:hi></tei:fw><tei:lb/>
    <tei:fw type="envelope">
     <tei:address>
      <tei:addrLine><tei:handShift new="#pr"/>To: <tei:handShift new="#EM"/>Dr. Heinrich
       Schenker</tei:addrLine>
      <tei:addrLine rend="indent-60"><tei:handShift new="#pr"/>in <tei:handShift new="#EM"/>Vienna
       III</tei:addrLine>
      <tei:addrLine>Keilgasse 8</tei:addrLine>
     </tei:address><tei:lb/>
     <tei:fw type="postmark">|| 1/1 VIENNA 1 | 27. II <tei:gap reason="illegible"/> | * 4a *
      ||</tei:fw><tei:lb/>
     <tei:fw type="postmark">|| 1/1 VIENNA 1 | <tei:gap reason="illegible"/> 5 | * <tei:gap
       reason="illegible"/> * ||</tei:fw><tei:lb/>
     <tei:milestone unit="folio" n="verso"/><tei:lb/>
    </tei:fw>
    <tei:salute>Most revered <tei:supplied reason="identity"><tei:rs type="person"
       key="entity-000632">Dr. Schenker</tei:rs></tei:supplied>,<tei:ptr corresp="#r0001-fn01"
      type="footnote"/></tei:salute>
   </tei:opener>


   <tei:p rend="first">Everything is, needless to say, at your service. I will ask only for a modest
    fee for usage. Let me know some two to three days ahead of time <tei:hi rend="underline"
     >when</tei:hi> you will be coming, so that I can have the leaves ready for you.</tei:p>

   <tei:closer>
    <tei:salute rend="indent-40">Best greetings, your</tei:salute>
    <tei:signed rend="indent-50"><tei:rs type="person" key="entity-000562"
     >Mandyczewski</tei:rs></tei:signed><tei:lb/>
    <tei:dateline><tei:date when="1925-02-27">February 27, 1925</tei:date></tei:dateline>
   </tei:closer>

  </tei:div>
