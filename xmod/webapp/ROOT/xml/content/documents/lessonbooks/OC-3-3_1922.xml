    <sdo:record ID="r0006">
        <sdo:itemDesc>
            <tei:rs role="pupil" type="person" key="entity-000605">Mond, Frau</tei:rs>
            <dc:title>Frau Mond: lessons: 1922/23</dc:title>


            <dcterms:created>1923-06-30T12:00:00Z</dcterms:created>
            <dcterms:dateSubmitted>2025-04-16</dcterms:dateSubmitted>

            <dc:description/>
